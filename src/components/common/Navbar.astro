            }

            .mega-link {
                text-decoration: none;
                padding: 1.5rem;
                border-radius: 1.2rem;
                transition: all 0.4s var(--transition-premium);
                display: flex;
                flex-direction: row;
                gap: 1.5rem;
                align-items: center;
                border: 1px solid transparent;
                background: transparent;
            }

            .premium-card:hover {
                background: white;
                border-color: var(--border-color);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
                transform: translateY(-4px);
            }

            .mega-link-icon {
                width: 64px;
                height: 64px;
                min-width: 64px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #f8fafc;
                border-radius: 16px;
                color: var(--icon-color, var(--brand-green));
                transition: all 0.4s ease;
            }

            .premium-card:hover .mega-link-icon {
                background: var(--icon-color, var(--brand-green));
                color: white;
                transform: scale(1.1) rotate(5deg);
            }

            .mega-link-content {
                display: flex;
                flex-direction: column;
            }

            .mega-link-title {
                font-family: var(--font-primary);
                font-weight: 700;
                font-size: 1.25rem;
                color: var(--text-primary);
                margin-bottom: 0.35rem;
                transition: color 0.3s ease;
            }

            .mega-link:hover .mega-link-title {
                color: var(--brand-blue);
            }

            .mega-link-desc {
                font-family: var(--font-primary);
                font-size: 0.9rem;
                color: var(--text-secondary);
                line-height: 1.5;
            }

            .sidebar-btn {
                background: #f1f5f9;
                color: var(--text-primary);
                padding: 1.2rem;
                border-radius: 1rem;
                text-decoration: none;
                font-family: var(--font-primary);
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 0.8rem;
                transition: all 0.3s ease;
                width: 100%;
                justify-content: center;
            }

            .sidebar-btn:hover {
                background: var(--brand-blue);
