---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

const prefixPath = (path: string) => {
    if (lang === "es") return path;
    return `/${lang}${path}`;
};

// Function to get the path for the other language
const getSwitchLangPath = (targetLang: string) => {
    const path = currentPath;
    if (targetLang === "en") {
        if (path.startsWith("/en")) return path;
        return `/en${path === "/" ? "" : path}`;
    } else {
        if (path.startsWith("/en/")) return path.replace("/en/", "/");
        if (path === "/en") return "/";
        return path;
    }
};

// Data for navigation
const navLinks = [
    { name: t("navbar.sustainability"), href: prefixPath("/#valores") },
    { name: t("nav.activities"), href: prefixPath("/impacto-circular") },
];

const productsItems = [
    {
        name: t("navbar.ceprobio"),
        desc: t("navbar.ceprobio_desc"),
        href: prefixPath("/lineas-de-negocio/ceprobio"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7c-1.18 0-2.29-.29-3.27-.8"/><path d="M11 20c-1.17 0-2.31-.29-3.32-.82C4.59 17.5 3.5 15 3.5 12c0-5.5 4.5-10 10-10"/></svg>`,
        color: "#67bd45",
    },
    {
        name: t("navbar.proveeduria"),
        desc: t("navbar.proveeduria_desc"),
        href: prefixPath("/lineas-de-negocio/proveeduria"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
        color: "#006db6",
    },
    {
        name: t("navbar.balik"),
        desc: t("navbar.balik_desc"),
        href: prefixPath("/lineas-de-negocio/balik"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7c.5 0 1 .2 1.4.6.4.4.6.9.6 1.4 0 .5-.2 1-.6 1.4-.4.4-.9.6-1.4.6h-2c-.5 0-1-.2-1.4-.6-.4-.4-.6-.9-.6-1.4 0-.5.2-1 .6-1.4.4-.4.9-.6 1.4-.6h2Z"/><path d="M12 13h.01"/><path d="M18 13h.01"/><path d="M6 13h.01"/><path d="M12 18h.01"/><path d="M18 18h.01"/><path d="M6 18h.01"/><path d="M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2"/></svg>`,
        color: "#00a9e0",
    },
    {
        name: t("navbar.proyectos"),
        desc: t("navbar.proyectos_desc"),
        href: prefixPath("/nuestros-proyectos"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/><path d="M7 3v13"/><path d="M17 3v13"/><path d="M12 3v13"/></svg>`,
        color: "#f39200",
    },
    {
        name: t("navbar.planta"),
        desc: t("navbar.planta_desc"),
        href: prefixPath("/lineas-de-negocio/planta-de-tratamiento"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7Z"/></svg>`,
        color: "#009640",
    },
];

const aboutItems = [
    {
        name: "Propósito y Esencia",
        desc: "Comprometidos con el ecosistema marino y el campo.",
        href: prefixPath("/nosotros#quienes-somos"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
        color: "#67bd45",
    },
    {
        name: "Modelo Circular",
        desc: "Transformando residuos en nutrición orgánica.",
        href: prefixPath("/nosotros#modelo-circular"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20"/><path d="M2 12h20"/><path d="M12 2a14.5 14.5 0 0 1 0 20"/></svg>`,
        color: "#006db6",
    },
    {
        name: "Ejes Estratégicos",
        desc: "Nuestros pilares operativos y tecnológicos.",
        href: prefixPath("/nosotros#ejes-economicos"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-7"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/></svg>`,
        color: "#00a9e0",
    },
    {
        name: "Nuestro Equipo",
        desc: "El talento humano detrás de la innovación.",
        href: prefixPath("/nosotros#nuestro-equipo"),
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
        color: "#f39200",
    },
];

const isTransparentPage =
    currentPath === "/" ||
    currentPath === "/en" ||
    currentPath === "/en/" ||
    currentPath.includes("/ceprobio") ||
    currentPath.includes("/proveeduria") ||
    currentPath.includes("/balik") ||
    currentPath.includes("/nosotros");

const isBalik = currentPath.includes("/balik");

const headerClass = isTransparentPage
    ? "main-header"
    : "main-header solid subpage";
---

<header class={`${headerClass} ${isBalik ? "balik-nav" : ""}`} id="mainHeader">
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="top-bar-inner">
            <a href={prefixPath("/contacto")} class="top-link">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m22 2-10 11"></path><path d="m22 2-7 20-4-9-9-4Z"
                    ></path></svg
                >
                {t("nav.contact")}
            </a>
            <a
                href={getSwitchLangPath(lang === "es" ? "en" : "es")}
                class="top-link lang-switcher"
            >
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path
                        d="M12 2a14.5 14.5 0 0 0 0 20"></path><path d="M2 12h20"
                    ></path><path d="M12 2a14.5 14.5 0 0 1 0 20"></path></svg
                >
                {lang === "es" ? "English (EN)" : "Español (ES)"}
            </a>
        </div>
    </div>

    <!-- Navigation Main -->
    <nav class="nav-container">
        <div class="nav-inner">
            <!-- Logo -->
            <a href={prefixPath("/")} class="nav-logo-link">
                <Image
                    src="/images/greenprod-blanco.png"
                    alt="Logo"
                    width={181}
                    height={56}
                    class="logo logo-white"
                    id="logoWhite"
                    loading="eager"
                />
                <Image
                    src="/images/greenprod.png"
                    alt="Logo"
                    width={181}
                    height={56}
                    class="logo logo-dark"
                    id="logoDark"
                    loading="eager"
                />
            </a>

            <!-- Desktop Menu -->
            <div class="desktop-menu">
                <div class="menu-item has-dropdown" data-dropdown="nosotros">
                    <a class="nav-link" href={prefixPath("/nosotros")}>
                        SOBRE NOSOTROS
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        >
                    </a>
                    <div class="mega-menu" id="dropdown-nosotros">
                        <div class="mega-content">
                            <div class="mega-main">
                                <h3
                                    class="mega-title uppercase tracking-widest"
                                >
                                    {t("nav.about") || "Sobre Nosotros"}
                                </h3>
                                <div class="mega-grid two-cols">
                                    {
                                        aboutItems.map((item) => (
                                            <a
                                                href={item.href}
                                                class="mega-link premium-card"
                                                aria-label={`${item.name} - ${item.desc}`}
                                            >
                                                <div
                                                    class="mega-link-icon"
                                                    style={`--icon-color: ${item.color}`}
                                                    set:html={item.icon}
                                                    aria-hidden="true"
                                                />
                                                <div class="mega-link-content">
                                                    <span class="mega-link-title">
                                                        {item.name}
                                                    </span>
                                                    <span class="mega-link-desc">
                                                        {item.desc}
                                                    </span>
                                                </div>
                                            </a>
                                        ))
                                    }
                                </div>
                            </div>
                            <div class="mega-sidebar">
                                <a
                                    href={prefixPath("/contacto")}
                                    class="sidebar-btn"
                                >
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path
                                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                        ></path>
                                    </svg>
                                    {t("navbar.work_with_us")}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="menu-item has-dropdown" data-dropdown="productos">
                    <button class="nav-link">
                        {t("navbar.products_services_title")}
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        >
                    </button>
                    <!-- Mega Menu PRODUCTOS -->
                    <div class="mega-menu" id="dropdown-productos">
                        <div class="mega-content">
                            <div class="mega-main">
                                <h3
                                    class="mega-title uppercase tracking-widest"
                                >
                                    {
                                        t("navbar.products_services_title") ||
                                            "Nuestras Líneas"
                                    }
                                </h3>
                                <div class="mega-grid three-cols">
                                    {
                                        productsItems.map((item) => (
                                            <a
                                                href={item.href || "#"}
                                                class="mega-link premium-card"
                                            >
                                                <div
                                                    class="mega-link-icon"
                                                    style={`--icon-color: ${item.color}`}
                                                    set:html={item.icon}
                                                    aria-hidden="true"
                                                />
                                                <div class="mega-link-content">
                                                    <span class="mega-link-title">
                                                        {item.name ||
                                                            "Línea de Negocio"}
                                                    </span>
                                                    <span class="mega-link-desc">
                                                        {item.desc ||
                                                            "Descripción del servicio corporativo."}
                                                    </span>
                                                </div>
                                            </a>
                                        ))
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class={`nav-link ${currentPath === link.href ? "active" : ""}`}
                        >
                            {link.name}
                        </a>
                    ))
                }

                <button class="icon-btn search-btn" aria-label="Buscar">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.3-4.3"></path></svg
                    >
                </button>
            </div>

            <!-- Overlay for Mega Menu Blur -->
            <div class="mega-overlay"></div>

            <!-- Mobile Actions -->
            <div class="mobile-actions">
                <button class="icon-btn" id="mobileSearch" aria-label="Buscar">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.3-4.3"></path></svg
                    >
                </button>
                <button class="icon-btn" id="mobileToggle" aria-label="Menu">
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        id="menuIcon"
                        ><line x1="4" x2="20" y1="12" y2="12"></line><line
                            x1="4"
                            x2="20"
                            y1="6"
                            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"
                        ></line></svg
                    >
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        id="closeIcon"
                        class="hidden"
                        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"
                        ></path></svg
                    >
                </button>
            </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div class="mobile-menu" id="mobileMenu">
            <div class="mobile-menu-top">
                <a href={prefixPath("/contacto")} class="top-link"
                    >{t("nav.contact")}</a
                >
                <a href={lang === "es" ? "/en" : "/"} class="top-link"
                    >{lang === "es" ? "EN" : "ES"}</a
                >
            </div>
            <div class="mobile-menu-links">
                <!-- Mobile Accordions -->
                <div class="mobile-accordion">
                    <button class="accordion-trigger"
                        >{t("nav.about")}
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        ></button
                    >
                    <div class="accordion-content">
                        {
                            aboutItems.map((item) => (
                                <a href={item.href}>{item.name}</a>
                            ))
                        }
                    </div>
                </div>

                <div class="mobile-accordion">
                    <button class="accordion-trigger"
                        >{t("navbar.products_services_title")}
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        ></button
                    >
                    <div class="accordion-content">
                        {
                            productsItems.map((item) => (
                                <a href={item.href}>{item.name}</a>
                            ))
                        }
                    </div>
                </div>

                <a href={prefixPath("/impacto-circular")} class="mobile-link"
                    >{t("nav.activities")}</a
                >
            </div>
            <div class="mobile-menu-footer">
                <a href={prefixPath("/contacto")} class="cta-mobile-btn">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                        ></path></svg
                    >
                    {t("navbar.work_with_us")}
                </a>
            </div>
        </div>

        <style>
            .main-header {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                z-index: 2000;
                transition: all 0.5s var(--transition-premium);
                background: transparent;
            }

            .main-header.scrolled {
                background: var(--text-white);
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
                border-bottom: 1px solid var(--border-color);
            }

            /* Balik Specific Glassmorphism */
            .main-header.balik-nav.scrolled {
                background: rgba(10, 15, 25, 0.6) !important;
                backdrop-filter: blur(15px) !important;
                -webkit-backdrop-filter: blur(15px) !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3) !important;
            }

            .main-header.balik-nav.scrolled .nav-link,
            .main-header.balik-nav.scrolled .top-link,
            .main-header.balik-nav.scrolled .icon-btn {
                color: white !important;
            }

            .main-header.balik-nav.scrolled #logoWhite {
                opacity: 1 !important;
                visibility: visible !important;
                position: relative !important;
            }
            .main-header.balik-nav.scrolled #logoDark {
                opacity: 0 !important;
                visibility: hidden !important;
                position: absolute !important;
            }

            .main-header.solid,
            .main-header.scrolled {
                background: var(--brand-blue);
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            }

            .main-header.scrolled:not(.solid):not(.subpage) {
                background: var(--text-white);
            }

            .main-header.nav-hidden {
                transform: translateY(-100%);
            }

            .hidden {
                display: none !important;
            }

            /* Top Bar */
            .top-bar {
                background: rgba(0, 0, 0, 0.1);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                transition: all 0.5s ease;
            }

            .main-header.scrolled .top-bar {
                height: 0;
                overflow: hidden;
                opacity: 0;
            }

            .top-bar-inner {
                max-width: 100%;
                margin: 0;
                padding: 0.5rem 4rem;
                display: flex;
                justify-content: flex-end;
                gap: 2rem;
            }

            .top-link {
                font-size: 0.75rem;
                color: rgba(255, 255, 255, 0.85);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-family: var(--font-primary);
                font-weight: 600;
                transition: color 0.3s ease;
            }

            .main-header.scrolled .top-link {
                color: var(--text-secondary);
            }

            .top-link:hover {
                color: var(--brand-green);
            }

            /* Nav Main */
            .nav-container {
                height: 6rem;
                display: flex;
                align-items: center;
                transition: all 0.5s ease;
            }

            .main-header.scrolled .nav-container {
                height: 5rem;
            }

            .nav-inner {
                max-width: 100%;
                width: 100%;
                margin: 0;
                padding: 0 4rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            /* Logo */
            .nav-logo-link {
                display: flex;
                align-items: center;
                height: 100%;
            }

            .logo {
                height: 3.5rem;
                width: auto;
                object-fit: contain;
                transition: opacity 0.5s ease;
            }

            .logo-dark {
                opacity: 0;
                position: absolute;
            }
            .logo-white {
                opacity: 1;
            }

            .main-header.scrolled .logo-white,
            .main-header.solid.subpage .logo-dark {
                opacity: 0;
                visibility: hidden;
                position: absolute;
            }
            .main-header.scrolled .logo-dark,
            .main-header.solid.subpage .logo-white {
                opacity: 1;
                visibility: visible;
                position: relative;
            }

            /* Desktop Menu */
            .desktop-menu {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                height: 100%;
            }

            .nav-link {
                padding: 1rem 1.5rem;
                font-family: var(--font-primary);
                font-size: 0.95rem;
                font-weight: 700;
                color: var(--text-white);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                text-decoration: none;
                transition: color 0.3s ease;
                display: flex;
                align-items: center;
                gap: 0.4rem;
                background: transparent;
                border: none;
                cursor: pointer;
                transition: all 0.3s var(--transition-premium);
                border-radius: 100px;
            }

            .main-header.scrolled .nav-link {
                color: var(--text-primary);
            }

            .main-header.solid.subpage .nav-link,
            .main-header.solid.subpage .top-link {
                color: white;
            }

            /* Subpage hover logic */
            .main-header.solid.subpage .nav-link:hover {
                background: rgba(255, 255, 255, 0.15);
                color: white;
            }

            .nav-link:hover,
            .main-header.solid.subpage .nav-link:hover {
                color: var(--brand-green);
                background: rgba(
                    103,
                    189,
                    69,
                    0.08
                ); /* Sutil fondo verde al pasar el mouse */
                border-radius: 100px;
            }

            .nav-link.active {
                color: var(--brand-green);
                position: relative;
            }

            .nav-link.active::after {
                content: "";
                position: absolute;
                bottom: 0.5rem;
                left: 50%;
                width: 4px;
                height: 4px;
                background: var(--brand-green);
                border-radius: 50%;
                transform: translateX(-50%);
            }

            .main-header.scrolled .nav-link.active::after {
                background: var(--brand-green);
            }

            .main-header.solid.subpage .nav-link:hover {
                color: white;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 8px;
            }

            .chevron {
                transition: transform 0.3s ease;
                opacity: 0.6;
            }

            .menu-item:hover .chevron {
                transform: rotate(180deg);
                color: var(--brand-green);
            }

            /* Mega Menu Styles */
            .mega-menu {
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                background: white;
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
                border-top: 1px solid var(--border-color);
                opacity: 0;
                visibility: hidden;
                transform: translateY(10px);
                transition: all 0.3s var(--transition-premium);
                z-index: 1001; /* Encima del overlay */
            }

            .menu-item:hover .mega-menu {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

            /* Mega Overlay Blur */
            .mega-overlay {
                position: fixed;
                inset: 0;
                top: 8.4rem; /* Altura del header completo (top-bar + nav) */
                background: rgba(0, 0, 0, 0.2);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                opacity: 0;
                visibility: hidden;
                transition: all 0.4s ease;
                z-index: 998;
                pointer-events: none;
            }

            /* Ajuste cuando el header se encoge al hacer scroll */
            .main-header.scrolled ~ .mega-overlay {
                top: 5rem;
            }

            /* Cuando hay un hover en desktop-menu, activamos el overlay */
            .desktop-menu:hover ~ .mega-overlay {
                opacity: 1;
                visibility: visible;
            }

            .mega-content {
                max-width: 1200px;
                margin: 0 auto;
                display: flex;
                padding: 3rem 2rem;
                gap: 3rem;
            }

            .mega-main {
                flex: 1;
            }
            .mega-sidebar {
                width: 250px;
                border-left: 1px solid var(--border-color);
                padding-left: 3rem;
                display: flex;
                align-items: center;
            }

            .mega-title {
                font-family: var(--font-primary);
                font-size: 1.1rem;
                color: var(--brand-blue);
                border-bottom: 2px solid var(--brand-green);
                display: inline-block;
                padding-bottom: 0.5rem;
                margin-bottom: 2rem;
                font-weight: 800;
            }

            .mega-grid {
                display: grid;
                gap: 1.5rem;
            }

