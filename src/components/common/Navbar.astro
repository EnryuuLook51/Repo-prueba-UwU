---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

const prefixPath = (path: string) => {
    if (lang === "es") return path;
    return `/${lang}${path}`;
};

// Function to get the path for the other language
const getSwitchLangPath = (targetLang: string) => {
    const path = currentPath;
    if (targetLang === "en") {
        if (path.startsWith("/en")) return path;
        return `/en${path === "/" ? "" : path}`;
    } else {
        if (path.startsWith("/en/")) return path.replace("/en/", "/");
        if (path === "/en") return "/";
        return path;
    }
};

// Data for navigation
const navLinks = [
    { name: t("nav.about"), href: prefixPath("/nosotros") },
    { name: t("navbar.sustainability"), href: prefixPath("/#valores") },
];

const productsItems = [
    {
        name: t("navbar.ceprobio"),
        desc: t("navbar.ceprobio_desc"),
        href: prefixPath("/lineas-de-negocio/ceprobio"),
    },
    {
        name: t("navbar.proveeduria"),
        desc: t("navbar.proveeduria_desc"),
        href: prefixPath("/lineas-de-negocio/proveeduria"),
    },
    {
        name: t("navbar.balik"),
        desc: t("navbar.balik_desc"),
        href: prefixPath("/lineas-de-negocio/balik"),
    },
    {
        name: t("navbar.proyectos"),
        desc: t("navbar.proyectos_desc"),
        href: prefixPath("/nuestros-proyectos"),
    },
    {
        name: t("navbar.planta"),
        desc: t("navbar.planta_desc"),
        href: prefixPath("/lineas-de-negocio/planta-de-tratamiento"),
    },
];

const aboutItems = [
    {
        name: t("navbar.who_we_are"),
        desc: t("navbar.who_we_are_desc"),
        href: prefixPath("/#nosotros"),
    },
    {
        name: t("navbar.our_history"),
        desc: t("navbar.our_history_desc"),
        href: prefixPath("/#valores"),
    },
];

const isTransparentPage =
    currentPath === "/" ||
    currentPath === "/en" ||
    currentPath === "/en/" ||
    currentPath.includes("/ceprobio") ||
    currentPath.includes("/proveeduria") ||
    currentPath.includes("/balik") ||
    currentPath.includes("/nosotros");
const headerClass = isTransparentPage
    ? "main-header"
    : "main-header solid subpage";
---

<header class={headerClass} id="mainHeader">
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="top-bar-inner">
            <a href={prefixPath("/contacto")} class="top-link">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m22 2-10 11"></path><path d="m22 2-7 20-4-9-9-4Z"
                    ></path></svg
                >
                {t("nav.contact")}
            </a>
            <a
                href={getSwitchLangPath(lang === "es" ? "en" : "es")}
                class="top-link lang-switcher"
            >
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path
                        d="M12 2a14.5 14.5 0 0 0 0 20"></path><path d="M2 12h20"
                    ></path><path d="M12 2a14.5 14.5 0 0 1 0 20"></path></svg
                >
                {lang === "es" ? "English (EN)" : "Español (ES)"}
            </a>
        </div>
    </div>

    <!-- Navigation Main -->
    <nav class="nav-container">
        <div class="nav-inner">
            <!-- Logo -->
            <a href={prefixPath("/")} class="nav-logo-link">
                <img
                    src="/images/greenprod-blanco.png"
                    alt="Logo"
                    class="logo logo-white"
                    id="logoWhite"
                />
                <img
                    src="/images/greenprod.png"
                    alt="Logo"
                    class="logo logo-dark"
                    id="logoDark"
                />
            </a>

            <!-- Desktop Menu -->
            <div class="desktop-menu">
                <div class="menu-item has-dropdown" data-dropdown="nosotros">
                    <button class="nav-link">
                        {t("nav.about")}
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        >
                    </button>
                    <!-- Mega Menu NOSOTROS -->
                    <div class="mega-menu" id="dropdown-nosotros">
                        <div class="mega-content">
                            <div class="mega-main">
                                <h3 class="mega-title">Sobre Nosotros</h3>
                                <div class="mega-grid two-cols">
                                    {
                                        aboutItems.map((item) => (
                                            <a
                                                href={item.href}
                                                class="mega-link"
                                            >
                                                <span class="mega-link-title">
                                                    {item.name}
                                                </span>
                                                <span class="mega-link-desc">
                                                    {item.desc}
                                                </span>
                                            </a>
                                        ))
                                    }
                                </div>
                            </div>
                            <div class="mega-sidebar">
                                <a
                                    href={prefixPath("/contacto")}
                                    class="sidebar-btn"
                                >
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><path
                                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                        ></path></svg
                                    >
                                    {t("navbar.work_with_us")}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="menu-item has-dropdown" data-dropdown="productos">
                    <button class="nav-link">
                        {t("navbar.products_services_title")}
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                        >
                    </button>
                    <!-- Mega Menu PRODUCTOS -->
                    <div class="mega-menu" id="dropdown-productos">
                        <div class="mega-content">
                            <div class="mega-main">
                                <h3
                                    class="mega-title uppercase tracking-widest"
                                >
                                    {t("navbar.products_services_title")}
                                </h3>
                                <div class="mega-grid three-cols">
                                    {
                                        productsItems.map((item) => (
                                            <a
                                                href={item.href}
                                                class="mega-link"
                                            >
                                                <span class="mega-link-title">
                                                    {item.name}
                                                </span>
                                                <span class="mega-link-desc">
                                                    {item.desc}
                                                </span>
                                            </a>
                                        ))
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class={`nav-link ${currentPath === link.href ? "active" : ""}`}
                        >
                            {link.name}
                        </a>
                    ))
                }

                <button class="icon-btn search-btn">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.3-4.3"></path></svg
                    >
                </button>
            </div>

            <!-- Mobile Actions -->
            <div class="mobile-actions">
                <button class="icon-btn" id="mobileSearch">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.3-4.3"></path></svg
                    >
                </button>
                <button class="icon-btn" id="mobileToggle">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        id="menuIcon"
                        ><line x1="4" x2="20" y1="12" y2="12"></line><line
                            x1="4"
                            x2="20"
                            y1="6"
                            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"
                        ></line></svg
                    >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        id="closeIcon"
                        class="hidden"
                        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"
                        ></path></svg
                    >
                </button>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div class="mobile-menu" id="mobileMenu">
        <div class="mobile-menu-top">
            <a href={prefixPath("/contacto")} class="top-link"
                >{t("nav.contact")}</a
            >
            <a href={lang === "es" ? "/en" : "/"} class="top-link"
                >{lang === "es" ? "EN" : "ES"}</a
            >
        </div>
        <div class="mobile-menu-links">
            <!-- Mobile Accordions -->
            <div class="mobile-accordion">
                <button class="accordion-trigger"
                    >{t("nav.about")}
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                    ></button
                >
                <div class="accordion-content">
                    {
                        aboutItems.map((item) => (
                            <a href={item.href}>{item.name}</a>
                        ))
                    }
                </div>
            </div>

            <div class="mobile-accordion">
                <button class="accordion-trigger"
                    >{t("navbar.products_services_title")}
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="chevron"><path d="m6 9 6 6 6-6"></path></svg
                    ></button
                >
                <div class="accordion-content">
                    {
                        productsItems.map((item) => (
                            <a href={item.href}>{item.name}</a>
                        ))
                    }
                </div>
            </div>

            <a href={prefixPath("/impacto-circular")} class="mobile-link"
                >{t("nav.activities")}</a
            >
        </div>
        <div class="mobile-menu-footer">
            <a href={prefixPath("/contacto")} class="cta-mobile-btn">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path></svg
                >
                {t("navbar.work_with_us")}
            </a>
        </div>
    </div>
</header>

<style>
    .main-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        transition: all 0.5s var(--transition-premium);
        background: transparent;
    }

    .main-header.scrolled {
        background: var(--text-white);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border-bottom: 1px solid var(--border-color);
    }

    .main-header.solid.subpage {
        background: var(--brand-blue);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-bottom: none;
    }

    .main-header.nav-hidden {
        transform: translateY(-100%);
    }

    /* Top Bar */
    .top-bar {
        background: rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.5s ease;
    }

    .main-header.scrolled .top-bar {
        height: 0;
        overflow: hidden;
        opacity: 0;
    }

    .top-bar-inner {
        max-width: 100%;
        margin: 0;
        padding: 0.5rem 4rem;
        display: flex;
        justify-content: flex-end;
        gap: 2rem;
    }

    .top-link {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-primary);
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .main-header.scrolled .top-link {
        color: var(--text-secondary);
    }

    .top-link:hover {
        color: var(--brand-green);
    }

    /* Nav Main */
    .nav-container {
        height: 6rem;
        display: flex;
        align-items: center;
        transition: all 0.5s ease;
    }

    .main-header.scrolled .nav-container {
        height: 5rem;
    }

    .nav-inner {
        max-width: 100%;
        width: 100%;
        margin: 0;
        padding: 0 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Logo */
    .nav-logo-link {
        display: flex;
        align-items: center;
        height: 100%;
    }

    .logo {
        height: 3.5rem;
        width: auto;
        object-fit: contain;
        transition: opacity 0.5s ease;
    }

    .logo-dark {
        opacity: 0;
        position: absolute;
    }
    .logo-white {
        opacity: 1;
    }

    .main-header.scrolled .logo-white,
    .main-header.solid.subpage .logo-dark {
        opacity: 0;
        visibility: hidden;
        position: absolute;
    }
    .main-header.scrolled .logo-dark,
    .main-header.solid.subpage .logo-white {
        opacity: 1;
        visibility: visible;
        position: relative;
    }

    /* Desktop Menu */
    .desktop-menu {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        height: 100%;
    }

    .nav-link {
        padding: 1rem 1.5rem;
        font-family: var(--font-primary);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-white);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: transparent;
        border: none;
        cursor: pointer;
    }

    .main-header.scrolled .nav-link {
        color: var(--text-primary);
    }

    .main-header.solid.subpage .nav-link,
    .main-header.solid.subpage .top-link {
        color: white;
    }

    .nav-link:hover,
    .main-header.solid.subpage .nav-link:hover {
        color: var(--brand-green);
    }

    .main-header.solid.subpage .nav-link:hover {
        color: white;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
    }

    .chevron {
        transition: transform 0.3s ease;
        opacity: 0.6;
    }

    .menu-item:hover .chevron {
        transform: rotate(180deg);
        color: var(--brand-green);
    }

    /* Mega Menu Styles */
    .mega-menu {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: white;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
        border-top: 1px solid var(--border-color);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.3s var(--transition-premium);
    }

    .menu-item:hover .mega-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .mega-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        padding: 3rem 2rem;
        gap: 3rem;
    }

    .mega-main {
        flex: 1;
    }
    .mega-sidebar {
        width: 250px;
        border-left: 1px solid var(--border-color);
        padding-left: 3rem;
        display: flex;
        align-items: center;
    }

    .mega-title {
        font-family: var(--font-primary);
        font-size: 1.1rem;
        color: var(--brand-blue);
        border-bottom: 2px solid var(--brand-green);
        display: inline-block;
        padding-bottom: 0.5rem;
        margin-bottom: 2rem;
        font-weight: 800;
    }

    .mega-grid {
        display: grid;
        gap: 1.5rem;
    }

    .mega-grid.two-cols {
        grid-template-columns: repeat(2, 1fr);
    }
    .mega-grid.three-cols {
        grid-template-columns: repeat(3, 1fr);
    }

    .mega-link {
        text-decoration: none;
        padding: 1rem;
        border-radius: 0.8rem;
        transition: background 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .mega-link:hover {
        background: #f8fafc;
    }

    .mega-link-title {
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
        transition: color 0.3s ease;
    }

    .mega-link:hover .mega-link-title {
        color: var(--brand-green);
    }

    .mega-link-desc {
        font-family: var(--font-secondary);
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .sidebar-btn {
        background: #f1f5f9;
        color: var(--text-primary);
        padding: 1.2rem;
        border-radius: 1rem;
        text-decoration: none;
        font-family: var(--font-primary);
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        transition: all 0.3s ease;
        width: 100%;
        justify-content: center;
    }

    .sidebar-btn:hover {
        background: var(--brand-blue);
        color: white;
        transform: translateY(-3px);
    }

    /* Icon Buttons */
    .icon-btn {
        background: transparent;
        border: none;
        color: var(--text-white);
        cursor: pointer;
        padding: 0.6rem;
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-header.scrolled .icon-btn {
        color: var(--text-primary);
    }

    .icon-btn:hover {
        color: var(--brand-green);
    }

    /* Mobile */
    .mobile-actions {
        display: none;
    }

    .mobile-menu {
        position: fixed;
        top: 0;
        right: -100%;
        width: 85%;
        height: 100vh;
        background: white;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        transition: right 0.5s var(--transition-premium);
        padding: 2rem;
        box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
    }

    .mobile-menu.active {
        right: 0;
    }

    .mobile-menu-top {
        display: flex;
        justify-content: space-between;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 2rem;
    }

    .mobile-menu-links {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .mobile-link,
    .accordion-trigger {
        font-family: var(--font-primary);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        text-decoration: none;
        padding: 1rem 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
        text-transform: uppercase;
    }

    .accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
        display: flex;
        flex-direction: column;
        padding-left: 1.5rem;
        gap: 1.5rem;
    }

    .mobile-accordion.active .accordion-content {
        max-height: 500px;
        padding-top: 1rem;
        padding-bottom: 2rem;
    }

    .mobile-accordion.active .accordion-trigger .chevron {
        transform: rotate(180deg);
    }

    .accordion-content a {
        font-family: var(--font-secondary);
        font-size: 1rem;
        color: var(--text-secondary);
        text-decoration: none;
    }

    .mobile-menu-footer {
        margin-top: auto;
        padding-top: 2rem;
    }

    .cta-mobile-btn {
        background: var(--brand-green);
        color: white;
        padding: 1.2rem;
        border-radius: 1rem;
        text-decoration: none;
        font-family: var(--font-primary);
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
    }

    @media (max-width: 1024px) {
        .top-bar {
            display: none;
        }
        .desktop-menu {
            display: none;
        }
        .mobile-actions {
            display: flex;
            gap: 0.5rem;
        }
        .logo {
            height: 2.8rem;
        }
        .nav-inner {
            padding: 0 1.5rem;
        }
    }
</style>

<script>
    // Scroll Logic
    const header = document.getElementById("mainHeader");
    let lastScrollY = window.scrollY;

    const updateScroll = () => {
        const currentScrollY = window.scrollY;

        // Sticky on scroll up, hide on scroll down
        if (currentScrollY > 100) {
            header?.classList.add("scrolled");
            if (currentScrollY > lastScrollY && currentScrollY > 400) {
                header?.classList.add("nav-hidden");
            } else {
                header?.classList.remove("nav-hidden");
            }
        } else {
            header?.classList.remove("scrolled");
            header?.classList.remove("nav-hidden");
        }

        lastScrollY = currentScrollY;
    };
    window.addEventListener("scroll", updateScroll, { passive: true });
    updateScroll();

    // Mobile Menu Toggle
    const mobileToggle = document.getElementById("mobileToggle");
    const mobileMenu = document.getElementById("mobileMenu");
    const menuIcon = document.getElementById("menuIcon");
    const closeIcon = document.getElementById("closeIcon");
    if (mobileToggle) {
        mobileToggle.addEventListener("click", () => {
            if (mobileMenu) {
                mobileMenu.classList.toggle("active");
            }
            if (menuIcon) {
                menuIcon.classList.toggle("hidden");
            }
            if (closeIcon) {
                closeIcon.classList.toggle("hidden");
            }
            if (header) {
                header.classList.toggle("solid");
            }
        });
    } else {
        console.log("No mobile toggle found");
    }

    // Accordions
    document.querySelectorAll(".accordion-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => {
            const parent = trigger.parentElement;
            if (parent) {
                parent.classList.toggle("active");
            }
        });
    });
</script>
