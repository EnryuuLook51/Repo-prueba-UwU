---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import { Image } from "astro:assets";
import "../../../styles/global.css";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefixPath = (path: string) => {
  if (lang === "es") return path;
  return `/${lang}${path}`;
};
const isBalik = Astro.url.pathname.includes("/balik");
---

<footer class={`footer ${isBalik ? "footer-balik" : ""}`}>
  <!-- Franja decorativa superior -->
  <div class="footer-topbar"></div>

  <div class="footer-inner">
    <!-- COLUMNA 1: Logo + tagline -->
    <div class="footer-brand">
      <a href={prefixPath("/")} class="footer-logo-link">
        <Image
          src="/images/greenprod.png"
          alt="Green Prod & Sustainable"
          width={155}
          height={48}
          class="footer-logo"
        />
      </a>
      <p class="footer-tagline">{t("footer.tagline")}</p>

      <!-- Redes Sociales -->
      <div class="footer-socials">
        <a
          href={isBalik
            ? "https://www.facebook.com/Balik"
            : "https://www.facebook.com/share/TaR3vZpTHC/?mibextid=wwXIfr"}
          target="_blank"
          rel="noopener noreferrer"
          class="social-pill"
          aria-label="Facebook"
        >
          <i class="fab fa-facebook"></i>
        </a>
        <a
          href={isBalik
            ? "https://www.instagram.com/balikperu"
            : "https://www.instagram.com/greenprodsustainable?igsh=MWE0ZXlynHdpYjBoZA=="}
          target="_blank"
          rel="noopener noreferrer"
          class="social-pill"
          aria-label="Instagram"
        >
          <i class="fab fa-instagram"></i>
        </a>
        <a
          href={isBalik
            ? "https://www.tiktok.com/@BalikPeru"
            : "https://www.tiktok.com/@greenprodsustainable?_r=1&_t=ZS-94pPT4ilMwL"}
          target="_blank"
          rel="noopener noreferrer"
          class="social-pill"
          aria-label="TikTok"
        >
          <i class="fab fa-tiktok"></i>
        </a>
      </div>
    </div>

    <!-- COLUMNA 2: Navegación -->
    <div class="footer-col">
      <h4 class="footer-col-title">{t("footer.nav")}</h4>
      <ul class="footer-links">
        <li>
          <a href={prefixPath("/nosotros")} class="footer-link">
            <span class="link-arrow">→</span>
            {t("nav.about")}
          </a>
        </li>
        <li>
          <a href={prefixPath("/#lineas-negocio")} class="footer-link">
            <span class="link-arrow">→</span>
            {t("nav.services")}
          </a>
        </li>
        <li>
          <a href={prefixPath("/impacto-circular")} class="footer-link">
            <span class="link-arrow">→</span>
            {t("nav.activities")}
          </a>
        </li>
        <li>
          <a href={prefixPath("/nuestros-proyectos")} class="footer-link">
            <span class="link-arrow">→</span>
            {t("nav.projects")}
          </a>
        </li>
        <li>
          <a href={prefixPath("/catalogo")} class="footer-link">
            <span class="link-arrow">→</span>
            {t("navbar.catalog")}
          </a>
        </li>
      </ul>
    </div>

    <!-- COLUMNA 3: Contacto -->
    <div class="footer-col">
      <h4 class="footer-col-title">{t("footer.contact")}</h4>
      <ul class="footer-contact-list">
        <li>
          <a
            href={isBalik
              ? "mailto:balikperu@gmail.com"
              : "mailto:greenprodsustainable@gmail.com"}
            class="footer-contact-item"
          >
            <span class="contact-icon">
              <i class="fas fa-envelope"></i>
            </span>
            <span
              >{
                isBalik
                  ? "balikperu@gmail.com"
                  : "greenprodsustainable@gmail.com"
              }</span
            >
          </a>
        </li>
        {
          isBalik && (
            <li>
              <a href="mailto:balik@greenprod.pe" class="footer-contact-item">
                <span class="contact-icon">
                  <i class="fas fa-envelope" />
                </span>
                <span>balik@greenprod.pe</span>
              </a>
            </li>
          )
        }
        <li>
          <a
            href={isBalik
              ? "https://wa.me/51961235080"
              : "https://wa.me/51950412534"}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-contact-item"
          >
            <span class="contact-icon">
              <i class="fab fa-whatsapp"></i>
            </span>
            <span
              >{isBalik ? "961 235 080 / 908 051 858" : "+51 950 412 534"}</span
            >
          </a>
        </li>
        <li>
          <a href={prefixPath("/contacto")} class="footer-cta-btn">
            {t("nav.contact")}
            <i class="fas fa-arrow-right"></i>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Separador y barra inferior -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-made">{t("footer.made_with")}</p>
      <p class="footer-copy">{t("footer.copyright")}</p>
    </div>
  </div>

  <!-- Destellos de fondo -->
  <div class="footer-glow footer-glow-1"></div>
  <div class="footer-glow footer-glow-2"></div>
</footer>

<style>
  /* ═══════════════════════════════════════
     FOOTER — DISEÑO PREMIUM
  ═══════════════════════════════════════ */

  .footer {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #02457a 0%, #006db6 55%, #014f86 100%);
    color: white;
  }

  /* Franja superior con gradiente verde→azul */
  .footer-topbar {
    height: 4px;
    background: linear-gradient(90deg, #67bd45 0%, #006db6 50%, #838587 100%);
    background-size: 200% auto;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  /* ── Layout principal ── */
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Columna 1: Marca ── */
  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    transition: opacity 0.3s ease;
  }

  .footer-logo:hover {
    opacity: 0.85;
  }

  .footer-tagline {
    font-family: var(--font-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    color: #838587; /* Gris corporativo */
    max-width: 300px;
    margin-bottom: 2.5rem;
  }

  /* ── Redes Sociales ── */
  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .social-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    text-decoration: none;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;
    backdrop-filter: blur(8px);
  }

  .social-pill:hover {
    background: var(--brand-green);
    border-color: var(--brand-green);
    color: white;
    transform: translateY(-4px);
  }

  /* ── Columnas de enlaces ── */
  .footer-col-title {
    font-family: var(--font-primary);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--brand-green);
    margin-bottom: 1.8rem;
    position: relative;
    padding-bottom: 1rem;
  }

  .footer-col-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 28px;
    height: 2px;
    background: var(--brand-green);
    border-radius: 2px;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition:
      color 0.25s ease,
      gap 0.25s ease;
  }

  .footer-link:hover {
    color: white;
    gap: 0.9rem;
  }

  .link-arrow {
    font-size: 0.75rem;
    color: var(--brand-green);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .footer-link:hover .link-arrow {
    opacity: 1;
  }

  /* ── Columna de contacto ── */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    font-family: var(--font-secondary);
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.25s ease;
  }

  .footer-contact-item:hover {
    color: #67bd45;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    min-width: 32px;
    background: rgba(103, 189, 69, 0.15);
    border-radius: 8px;
    color: var(--brand-green);
    font-size: 0.85rem;
    transition: background 0.25s ease;
  }

  .footer-contact-item:hover .contact-icon {
    background: rgba(103, 189, 69, 0.28);
  }

  /* Botón CTA pequeño */
  .footer-cta-btn {
    margin-top: 0.4rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.4rem;
    background: var(--brand-green);
    color: white;
    text-decoration: none;
    border-radius: 99px;
    font-size: 0.82rem;
    font-weight: 700;
    font-family: var(--font-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      background 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .footer-cta-btn:hover {
    background: white;
    color: var(--brand-green);
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
  }

  /* ── Barra inferior ── */
  .footer-bottom {
    background: #838587; /* Gris corporativo en la base */
    color: white;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.6rem 2rem;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-made,
  .footer-copy {
    font-family: var(--font-secondary);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ── Destellos de fondo ── */
  .footer-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .footer-glow-1 {
    width: 400px;
    height: 400px;
    background: rgba(103, 189, 69, 0.08);
    bottom: -100px;
    right: -80px;
  }

  .footer-glow-2 {
    width: 300px;
    height: 300px;
    background: rgba(255, 255, 255, 0.04);
    top: -60px;
    left: -60px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 576px) {
    .footer-inner {
      grid-template-columns: 1fr;
      padding: 3.5rem 1.5rem 3rem;
      gap: 2.5rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.4rem;
    }
  }

  /* ═══ BALIK BRANDING (NIGHT MODE) ═══ */
  .footer-balik {
    background: rgba(8, 12, 18, 0.45) !important;
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-balik .footer-topbar {
    background: linear-gradient(
      90deg,
      #67bd45 0%,
      rgba(0, 109, 182, 0.4) 50%,
      rgba(255, 255, 255, 0.2) 100%
    );
    opacity: 0.8;
  }

  .footer-balik .footer-bottom {
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .footer-balik .footer-tagline {
    color: rgba(255, 255, 255, 0.4);
  }
</style>
