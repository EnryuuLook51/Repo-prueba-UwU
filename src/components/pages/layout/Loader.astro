---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="preloader-overlay" id="loader">
    <div class="bg-glow"></div>
    <div class="particles" id="particles"></div>

    <div class="loader-wrapper">
        <div class="logo-container">
            <div class="wordmark-row">
                <div class="word-green">
                    <span class="char c0">g</span>
                    <span class="char c1">r</span>
                    <span class="char c2">e</span>
                    <span class="char c3">e</span>
                    <span class="char c4">n</span>
                </div>

                <div class="leaf-wrapper">
                    <svg
                        class="leaf-svg"
                        viewBox="0 0 44 44"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M22 38 Q14 20 22 6 Q30 20 22 38 Z"
                            fill="#67bd45"></path>
                        <path
                            d="M22 34 Q10 22 16 10 Q20 22 22 34 Z"
                            fill="#67bd45"
                            opacity="0.78"></path>
                        <line
                            x1="22"
                            y1="10"
                            x2="22"
                            y2="36"
                            stroke="#4c9332"
                            stroke-width="1"
                            opacity="0.5"></line>
                    </svg>
                </div>

                <div class="word-prod">
                    <span class="char c5">p</span>
                    <span class="char c6">r</span>
                    <span class="char c7">o</span>
                    <span class="char c8">d</span>
                </div>
            </div>

            <div class="bottom-row">
                <svg
                    class="waves-svg"
                    viewBox="0 0 68 15"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        class="wave-path w1"
                        d="M2 4 Q10 0 18 4 Q26 8 34 4 Q42 0 50 4 Q58 8 66 4"
                    ></path>
                    <path
                        class="wave-path w2"
                        d="M2 10 Q10 6 18 10 Q26 14 34 10 Q42 6 50 10 Q58 14 66 10"
                    ></path>
                </svg>
                <span class="sustainable-label">sustainable</span>
            </div>
        </div>

        <div class="progress-container">
            <div class="progress-meta">
                <span class="progress-text">{t("loader.loading")}</span>
                <span class="progress-percent" id="pct">0%</span>
            </div>
            <div class="bar-track">
                <div class="bar-fill"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .preloader-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .bg-glow {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(103, 189, 69, 0.08) 0%,
            transparent 70%
        );
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: glowPulse 3.5s ease-in-out infinite;
        pointer-events: none;
    }

    @keyframes glowPulse {
        0%,
        100% {
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1);
        }
        50% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1.12);
        }
    }

    .particles {
        position: fixed;
        inset: 0;
        pointer-events: none;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        opacity: 0;
        animation: floatUp linear infinite;
    }

    @keyframes floatUp {
        0% {
            transform: translateY(100vh);
            opacity: 0;
        }
        10% {
            opacity: 0.6;
        }
        90% {
            opacity: 0.3;
        }
        100% {
            transform: translateY(-40px);
            opacity: 0;
        }
    }

    .loader-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 32px;
    }

    .logo-container {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .wordmark-row {
        display: flex;
        align-items: baseline;
        line-height: 1;
        position: relative;
    }

    .word-green {
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: clamp(48px, 10vw, 72px);
        color: var(--brand-green);
        display: flex;
        letter-spacing: -2px;
        text-transform: lowercase;
    }

    .word-prod {
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: clamp(48px, 10vw, 72px);
        color: var(--brand-blue);
        display: flex;
        letter-spacing: -2px;
        text-transform: lowercase;
    }

    .leaf-wrapper {
        position: relative;
        width: 0px;
        display: flex;
        align-items: flex-end;
    }

    .leaf-svg {
        position: absolute;
        bottom: 28px;
        left: -18px;
        width: 44px;
        height: 44px;
        animation: leafBounce 2.4s ease-in-out infinite;
        transform-origin: center bottom;
    }

    @keyframes leafBounce {
        0%,
        100% {
            transform: translateY(0) rotate(0deg) scaleX(1);
        }
        30% {
            transform: translateY(-7px) rotate(-4deg) scaleX(0.97);
        }
        60% {
            transform: translateY(-3px) rotate(3deg) scaleX(1.02);
        }
    }

    .char {
        display: inline-block;
        opacity: 0;
        transform: translateY(14px);
        animation: charIn 0.45s forwards ease-out;
    }

    .c0 {
        animation-delay: 0.05s;
    }
    .c1 {
        animation-delay: 0.12s;
    }
    .c2 {
        animation-delay: 0.19s;
    }
    .c3 {
        animation-delay: 0.26s;
    }
    .c4 {
        animation-delay: 0.33s;
    }
    .c5 {
        animation-delay: 0.5s;
    }
    .c6 {
        animation-delay: 0.57s;
    }
    .c7 {
        animation-delay: 0.64s;
    }
    .c8 {
        animation-delay: 0.71s;
    }

    @keyframes charIn {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .bottom-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 2px;
        padding-left: clamp(
            52px,
            11vw,
            78px
        ); /* Shifts to align with the first 'e' */
        opacity: 0;
        animation: fadeUp 0.6s 1.1s forwards;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .waves-svg {
        width: 60px;
        height: 15px;
    }

    .wave-path {
        fill: none;
        stroke: var(--brand-blue);
        stroke-width: 2.2;
        stroke-linecap: round;
        stroke-dasharray: 80;
        stroke-dashoffset: 80;
        animation: waveDraw 0.8s ease forwards;
    }

    .w1 {
        animation-delay: 1.1s;
    }
    .w2 {
        animation-delay: 1.25s;
    }

    @keyframes waveDraw {
        to {
            stroke-dashoffset: 0;
        }
    }

    .sustainable-label {
        font-family: var(--font-secondary);
        font-weight: 600;
        font-size: clamp(14px, 2.5vw, 20px);
        letter-spacing: 4px;
        color: var(--text-secondary);
        text-transform: lowercase;
    }

    .progress-container {
        width: clamp(280px, 50vw, 380px);
    }

    .progress-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .progress-text {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(0, 0, 0, 0.3);
    }

    .progress-percent {
        font-size: 11px;
        font-weight: 700;
        color: var(--brand-green);
        font-variant-numeric: tabular-nums;
        font-family: var(--font-primary);
    }

    .bar-track {
        width: 100%;
        height: 3px;
        background: rgba(0, 0, 0, 0.06);
        border-radius: 99px;
        overflow: visible;
        position: relative;
    }

    .bar-fill {
        height: 100%;
        width: 0%;
        border-radius: 99px;
        background: linear-gradient(
            90deg,
            var(--brand-green),
            var(--brand-blue)
        );
        animation: fillBar 2.6s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
        position: relative;
    }

    .bar-fill::after {
        content: "";
        position: absolute;
        right: -1px;
        top: 50%;
        transform: translateY(-50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--brand-green);
        box-shadow:
            0 0 8px var(--brand-green),
            0 0 18px rgba(103, 189, 69, 0.4);
    }

    @keyframes fillBar {
        0% {
            width: 0%;
        }
        35% {
            width: 40%;
        }
        65% {
            width: 70%;
        }
        88% {
            width: 88%;
        }
        100% {
            width: 100%;
        }
    }
</style>

<script>
    function initLoader() {
        const pctEl = document.getElementById("pct");
        const loader = document.getElementById("loader");
        const fill = document.querySelector(".bar-fill") as HTMLElement;
        if (!pctEl || !loader) return;

        let progress = 0;
        let startTime = Date.now();
        const duration = 3000; // 3 seconds to reach 99%

        function update() {
            const now = Date.now();
            const elapsed = now - startTime;

            // Linear progress for simplicity and reliability
            if (progress < 99) {
                progress = Math.min(99, (elapsed / duration) * 99);
                pctEl.textContent = Math.round(progress) + "%";
                if (fill) fill.style.width = progress + "%";
            }

            if (progress < 99) {
                requestAnimationFrame(update);
            }
        }

        requestAnimationFrame(update);

        const finishLoader = () => {
            // Jump to 100
            progress = 100;
            pctEl.textContent = "100%";
            if (fill) fill.style.width = "100%";

            setTimeout(() => {
                loader.style.transition =
                    "opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s ease";
                loader.style.opacity = "0";
                loader.style.transform = "scale(1.1)";
                setTimeout(() => {
                    loader.style.display = "none";
                }, 800);
            }, 400);
        };

        // Finish on window load OR after 4 seconds safety timeout
        window.addEventListener("load", finishLoader);
        setTimeout(finishLoader, 4000);
    }

    // Run on start
    initLoader();

    // Particles (Minimal & Safe)
    const pc = document.getElementById("particles");
    if (pc) {
        for (let i = 0; i < 15; i++) {
            const p = document.createElement("div");
            p.className = "particle";
            const size = 2 + Math.random() * 3;
            const color = Math.random() > 0.5 ? "#67bd45" : "#006db6";
            p.style.cssText = `left:${Math.random() * 100}%;width:${size}px;height:${size}px;background:${color};top:${Math.random() * 100}%;opacity:${0.1 + Math.random() * 0.2};`;
            pc.appendChild(p);
        }
    }
</script>
