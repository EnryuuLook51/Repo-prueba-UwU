---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="quehacemos-section" id="que-hacemos">
    <div class="qh-inner">
        <span class="qh-tag">{t("services.title")}</span>

        <div class="qh-grid">
            <!-- BIOINSUMOS — Tarjeta especial con efecto 3D -->
            <article class="card-3d" data-reveal>
                <img
                    src="/images/fondo-bioinsumo.png"
                    alt={t("services.ceprobio.title")}
                    class="card-3d-bg"
                />
                <img
                    src="/images/Bioinsumos.png"
                    alt={t("services.ceprobio.title")}
                    class="card-3d-product"
                />
                <div class="card-3d-info">
                    <h3>{t("services.ceprobio.title")}</h3>
                    <p class="">
                        {t("services.ceprobio.description")}
                    </p>
                </div>
            </article>

            <!-- TRATAMIENTO PRIMARIO -->
            <article class="card-simple" data-reveal>
                <div class="card-simple-icon">🐟</div>
                <h3>{t("services.balik.title")}</h3>
                <p>{t("services.balik.description")}</p>
            </article>

            <!-- CIRCULARIDAD -->
            <article class="card-simple" data-reveal>
                <div class="card-simple-icon">♻️</div>
                <h3>{t("services.proveeduria.title")}</h3>
                <p>{t("services.proveeduria.description")}</p>
            </article>

            <!-- INFRAESTRUCTURA -->
            <article class="card-simple" data-reveal>
                <div class="card-simple-icon">🏗️</div>
                <h3>{t("services.proyectos.title")}</h3>
                <p>{t("services.proyectos.description")}</p>
            </article>
        </div>
    </div>
</section>

<style>
    .quehacemos-section {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }

    .qh-inner {
        max-width: 1100px;
        margin: 0 auto;
        text-align: center;
    }

    .qh-tag {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--brand-blue);
        margin-bottom: 3rem;
        font-weight: 600;
    }

    .qh-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        align-items: start;
    }

    /* ═══ TARJETA 3D — BIOINSUMOS ═══ */
    .card-3d {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 4;
        border-radius: 1.2rem;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.4s ease;
    }

    .card-3d-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 1.2rem;
        box-shadow: 0 60px 60px -60px rgba(0, 109, 182, 0.5);
    }

    .card-3d-product {
        position: absolute;
        width: 75%;
        bottom: 0;
        left: 0;
        right: 0;
        margin: auto;
        transform: translateY(25%);
        transition: all 0.4s ease;
        opacity: 0;
        object-fit: contain;
        z-index: 3;
        filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
    }

    .card-3d::before {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        height: 100%;
        width: 100%;
        background-image: linear-gradient(
            to bottom,
            transparent 10%,
            rgba(0, 0, 0, 0.5) 50%,
            rgba(0, 0, 0, 0.9) 95%
        );
        opacity: 0;
        transition: all 0.4s ease;
        z-index: 2;
        border-radius: 1.2rem;
    }

    .card-3d-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.5rem;
        z-index: 4;
        text-align: left;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s ease 0.1s;
        color: var(--brand-blue);
    }

    .card-3d-info h3 {
        font-family: var(--font-primary);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-white);
        margin-bottom: 0.4rem;
    }

    .card-3d-info p {
        font-family: var(--font-secondary);
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.5;
    }

    .card-3d:hover {
        transform: perspective(500px) rotateX(10deg) translateY(-5%)
            translateZ(0);
    }

    .card-3d:hover::before {
        opacity: 1;
    }

    .card-3d:hover .card-3d-product {
        opacity: 1;
        transform: translateY(10%);
    }

    .card-3d:hover .card-3d-info {
        opacity: 1;
        transform: translateY(0);
    }

    /* ═══ TARJETAS SIMPLES ═══ */
    .card-simple {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 1.2rem;
        padding: 2.5rem 1.5rem;
        text-align: center;
        box-shadow: var(--shadow-glow);
        transition:
            transform 0.4s ease,
            box-shadow 0.4s ease;
    }

    .card-simple:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(0, 109, 182, 0.1);
    }

    .card-simple-icon {
        font-size: 2.8rem;
        margin-bottom: 1.2rem;
    }

    .card-simple h3 {
        font-family: var(--font-primary);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.8rem;
    }

    .card-simple p {
        font-family: var(--font-secondary);
        font-size: 0.88rem;
        color: var(--text-secondary);
        line-height: 1.65;
    }

    /* ═══ REVEAL ═══ */
    [data-reveal] {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.8s ease,
            transform 0.8s ease;
    }

    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 1024px) {
        .qh-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 600px) {
        .qh-grid {
            grid-template-columns: 1fr;
        }
        .card-3d {
            max-width: 320px;
            margin: 0 auto;
        }
    }
</style>

<script>
    const revealEls = document.querySelectorAll(
        ".quehacemos-section [data-reveal]",
    );
    const obs = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add("revealed");
                    }, 120 * i);
                } else {
                    entry.target.classList.remove("revealed");
                }
            });
        },
        { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
    );
    revealEls.forEach((el) => obs.observe(el));
</script>
