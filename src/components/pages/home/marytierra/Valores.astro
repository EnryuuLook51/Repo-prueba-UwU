---
import { getLangFromUrl, useTranslations } from "../../../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- BLOQUE 1: Valores / Raíces -->
<div class="story-block dark-block green-block" id="valores" data-reveal>
    <div class="story-inner side-layout">
        <div class="side-content">
            <span class="tag">{t("marytierra.roots.label")}</span>
            <h2 class="headline">
                {t("marytierra.roots.v1")}
                <br />
                {t("marytierra.roots.v2")}
                <br />
                {t("marytierra.roots.v3")}
            </h2>
            <div class="pills">
                <span class="pill">{t("marytierra.roots.v1")}</span>
                <span class="pill">{t("marytierra.roots.v2")}</span>
                <span class="pill">{t("marytierra.roots.v3")}</span>
            </div>
        </div>
        <div class="img-box side" data-reveal-child>
            <img
                src="/images/sostenibilidad-banner.png"
                alt="Sostenibilidad"
                loading="lazy"
            />
        </div>
    </div>
</div>

<style>
    .story-block {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }
    .story-block.dark-block {
        color: var(--text-white);
    }
    .story-block.green-block {
        background: var(--brand-green);
    }

    .story-inner {
        max-width: 1100px;
        margin: 0 auto;
    }
    .story-inner.side-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .side-content {
        text-align: left;
    }
    .side-content .pills {
        justify-content: flex-start;
        margin-top: 2.5rem;
    }

    /* Reveal */
    [data-reveal] {
        opacity: 0;
        transform: translateY(60px);
        transition:
            opacity 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
    [data-reveal-child] {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }
    [data-reveal-child].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* Typography */
    .tag {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--text-white);
        opacity: 0.85;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }
    .headline {
        font-family: var(--font-primary);
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.1;
        font-weight: 600;
        margin-bottom: 2rem;
        color: var(--text-white);
    }

    /* Pills */
    .pills {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }
    .pill {
        padding: 0.6rem 1.6rem;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 99px;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        background: rgba(255, 255, 255, 0.05);
        transition:
            background 0.3s ease,
            transform 0.3s ease;
    }
    .pill:hover {
        background: rgba(255, 255, 255, 0.12);
        transform: translateY(-2px);
    }

    /* Image */
    .img-box {
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s var(--transition-premium);
    }
    .img-box:hover img {
        transform: scale(1.05);
    }
    .img-box.side {
        width: 100%;
        height: 480px;
        border-radius: 2rem;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.2);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .story-block {
            padding: 4rem 1.5rem;
        }
        .side-layout {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 3rem;
        }
        .side-content {
            text-align: center;
        }
        .side-content .pills {
            justify-content: center;
        }
    }
</style>
