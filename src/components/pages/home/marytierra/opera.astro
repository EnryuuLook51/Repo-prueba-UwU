---
import { getLangFromUrl, useTranslations } from "../../../../i18n/utils";
import OpBackground from "./opera/OpBackground.astro";
import OpImages from "./opera/OpImages.astro";
import OpCube from "./opera/OpCube.astro";
import OpCard from "./opera/OpCard.astro";
import OpUI from "./opera/OpUI.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefixPath = (p: string) => (lang === "es" ? p : `/${lang}${p}`);

const slides = [
    {
        num: "01",
        tag: "Océano",
        name: "PESCA",
        title: ["PESCA", "RESPONSABLE"],
        body: "Ofrecemos productos marinos respetando las tallas mínimas y brindando soluciones a los desechos generados.",
        stats: [
            { num: "100%", label: "Tallas OK" },
            { num: "0", label: "Desechos" },
        ],
        img: "/images/cube/PescaSostenible.jfif",
        side: "left",
    },
    {
        num: "02",
        tag: "Transformación",
        name: "VALORIZACIÓN",
        title: ["VALORIZACIÓN", "DE RESIDUOS"],
        body: "Transformamos residuos de pescado en hidrolizado (Líquido), aceite y materia orgánica sólida de alta calidad.",
        stats: [
            { num: "10T", label: "Residuos/Mes" },
            { num: "2T", label: "Abono/Mes" },
        ],
        img: "/images/cube/Circularidad.png",
        side: "right",
    },
    {
        num: "03",
        tag: "Biotecnología",
        name: "BIOINSUMOS",
        title: ["PRODUCCIÓN", "DE BIO-INSUMOS"],
        body: "Biofungicidas, bioinsecticidas y bionematicidas como propuesta integral para la agricultura orgánica.",
        stats: [
            { num: "1", label: "Laboratorio" },
            { num: "SENASA", label: "Convenio" },
        ],
        img: "/images/cube/solucionesBiologicas.jpeg",
        side: "left",
    },
    {
        num: "04",
        tag: "Sostenibilidad",
        name: "CAMPO",
        title: ["AGRICULTURA", "SOSTENIBLE"],
        body: "Nutrimos los suelos, mejoramos la productividad y reducimos el impacto ambiental drásticamente.",
        stats: [
            { num: "360°", label: "Visión" },
            { num: "♻️", label: "Eco-Friendly" },
        ],
        img: "/images/cube/agriculturaRegenerativa.jpg",
        side: "right",
    },
    {
        num: "05",
        tag: "Planta Balik",
        name: "BALIK",
        title: ["PROCESO", "PRIMARIO"],
        body: "Especialistas en fresco refrigerado, filetes congelados y empacados al vacío con protocolo sanitario.",
        stats: [
            { num: "3T", label: "Ton/Día" },
            { num: "1T", label: "Almacén" },
        ],
        img: "/images/FiletePescado.jpg",
        side: "left",
    },
    {
        num: "06",
        tag: "Garantía",
        name: "CALIDAD",
        title: ["ESTÁNDARES", "SANITARIOS"],
        body: "Aseguramos la inocuidad en toda la cadena de valor, cumpliendo con licencias de SANIPES y SENASA.",
        stats: [
            { num: "100%", label: "Seguro" },
            { num: "OK", label: "SANIPES" },
        ],
        img: "/images/lineas/ceprobio/laboratorio.jpg",
        side: "right",
    },
];

const N = slides.length;
const slideNames = slides.map((s) => s.name);
---

<section
    class="op-root"
    id="op-operaciones"
    aria-label="Operaciones Mar y Tierra"
    data-n={N}
    data-names={JSON.stringify(slideNames)}
>
    <div class="op-outer" id="op-outer" style={`--op-n:${N}`}>
        <div class="op-stage" id="op-stage">
            <OpBackground />
            <div class="op-desktop-view">
                <OpCube slides={slides} />
            </div>
            <div class="op-mobile-view">
                <OpImages slides={slides} />
            </div>

            <div class="op-cards" id="op-cards" aria-live="polite">
                {
                    slides.map((s, i) => (
                        <OpCard
                            slide={s}
                            index={i}
                            N={N}
                            prefixPath={prefixPath}
                        />
                    ))
                }
            </div>

            <OpUI slides={slides} />
        </div>
    </div>
</section>

<style>
    /* ══════════════════════════════════════════
       ESTRUCTURA Y TOKENS (Orquestador)
    ══════════════════════════════════════════ */
    .op-root {
        --op-bg: var(--bg-main, #f5f7f2);
        --op-fg: var(--text-primary, #192416);
        --op-muted: var(--text-secondary, #7a9977);
        --op-accent: var(--brand-green, #67bd45);
        --op-card-bg: var(--bg-card, rgba(255, 255, 255, 0.9));
        --op-card-border: var(--border-color, rgba(0, 0, 0, 0.08));
        --op-card-shadow: 0 8px 40px rgba(25, 36, 22, 0.08);
        --op-hairline: 1px;
        --op-ui-inset: 1.75rem;
        --op-font-display: var(--font-primary, sans-serif);
        --op-font-body: var(--font-secondary, sans-serif);
        --op-reveal-dur: 0.5s;
    }

    .op-stage {
        z-index: 1;
    }

    .op-outer {
        position: relative;
        height: calc(
            100vh + (var(--op-n) - 1) * 100vh + 100vh
        ); /* Aumentado a 100vh para dar más tiempo a la lectura */
        background: var(--op-bg);
    }

    .op-stage {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .op-cards {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 10;
    }

    .op-desktop-view {
        display: block;
    }
    .op-mobile-view {
        display: none;
    }

    @media (max-width: 1024px) {
        .op-desktop-view {
            display: none;
        }
        .op-mobile-view {
            display: block;
        }
    }
</style>

<script>
    const initOpera = () => {
        "use strict";

        /* ── Configuración Dinámica ── */
        const root = document.querySelector(".op-root") as HTMLElement;
        if (!root) return;

        const N = parseInt(root.dataset.n || "6");
        const NAMES = JSON.parse(root.dataset.names || "[]");

        /* ── DOM ── */
        const outer = document.getElementById("op-outer") as HTMLElement | null;
        const imgWrappers = [
            ...document.querySelectorAll("[data-op-image]"),
        ] as HTMLElement[];
        const cards = [
            ...document.querySelectorAll("[data-op-card]"),
        ] as HTMLElement[];
        const dots = [
            ...document.querySelectorAll("[data-op-dot]"),
        ] as HTMLElement[];
        const hudPct = document.getElementById("op-hud-pct");
        const hudFill = document.getElementById("op-hud-fill");
        const hudLbl = document.getElementById("op-hud-label");
        const capNum = document.getElementById("op-caption-num");
        const capName = document.getElementById("op-caption-name");
        const cube = document.getElementById("op-cube");

        if (!outer) return;

        /* Evitar inicialización doble (Ej: view transitions de Astro) */
        if (outer.dataset.initialized === "true") return;
        outer.dataset.initialized = "true";

        /* ── Helpers ── */
        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
        const clamp = (v: number, lo: number, hi: number) =>
            Math.max(lo, Math.min(hi, v));
        const easeIO = (t: number) =>
            t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

        const PER_SLIDE_VH = 100; // Incrementado para que se sienta que requiere más scroll

        function getProgress(): number {
            const rect = outer!.getBoundingClientRect();
            const transitionTotal =
                ((N - 1) * PER_SLIDE_VH * window.innerHeight) / 100;
            return Math.min(1, Math.max(0, -rect.top) / transitionTotal);
        }

        function setImages(p: number) {
            const isMobile = window.innerWidth <= 1024;

            if (isMobile) {
                imgWrappers.forEach((img, i) => {
                    const centre = i / (N - 1);
                    const diff = (p - centre) * (N - 1);
                    const op = clamp(1.4 - Math.abs(diff) * 2.5, 0, 1);
                    const slideFactor = diff * 120;
                    const isSquared = Math.abs(diff) < 0.1;
                    const highlight = isSquared ? 1 : 0;

                    img.style.opacity = String(op);
                    img.style.transform = `translateY(${slideFactor}px) scale(${1 + highlight * 0.02})`;
                    img.style.filter = `brightness(${1 + highlight * 0.08}) drop-shadow(0 ${10 + highlight * 15}px 40px rgba(0,0,0,${0.15 + highlight * 0.1}))`;
                    img.setAttribute(
                        "aria-hidden",
                        op < 0.05 ? "true" : "false",
                    );
                });
            } else if (cube) {
                // Lógica del CUBO (ESCRITORIO)
                // Dividimos el progreso en segmentos según Slide (0 a N-1)
                const segment = 1 / (N - 1);

                // Rotación base Y para las primeras 4 caras (índices 0, 1, 2, 3)
                // 0 -> 0deg, 1 -> -90deg, 2 -> -180deg, 3 -> -270deg
                let rotY = 0;
                let rotX = 12; // Inclinación constante

                if (p <= 3 * segment) {
                    // Caras laterales: 0, 1, 2, 3
                    rotY = -p * (N - 1) * 90;
                    rotX = 12;
                } else if (p <= 4 * segment) {
                    // Transición a TOP (Slide 5)
                    const subP = (p - 3 * segment) / segment; // 0 a 1
                    rotY = -270 + subP * 270; // Volver a Y=0 para el Top? o mantener -270?
                    // Para ver el top desde el "Back" o "Left"?
                    // Si Slide 3 era Left (-270), y queremos ver Top:
                    rotY = -270;
                    rotX = 12 - subP * 102; // De 12 a -90
                } else {
                    // Transición a BOTTOM (Slide 6)
                    const subP = (p - 4 * segment) / segment; // 0 a 1
                    rotY = -270 + subP * 90; // Ajuste
                    rotX = -90 + subP * 180; // De -90 a 90
                }

                cube.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
            }
        }

        function setCards(p: number) {
            const band = 1.0 / (N - 1);
            cards.forEach((c, i) => {
                const centre = i / (N - 1);
                const dist = Math.abs(p - centre);
                // Opacidad con meseta para la tarjeta
                const op = clamp(1.4 - dist * (N - 1) * 2, 0, 1);

                const parallaxY = (centre - p) * 1200;
                const isMobile = window.innerWidth <= 600;

                c.style.opacity = String(op);

                // Indicación visual: cambio de borde y sombra al estar cuadrado
                const isSquared = dist < 0.08 / (N - 1);
                if (isSquared) {
                    c.style.borderColor = "var(--op-accent)";
                    c.style.boxShadow = "0 30px 60px rgba(103, 189, 69, 0.15)";
                } else {
                    c.style.borderColor = "var(--op-card-border)";
                    c.style.boxShadow = "var(--op-card-shadow)";
                }

                if (isMobile) {
                    c.style.transform = `translateY(${parallaxY}px)`;
                } else {
                    c.style.transform = `translateY(calc(-50% + ${parallaxY}px))`;
                }
                c.setAttribute("aria-hidden", op < 0.05 ? "true" : "false");
                c.style.pointerEvents = op > 0.5 ? "auto" : "none";
            });
        }

        let lastActive = -1;
        function setUI(p: number) {
            const pct = Math.round(p * 100);
            const active = Math.round(p * (N - 1));
            if (hudPct) hudPct.textContent = `${String(pct).padStart(2, "0")}%`;
            if (hudFill) hudFill.style.width = `${pct}%`;
            if (active !== lastActive) {
                lastActive = active;
                const name = NAMES[active] ?? "";
                if (hudLbl) hudLbl.textContent = name;
                if (capNum)
                    capNum.textContent = String(active + 1).padStart(2, "0");
                if (capName) capName.textContent = name;
                dots.forEach((d, i) =>
                    d.classList.toggle("op-dot--active", i === active),
                );
            }
        }

        let tgt = 0,
            smooth = 0,
            lastNow = performance.now(),
            rafId: number;
        function tick(now: number) {
            rafId = requestAnimationFrame(tick);
            const dt = Math.min((now - lastNow) / 1000, 0.05);
            lastNow = now;
            tgt = getProgress();
            smooth += (tgt - smooth) * (1 - Math.exp(-dt * 7));
            smooth = clamp(smooth, 0, 1);
            setImages(smooth);
            setCards(smooth);
            setUI(smooth);
        }

        const io = new IntersectionObserver(
            ([e]) => {
                if (e.isIntersecting) {
                    lastNow = performance.now();
                    rafId = requestAnimationFrame(tick);
                } else {
                    cancelAnimationFrame(rafId);
                }
            },
            { rootMargin: "200px" },
        );

        io.observe(outer);

        const scrollToSlide = (idx: number) => {
            if (!outer) return;
            const outerTop = outer.getBoundingClientRect().top + window.scrollY;
            // Usar transitionTotal en lugar del height total para no incluir el plateau final
            const transitionTotal =
                ((N - 1) * PER_SLIDE_VH * window.innerHeight) / 100;
            const slideProgress = idx / (N - 1);
            const targetY = outerTop + slideProgress * transitionTotal;
            window.scrollTo({ top: targetY, behavior: "smooth" });
        };

        outer.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;

            // Botón siguiente
            const btn = target.closest("[data-op-nav-next]");
            if (btn) {
                const idx = Number((btn as HTMLElement).dataset.opNavNext);
                if (!isNaN(idx)) scrollToSlide(idx);
                return;
            }

            // Dot de navegación
            const dot = target.closest("[data-op-dot]");
            if (dot) {
                const idx = Number((dot as HTMLElement).dataset.opDot);
                if (!isNaN(idx)) scrollToSlide(idx);
                return;
            }
        });

        const init = () => {
            setImages(0);
            setCards(0);
            setUI(0);
        };
        init();
    };

    // Ejecutar al cargar la página (soporte para recargas completas y View Transitions de Astro)
    initOpera();
    document.addEventListener("astro:page-load", initOpera);
    document.addEventListener("astro:after-swap", initOpera);
</script>
