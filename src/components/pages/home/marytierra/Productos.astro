---
import { getLangFromUrl, useTranslations } from "../../../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefixPath = (path: string) => {
    if (lang === "es") return path;
    return `/${lang}${path}`;
};
---

<!-- BLOQUE 4: Productos -->
<div class="story-block" id="productos-servicios" data-reveal>
    <div class="story-inner center">
        <span class="tag">{t("marytierra.products.tag")}</span>
        <div class="products">
            <!-- Tarjeta 1: Del Mar -->
            <div class="product-card" data-reveal-child>
                <div class="img-box product-img">
                    <img
                        src="/images/FiletePescado.jpg"
                        alt="Filete de pescado fresco"
                        loading="lazy"
                    />
                </div>
                <h4 class="product-name">
                    {t("marytierra.products.p1.name")}
                </h4>
                <p class="product-desc">
                    {t("marytierra.products.p1.desc")}
                </p>
            </div>

            <!-- Tarjeta 2: 3D Bioinsumos -->
            <article class="product-card card-3d" data-reveal-child>
                <img
                    src="/images/Catalogo/Fondo/GpBioEstimulanteFondo.png"
                    alt=""
                    class="card-3d-bg"
                    loading="lazy"
                />
                <img
                    src="/images/Catalogo/Pngs/GpBioEstimulante.png"
                    alt="Bioinsumos orgánicos"
                    class="card-3d-product"
                    loading="lazy"
                />
                <div class="card-3d-overlay"></div>
                <div class="card-3d-info">
                    <h4 class="product-name">
                        {t("marytierra.products.p2.name")}
                    </h4>
                    <p class="product-desc">
                        {t("marytierra.products.p2.desc")}
                    </p>
                </div>
            </article>
        </div>

        <div class="product-actions" data-reveal-child>
            <a href={prefixPath("/catalogo")} class="btn-cta">
                {t("marytierra.products.verMas")}
            </a>
        </div>
    </div>
</div>

<style>
    .story-block {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }
    .story-inner {
        max-width: 1100px;
        margin: 0 auto;
    }
    .story-inner.center {
        text-align: center;
    }

    /* Reveal */
    [data-reveal] {
        opacity: 0;
        transform: translateY(60px);
        transition:
            opacity 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
    [data-reveal-child] {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }
    [data-reveal-child].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* Tag */
    .tag {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--brand-green);
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    /* Products grid */
    .products {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        max-width: 700px;
        margin: 2rem auto 0;
    }

    .product-actions {
        margin-top: 4rem;
        margin-bottom: 4rem;
        display: flex;
        justify-content: center;
    }

    /* Product card base */
    .product-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        padding: 3rem 2rem;
        border-radius: 2rem;
        text-align: center;
        box-shadow: var(--shadow-glow);
        transition:
            transform 0.4s ease,
            box-shadow 0.4s ease;
    }
    .product-card:hover {
        transform: translateY(-8px);
    }

    .product-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
    }
    .product-desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* Image boxes */
    .img-box {
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s var(--transition-premium);
    }
    .img-box:hover img {
        transform: scale(1.05);
    }
    .img-box.product-img {
        width: 100%;
        height: 180px;
        margin-bottom: 1rem;
        border-radius: 1.2rem;
    }

    /* 3D Card */
    .card-3d {
        position: relative;
        overflow: hidden;
        cursor: pointer;
        padding: 0 !important;
        min-height: 320px;
    }
    .card-3d-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 2rem;
        box-shadow: 0 60px 60px -60px rgba(0, 109, 182, 0.5);
    }
    .card-3d-product {
        position: absolute;
        width: 65%;
        bottom: 0;
        left: 0;
        right: 0;
        margin: auto;
        transform: translateY(25%);
        transition: all 0.4s ease;
        opacity: 0;
        object-fit: contain;
        z-index: 3;
        filter: drop-shadow(0 10px 25px rgba(0, 0, 0, 0.4));
    }
    .card-3d-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            transparent 10%,
            rgba(0, 0, 0, 0.5) 50%,
            rgba(0, 0, 0, 0.9) 95%
        );
        opacity: 0;
        transition: all 0.4s ease;
        z-index: 2;
        border-radius: 2rem;
    }
    .card-3d-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.8rem;
        z-index: 4;
        text-align: left;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s ease 0.1s;
    }
    .card-3d-info .product-name {
        color: var(--text-white);
    }
    .card-3d-info .product-desc {
        color: rgba(255, 255, 255, 0.8);
    }
    .card-3d:hover {
        transform: perspective(500px) rotateX(10deg) translateY(-5%)
            translateZ(0);
        box-shadow: 0 40px 60px rgba(0, 0, 0, 0.15);
    }
    .card-3d:hover .card-3d-overlay {
        opacity: 1;
    }
    .card-3d:hover .card-3d-product {
        opacity: 1;
        transform: translateY(10%);
    }
    .card-3d:hover .card-3d-info {
        opacity: 1;
        transform: translateY(0);
    }

    /* CTA Button */
    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.2rem 3rem;
        background: var(--brand-green);
        color: var(--text-white);
        text-decoration: none;
        border-radius: 99px;
        font-weight: 700;
        font-size: 1rem;
        font-family: var(--font-primary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.4s var(--transition-premium);
    }
    .btn-cta:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.25);
    }

    @media (max-width: 768px) {
        .story-block {
            padding: 4rem 1.5rem;
        }
        .products {
            grid-template-columns: 1fr;
        }
        .img-box.product-img {
            height: 140px;
        }
    }
</style>
