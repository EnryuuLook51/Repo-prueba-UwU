---
import { getLangFromUrl, useTranslations } from "../../../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefixPath = (path: string) => {
    if (lang === "es") return path;
    return `/${lang}${path}`;
};
---

<!-- BLOQUE 5: CTA Final -->
<div class="story-block dark-block green-block cta-block" data-reveal>
    <div class="story-inner center">
        <h2 class="headline cta-headline">
            <Fragment set:html={t("marytierra.future.title")} />
        </h2>
        <a href={prefixPath("/contacto")} class="btn-cta">
            {t("marytierra.future.button")}
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
        </a>
    </div>
</div>

<style>
    .story-block {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }
    .story-block.dark-block {
        color: var(--text-white);
    }
    .story-block.green-block {
        background: var(--brand-green);
    }
    .cta-block {
        padding: 8rem 2rem;
    }

    .story-inner {
        max-width: 1100px;
        margin: 0 auto;
    }
    .story-inner.center {
        text-align: center;
    }

    /* Reveal */
    [data-reveal] {
        opacity: 0;
        transform: translateY(60px);
        transition:
            opacity 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* Typography */
    .headline {
        font-family: var(--font-primary);
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.1;
        font-weight: 600;
        margin-bottom: 2rem;
        color: var(--text-white);
    }
    .headline :global(em) {
        font-style: italic;
        color: var(--text-white);
    }
    .cta-headline {
        font-size: clamp(2rem, 4.5vw, 3.5rem);
        margin-bottom: 3rem;
    }

    /* Button */
    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.2rem 3rem;
        background: var(--brand-blue);
        color: var(--text-white);
        text-decoration: none;
        border-radius: 99px;
        font-weight: 700;
        font-size: 1rem;
        font-family: var(--font-primary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.4s var(--transition-premium);
    }
    .btn-cta:hover {
        background: var(--text-white);
        color: var(--brand-green);
        transform: translateY(-4px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.25);
    }

    @media (max-width: 768px) {
        .cta-block {
            padding: 5rem 1.5rem;
        }
    }
</style>
