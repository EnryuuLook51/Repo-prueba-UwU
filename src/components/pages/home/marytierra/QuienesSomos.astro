---
import { getLangFromUrl, useTranslations } from "../../../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- BLOQUE 3: Quiénes Somos -->
<div class="story-block dark-block blue-block" id="nosotros" data-reveal>
    <div class="story-inner company-layout full-width">
        <div class="accent-card" data-reveal-child>
            <span class="tag">{t("marytierra.company.tag")}</span>
            <h2 class="headline">{t("marytierra.company.title")}</h2>
            <p class="body-lg">{t("marytierra.company.text")}</p>
        </div>
        <div class="img-box diagram" data-reveal-child>
            <img
                src="/images/modeloCircular.png"
                alt="Modelo de economía circular"
                loading="lazy"
            />
        </div>
    </div>
</div>

<style>
    .story-block {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }
    .story-block.dark-block {
        color: var(--text-white);
    }
    .story-block.blue-block {
        background: var(--brand-blue);
    }

    .story-inner {
        max-width: 1100px;
        margin: 0 auto;
    }
    .story-inner.full-width {
        max-width: 100%;
        padding-left: 5rem;
        padding-right: 5rem;
    }
    .company-layout {
        display: grid;
        grid-template-columns: 2fr 3fr;
        gap: 3rem;
        align-items: center;
    }

    /* Reveal */
    [data-reveal] {
        opacity: 0;
        transform: translateY(60px);
        transition:
            opacity 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
    [data-reveal-child] {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }
    [data-reveal-child].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* Typography */
    .tag {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--brand-green);
        margin-bottom: 1.5rem;
        font-weight: 600;
    }
    .headline {
        font-family: var(--font-primary);
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.1;
        font-weight: 600;
        margin-bottom: 2rem;
        color: var(--text-white);
    }
    .body-lg {
        font-family: var(--font-secondary);
        font-size: clamp(1.05rem, 1.5vw, 1.3rem);
        line-height: 1.7;
        color: var(--text-white);
        max-width: 700px;
    }

    /* Accent card */
    .accent-card {
        border-left: 5px solid var(--brand-green);
        padding: 4rem 3rem;
        border-radius: 0 2rem 2rem 0;
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(10px);
        text-align: left;
        max-width: 800px;
    }

    /* Image */
    .img-box {
        border-radius: 1.5rem;
        overflow: hidden;
    }
    .img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s var(--transition-premium);
    }
    .img-box.diagram {
        width: 100%;
        min-height: 450px;
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
    }
    .img-box.diagram img {
        object-fit: contain;
        padding: 1rem;
    }

    @media (max-width: 768px) {
        .story-block {
            padding: 4rem 1.5rem;
        }
        .story-inner.full-width {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }
        .company-layout {
            grid-template-columns: 1fr;
        }
        .accent-card {
            padding: 2.5rem 2rem;
            text-align: center;
            border-left: none;
            border-top: 5px solid var(--brand-green);
            border-radius: 0 0 2rem 2rem;
        }
        .img-box.diagram {
            min-height: 300px;
        }
    }
</style>
