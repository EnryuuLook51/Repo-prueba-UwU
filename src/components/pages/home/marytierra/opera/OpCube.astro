---
/* 
   OpCube.astro — Cubo 3D de 6 Caras Completas
*/
interface Props {
    slides: any[];
}
const { slides } = Astro.props;
---

<div class="op-perspective" aria-hidden="true">
    <div class="op-cube" id="op-cube">
        {
            slides.map((s, i) => {
                const rules = [
                    "rotateY(0deg)",
                    "rotateY(90deg)",
                    "rotateY(180deg)",
                    "rotateY(270deg)",
                    "rotateX(90deg)",
                    "rotateX(-90deg)",
                ];
                const transform = `${rules[i]} translateZ(calc(var(--sz) / 2))`;

                return (
                    <div
                        class="op-face"
                        data-face={i}
                        style={`transform: ${transform};`}
                    >
                        <img
                            src={s.img}
                            alt={s.name}
                            loading={i === 0 ? "eager" : "lazy"}
                            style={
                                i === 4
                                    ? "transform: rotate(180deg);"
                                    : i === 5
                                      ? "transform: rotate(180deg);"
                                      : ""
                            }
                        />
                        <div class="op-face-overlay" />
                    </div>
                );
            })
        }
    </div>
</div>

<style>
    .op-perspective {
        position: absolute;
        inset: 0;
        perspective: 1200px;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 1;
    }

    .op-cube {
        --sz: min(60vw, 62vh, 520px);
        width: var(--sz);
        height: var(--sz);
        position: relative;
        transform-style: preserve-3d;
        transform: rotateX(12deg) rotateY(0deg);
        will-change: transform;
    }

    @media (max-width: 600px) {
        .op-cube {
            --sz: 50vw;
        }
    }

    .op-face {
        position: absolute;
        inset: 0;
        overflow: hidden;
        backface-visibility: hidden;
        background:
            repeating-linear-gradient(
                0deg,
                rgba(25, 36, 22, 0.05) 0,
                rgba(25, 36, 22, 0.05) 1px,
                transparent 1px,
                transparent 52px
            ),
            repeating-linear-gradient(
                90deg,
                rgba(25, 36, 22, 0.05) 0,
                rgba(25, 36, 22, 0.05) 1px,
                transparent 1px,
                transparent 52px
            ),
            #edf2e8;
        box-shadow: inset 0 0 0 1px rgba(103, 189, 69, 0.15);
    }

    .op-face img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .op-face-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            160deg,
            rgba(245, 247, 242, 0.15) 0%,
            rgba(62, 168, 32, 0.04) 100%
        );
        z-index: 1;
    }
</style>
