---
/* 
   OpImages.astro — Galería de imágenes grandes con efecto de desplazamiento
*/
interface Props {
    slides: any[];
}
const { slides } = Astro.props;
---

<div class="op-images-container" aria-hidden="true">
    <div class="op-images-inner" id="op-images-inner">
        {
            slides.map((s, i) => (
                <div
                    class={`op-image-wrap op-image-wrap--${s.side}`}
                    data-op-image={i}
                    style={`z-index: ${slides.length - i};`}
                >
                    <img
                        src={s.img}
                        alt={s.name}
                        loading={i === 0 ? "eager" : "lazy"}
                    />
                    <div class="op-image-overlay" />
                </div>
            ))
        }
    </div>
</div>

<style>
    .op-images-container {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
    }

    .op-images-inner {
        position: relative;
        width: 100%;
        height: 100%;
        will-change: transform;
    }

    .op-image-wrap {
        position: absolute;
        width: 60vw;
        height: 65vh;
        top: 15vh;
        overflow: hidden;
        border-radius: 12px;
        box-shadow: 0 40px 120px rgba(0, 0, 0, 0.25);
        opacity: 0;
        transition: opacity 0.4s ease;
        background: #edf2e8;
    }

    .op-image-wrap--left {
        right: 5vw; /* Imagen a la derecha si la tarjeta está a la izquierda */
    }

    .op-image-wrap--right {
        left: 5vw; /* Imagen a la izquierda si la tarjeta está a la derecha */
    }

    .op-image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .op-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(25, 36, 22, 0.1) 0%,
            transparent 40%,
            rgba(25, 36, 22, 0.2) 100%
        );
        z-index: 1;
    }

    @media (max-width: 1100px) {
        .op-image-wrap {
            width: 70vw;
            height: 60vh;
        }
    }

    @media (max-width: 600px) {
        .op-image-wrap {
            width: 90vw;
            height: 48vh;
            top: 5vh;
            left: 5vw !important;
            right: auto !important;
        }
    }
</style>
