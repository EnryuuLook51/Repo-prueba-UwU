---
1;
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero-section" id="home">
  <!-- Full Screen Background Carousel -->
  <div class="hero-bg-wrapper">
    <div class="visual-container">
      <div class="main-image-wrapper">
        {
          [
            "/images/agricultores_trabajando_202603251507.jpeg",
            "/images/carrusel/imagen1.jpeg",
            "/images/carrusel/imagen 2.png",
          ].map((img, index) => (
            <Image
              src={img}
              alt={`Sustainability ${index + 1}`}
              width={index === 0 ? 1920 : 1280}
              height={index === 0 ? 1080 : 720}
              class={`main-image hero-carousel-img ${index === 0 ? "active" : ""}`}
              loading={index === 0 ? "eager" : "lazy"}
              decoding={index === 0 ? "sync" : "async"}
            />
          ))
        }
        <div class="image-overlay"></div>
      </div>
    </div>
  </div>

  <!-- Content Overlay -->
  <div class="hero-content text-center" id="heroText">
    <div class="hero-content-inner">
      <h1 class="hero-title pt-12 md:pt-0" id="heroTitle">
        <span class="title-blue">{t("hero.subtitle.p1")}</span>
        <br />
        <span class="title-green">{t("hero.subtitle.p2")}</span>
      </h1>

      <p class="text-white hero-description" id="heroDesc" data-fade-in="up">
        {t("hero.description")}
      </p>

      <div class="hero-actions items-center" id="heroActions" data-fade-in="up">
        <div class="hero-cta">
          <a href="/contacto" class="btn-premium">
            {t("nav.consultation")}
            <i class="fas fa-arrow-right ms-2 transition-transform"></i>
          </a>
        </div>
        <div class="hero-secondary-cta pt-4 md:pt-0">
          <span class="text-xs text-white/70 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-brand-green animate-pulse"
            ></span>
            Disponibilidad inmediata para nuevos proyectos
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fixed Centering */
  .hero-section {
    min-height: 100vh;
    width: 100%;
    position: relative;
    background: var(--brand-blue);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .visual-container {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .main-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .main-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 2s ease-in-out;
    transform: scale(1.05);
  }

  .main-image.active {
    opacity: 1;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.6) 300%
    );
    z-index: 2;
  }

  .container {
    pointer-events: none; /* Let clicks pass to parallax if needed, but we have buttons */
  }

  .hero-content {
    pointer-events: auto;
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-title {
    font-size: clamp(2.2rem, 12vw, 6.5rem);
    font-weight: 950;
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
    color: var(--text-white);
    word-break: keep-all;
  }

  @media (max-width: 640px) {
    .hero-content {
      padding: 0 1.5rem;
    }
    .hero-title {
      margin-bottom: 1rem;
    }
  }

  .title-blue {
    color: var(--brand-blue-5);
    text-shadow:
      2px 2px 0px #fff,
      -2px -2px 0px #fff,
      2px -2px 0px #fff,
      -2px 2px 0px #fff,
      0 0 10px rgba(255, 255, 255, 0.5);
  }
  .title-green {
    color: var(--brand-green);
    text-shadow:
      2px 2px 0px #fff,
      -2px -2px 0px #fff,
      2px -2px 0px #fff,
      -2px 2px 0px #fff,
      0 0 10px rgba(255, 255, 255, 0.5);
  }

  .title-main {
    display: block;
  }

  :global(.word-wrapper) {
    display: inline-block;
    white-space: nowrap;
    margin-right: 0.25em;
  }

  :global(.split-char) {
    display: inline-block;
    opacity: 1;
    transform: translateX(0);
  }

  .hero-description {
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    color: var(--text-white);
    max-width: 800px;
    line-height: 1.6;
    margin-bottom: 3rem;
    opacity: 1;
    max-width: 1400px;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 1;
  }

  .btn-premium:hover i {
    transform: translateX(5px);
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 6rem;
    }
    .hero-description {
      margin: 0 auto 3rem;
    }
    .hero-actions {
      align-items: center;
    }
    .badge-1,
    .badge-2,
    .badge-3 {
      display: none;
    }
    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function splitIntoWordsAndChars(node: Node) {
    const text = node.textContent || "";
    const words = text.split(" ").filter((w: string) => w !== "");
    const fragment = document.createDocumentFragment();

    words.forEach((word: string) => {
      const wordSpan = document.createElement("span");
      wordSpan.className = "word-wrapper";
      word.split("").forEach((char: string) => {
        const charSpan = document.createElement("span");
        charSpan.className = "split-char";
        charSpan.innerText = char;
        wordSpan.appendChild(charSpan);
      });
      fragment.appendChild(wordSpan);
    });
    (node as Element).replaceWith(fragment);
  }

  function splitTextPro(el: HTMLElement) {
    const childNodes = Array.from(el.childNodes);
    childNodes.forEach((node: Node) => {
      if (node.nodeType === 3) splitIntoWordsAndChars(node);
      else if (
        (node as Element).classList &&
        (node as Element).classList.contains("split-target")
      )
        splitIntoWordsAndChars(node);
    });
    return el.querySelectorAll(".split-char");
  }

  window.addEventListener("load", () => {
    const heroTl = gsap.timeline({ delay: 0 });
    const titleEl = document.getElementById("heroTitle");
    if (!titleEl) return;
    const chars = splitTextPro(titleEl as HTMLElement);

    heroTl
      .to(chars, {
        x: 0,
        opacity: 1,
        ease: "power2.inOut",
        stagger: { each: 0.012, from: "random" },
        duration: 0.6,
      })
      .from(
        "[data-fade-in]",
        {
          y: (i, el) =>
            el.dataset.fadeIn === "up"
              ? 40
              : el.dataset.fadeIn === "down"
                ? -40
                : 0,
          x: (i, el) => (el.dataset.fadeIn === "left" ? 80 : 0),
          duration: 1.25,
          ease: "power4.inOut",
          stagger: 0.08,
        },
        "-=0.3",
      )
      .to(
        ".hero-carousel-img",
        {
          scale: 1,
          duration: 2,
          ease: "power2.out",
        },
        "-=1.5",
      );
    // Hero Image Carousel Logic
    const carouselImages = document.querySelectorAll(".hero-carousel-img");
    let currentIdx = 0;

    function nextHeroImage() {
      const nextIdx = (currentIdx + 1) % carouselImages.length;

      gsap.to(carouselImages[currentIdx], {
        opacity: 0,
        duration: 2,
        ease: "power2.inOut",
      });
      gsap.to(carouselImages[nextIdx], {
        opacity: 1,
        duration: 2,
        ease: "power2.inOut",
      });

      currentIdx = nextIdx;
    }

    if (carouselImages.length > 1) {
      setInterval(nextHeroImage, 6000); // Change image every 6 seconds
    }
  });
</script>
