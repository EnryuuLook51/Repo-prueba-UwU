---
import OceanoYCampo from "./marytierra/opera.astro";
---

<section class="story-root" id="identidad">
    <OceanoYCampo />
</section>

<style>
    .story-root {
        width: 100%;
        position: relative;
    }
</style>

<script>
    /**
     * Sistema Global de Revelado (Storytelling)
     * Maneja el fade-in de secciones y el stagger de sus elementos hijos.
     */
    const initRevealObserver = () => {
        const revealElements = document.querySelectorAll("[data-reveal]");
        if (revealElements.length === 0) return;

        const observerOptions = {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px",
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                const target = entry.target;

                if (entry.isIntersecting) {
                    target.classList.add("revealed");

                    // Staggering para elementos hijos
                    const children = target.querySelectorAll(
                        "[data-reveal-child]",
                    );
                    children.forEach((child, i) => {
                        setTimeout(() => {
                            child.classList.add("revealed");
                        }, 120 * i);
                    });
                } else {
                    // Opcional: remover clases si se desea re-animar al volver a subir
                    // target.classList.remove("revealed");
                }
            });
        }, observerOptions);

        revealElements.forEach((el) => observer.observe(el));
    };

    // Ejecutar al cargar y tras navegaciones de Astro (si se usa View Transitions)
    initRevealObserver();
    document.addEventListener("astro:after-swap", initRevealObserver);
</script>
