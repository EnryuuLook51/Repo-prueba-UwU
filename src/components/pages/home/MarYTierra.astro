---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefixPath = (path: string) => {
    if (lang === "es") return path;
    return `/${lang}${path}`;
};
---

<section class="story" id="identidad">
    <!-- BLOQUE 1: Valores / Raíces -->
    <div class="story-block dark-block green-block" id="valores" data-reveal>
        <div class="story-inner side-layout">
            <div class="side-content">
                <span class="tag">{t("marytierra.roots.label")}</span>
                <h2 class="headline">
                    {t("marytierra.roots.v1")}
                    <br />
                    {t("marytierra.roots.v2")}
                    <br />
                    {t("marytierra.roots.v3")}
                </h2>
                <div class="pills">
                    <span class="pill">{t("marytierra.roots.v1")}</span>
                    <span class="pill">{t("marytierra.roots.v2")}</span>
                    <span class="pill">{t("marytierra.roots.v3")}</span>
                </div>
            </div>
            <div class="img-box side" data-reveal-child>
                <img
                    src="/images/sostenibilidad-banner.png"
                    alt="Sostenibilidad"
                    loading="lazy"
                />
            </div>
        </div>
    </div>

    <!-- BLOQUE 2: Océano & Campo (lado a lado) -->
    <div class="story-block" id="operaciones" data-reveal>
        <div class="story-inner two-col">
            <div class="col glass-card" data-reveal-child>
                <div class="img-box card-img">
                    <img
                        src="/images/Chimbote.jpg"
                        alt="Pesca artesanal en Chimbote"
                        loading="lazy"
                    />
                </div>
                <span class="tag blue">{t("marytierra.ocean.tag")}</span>
                <h3 class="col-title">
                    <Fragment set:html={t("marytierra.ocean.title")} />
                </h3>
                <p class="col-text">{t("marytierra.ocean.text")}</p>
            </div>
            <div class="col glass-card" data-reveal-child>
                <div class="img-box card-img">
                    <img
                        src="/images/agricultura-chimbote.jpg"
                        alt="Agricultura regenerativa"
                        loading="lazy"
                    />
                </div>
                <span class="tag green">{t("marytierra.earth.tag")}</span>
                <h3 class="col-title">
                    <Fragment set:html={t("marytierra.earth.title")} />
                </h3>
                <p class="col-text">{t("marytierra.earth.text")}</p>
            </div>
        </div>
    </div>

    <!-- BLOQUE 3: Quiénes Somos -->
    <div class="story-block dark-block blue-block" id="nosotros" data-reveal>
        <div class="story-inner company-layout full-width">
            <div class="accent-card" data-reveal-child>
                <span class="tag">{t("marytierra.company.tag")}</span>
                <h2 class="headline">{t("marytierra.company.title")}</h2>
                <p class="body-lg">{t("marytierra.company.text")}</p>
            </div>
            <div class="img-box diagram" data-reveal-child>
                <img
                    src="/images/modeloCircular.png"
                    alt="Modelo de economía circular"
                    loading="lazy"
                />
            </div>
        </div>
    </div>

    <!-- BLOQUE 4: Productos -->
    <div class="story-block" id="productos-servicios" data-reveal>
        <div class="story-inner center">
            <span class="tag">{t("marytierra.products.tag")}</span>
            <div class="products">
                <div class="product-card" data-reveal-child>
                    <div class="img-box product-img">
                        <img
                            src="/images/FiletePescado.jpg"
                            alt="Filete de pescado fresco"
                            loading="lazy"
                        />
                    </div>
                    <h4 class="product-name">
                        {t("marytierra.products.p1.name")}
                    </h4>
                    <p class="product-desc">
                        {t("marytierra.products.p1.desc")}
                    </p>
                </div>
                <article class="product-card card-3d" data-reveal-child>
                    <img
                        src="/images/fondo-bioinsumo.png"
                        alt=""
                        class="card-3d-bg"
                        loading="lazy"
                    />
                    <img
                        src="/images/Bioinsumos.png"
                        alt="Bioinsumos orgánicos"
                        class="card-3d-product"
                        loading="lazy"
                    />
                    <div class="card-3d-overlay"></div>
                    <div class="card-3d-info">
                        <h4 class="product-name">
                            {t("marytierra.products.p2.name")}
                        </h4>
                        <p class="product-desc">
                            {t("marytierra.products.p2.desc")}
                        </p>
                    </div>
                </article>
            </div>
        </div>
    </div>

    <!-- BLOQUE 5: CTA Final -->
    <div class="story-block dark-block green-block cta-block" data-reveal>
        <div class="story-inner center">
            <h2 class="headline cta-headline">
                <Fragment set:html={t("marytierra.future.title")} />
            </h2>
            <a href={prefixPath("/contacto")} class="btn-cta">
                {t("marytierra.future.button")}
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    /* ═══ LAYOUT ═══ */
    .story {
        width: 100%;
    }

    .story-block {
        padding: 6rem 2rem;
        background: var(--bg-main);
    }

    .story-block.dark-block {
        color: var(--text-white);
    }

    .story-block.green-block {
        background: var(--brand-green);
    }

    .story-block.blue-block {
        background: var(--brand-blue);
    }

    .story-inner {
        max-width: 1100px;
        margin: 0 auto;
    }

    /* Modifica el max-width a 100% para que ocupe todo el ancho */
    .story-inner.full-width {
        max-width: 100%;
        padding-left: 5rem; /* <--- Aquí modificas el padding izquierdo */
        padding-right: 5rem; /* <--- Aquí modificas el padding derecho */
    }

    .story-inner.center {
        text-align: center;
    }

    .story-inner.side-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .side-content {
        text-align: left;
    }

    .side-content .pills {
        justify-content: flex-start;
        margin-top: 2.5rem;
    }

    /* ═══ REVEAL ANIMATIONS ═══ */
    [data-reveal] {
        opacity: 0;
        transform: translateY(60px);
        transition:
            opacity 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    [data-reveal-child] {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }

    [data-reveal-child].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* ═══ TYPOGRAPHY ═══ */
    .tag {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--brand-green);
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .tag.blue {
        color: var(--brand-blue);
    }
    .tag.green {
        color: var(--brand-green);
    }

    .headline {
        font-family: var(--font-primary);
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.1;
        font-weight: 600;
        margin-bottom: 2rem;
    }

    .dark-block .headline {
        color: var(--text-white);
    }

    .headline :global(em) {
        font-style: italic;
        color: var(--brand-green);
    }

    /* En bloques verdes, los textos verdes pasan a blanco */
    .green-block .tag {
        color: var(--text-white);
        opacity: 0.85;
    }

    .green-block .headline :global(em) {
        color: var(--text-white);
    }

    .cta-headline {
        font-size: clamp(2rem, 4.5vw, 3.5rem);
        margin-bottom: 3rem;
    }

    .body-lg {
        font-family: var(--font-secondary);
        font-size: clamp(1.05rem, 1.5vw, 1.3rem);
        line-height: 1.7;
        color: var(--text-white);
        max-width: 700px;
        margin: 0 auto;
    }

    /* ═══ PILLS ═══ */
    .pills {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .pill {
        padding: 0.6rem 1.6rem;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 99px;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        background: rgba(255, 255, 255, 0.05);
        transition:
            background 0.3s ease,
            transform 0.3s ease;
    }

    .pill:hover {
        background: rgba(255, 255, 255, 0.12);
        transform: translateY(-2px);
    }

    /* ═══ TWO COLUMNS ═══ */
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
    }

    .glass-card {
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        padding: 3rem 2.5rem;
        border-radius: 2rem;
        box-shadow: var(--shadow-glow);
        transition:
            transform 0.4s ease,
            box-shadow 0.4s ease;
    }

    .glass-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 30px 60px rgba(32, 114, 184, 0.1);
    }

    .col-title {
        font-family: var(--font-primary);
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        line-height: 1.15;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .col-title :global(em) {
        font-style: italic;
        color: var(--brand-green);
    }

    .col-text {
        font-family: var(--font-secondary);
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--text-secondary);
    }

    /* ═══ COMPANY LAYOUT ═══ */
    .company-layout {
        display: grid;
        grid-template-columns: 2fr 3fr;
        gap: 3rem;
        align-items: center;
    }

    /* ═══ ACCENT CARD ═══ */
    .accent-card {
        border-left: 5px solid var(--brand-green);
        padding: 4rem 3rem;
        border-radius: 0 2rem 2rem 0;
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(10px);
        text-align: left;
        max-width: 800px;
    }

    /* ═══ PRODUCTS ═══ */
    .products {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        max-width: 700px;
        margin: 2rem auto 0;
    }

    .product-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        padding: 3rem 2rem;
        border-radius: 2rem;
        text-align: center;
        box-shadow: var(--shadow-glow);
        transition:
            transform 0.4s ease,
            box-shadow 0.4s ease;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px var(--shadow-glow);
    }

    .product-icon {
        font-size: 3.5rem;
        display: block;
        margin-bottom: 1.2rem;
    }

    .product-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
    }

    .product-desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* ═══ TARJETA 3D — BIOINSUMOS ═══ */
    .card-3d {
        position: relative;
        overflow: hidden;
        cursor: pointer;
        padding: 0 !important;
        min-height: 320px;
    }

    .card-3d-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 2rem;
        box-shadow: 0 60px 60px -60px rgba(0, 109, 182, 0.5);
    }

    .card-3d-product {
        position: absolute;
        width: 65%;
        bottom: 0;
        left: 0;
        right: 0;
        margin: auto;
        transform: translateY(25%);
        transition: all 0.4s ease;
        opacity: 0;
        object-fit: contain;
        z-index: 3;
        filter: drop-shadow(0 10px 25px rgba(0, 0, 0, 0.4));
    }

    .card-3d-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            transparent 10%,
            rgba(0, 0, 0, 0.5) 50%,
            rgba(0, 0, 0, 0.9) 95%
        );
        opacity: 0;
        transition: all 0.4s ease;
        z-index: 2;
        border-radius: 2rem;
    }

    .card-3d-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.8rem;
        z-index: 4;
        text-align: left;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s ease 0.1s;
    }

    .card-3d-info .product-name {
        color: var(--text-white);
    }

    .card-3d-info .product-desc {
        color: rgba(255, 255, 255, 0.8);
    }

    .card-3d:hover {
        transform: perspective(500px) rotateX(10deg) translateY(-5%)
            translateZ(0);
        box-shadow: 0 40px 60px rgba(0, 0, 0, 0.15);
    }

    .card-3d:hover .card-3d-overlay {
        opacity: 1;
    }

    .card-3d:hover .card-3d-product {
        opacity: 1;
        transform: translateY(10%);
    }

    .card-3d:hover .card-3d-info {
        opacity: 1;
        transform: translateY(0);
    }
    /* ═══ CTA ═══ */
    .cta-block {
        padding: 8rem 2rem;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.2rem 3rem;
        background: var(--brand-green);
        color: var(--text-white);
        text-decoration: none;
        border-radius: 99px;
        font-weight: 700;
        font-size: 1rem;
        font-family: var(--font-primary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.4s var(--transition-premium);
    }

    .btn-cta:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.25);
    }

    .green-block .btn-cta {
        background: var(--brand-blue);
    }

    .green-block .btn-cta:hover {
        background: var(--text-white);
        color: var(--brand-green);
    }

    /* ═══ IMAGE BOXES ═══ */
    .img-box {
        border-radius: 1.5rem;
        overflow: hidden;
    }

    .img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s var(--transition-premium);
    }

    .img-box:hover img {
        transform: scale(1.05);
    }

    /* Tamaños */
    .img-box.side {
        width: 100%;
        height: 480px;
        border-radius: 2rem;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.2);
    }

    .img-box.side img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .img-box.card-img {
        width: 100%;
        height: 250px;
        margin-bottom: 2rem;
        border-radius: 1.5rem;
    }

    .img-box.diagram {
        width: 100%;
        min-height: 450px;
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
    }

    .img-box.diagram img {
        object-fit: contain;
        padding: 1rem;
    }

    .img-box.product-img {
        width: 100%;
        height: 180px;
        margin-bottom: 1rem;
        border-radius: 1.2rem;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 768px) {
        .story-block {
            padding: 4rem 1.5rem;
        }
        .two-col {
            grid-template-columns: 1fr;
        }
        .company-layout {
            grid-template-columns: 1fr;
        }
        .products {
            grid-template-columns: 1fr;
        }
        .side-layout {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 3rem;
        }
        .side-content {
            text-align: center;
        }
        .side-content .pills {
            justify-content: center;
        }
        .glass-card {
            padding: 2rem 1.5rem;
        }
        .accent-card {
            padding: 2.5rem 2rem;
            text-align: center;
            border-left: none;
            border-top: 5px solid var(--brand-green);
            border-radius: 0 0 2rem 2rem;
        }
        .cta-block {
            padding: 5rem 1.5rem;
        }
        .img-box.wide {
            height: 200px;
        }
        .img-box.diagram {
            min-height: 300px;
        }
        .img-box.card-img {
            height: 160px;
        }
        .img-box.product-img {
            height: 140px;
        }
    }
</style>

<script>
    // Intersection Observer - fade in al entrar, fade out al salir
    const revealElements = document.querySelectorAll("[data-reveal]");
    const revealChildren = document.querySelectorAll("[data-reveal-child]");

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("revealed");

                    // Stagger children
                    const children = entry.target.querySelectorAll(
                        "[data-reveal-child]",
                    );
                    children.forEach((child, i) => {
                        setTimeout(() => {
                            child.classList.add("revealed");
                        }, 150 * i);
                    });
                } else {
                    // Al salir del viewport, quitar clase para que re-animen al volver
                    entry.target.classList.remove("revealed");
                    const children = entry.target.querySelectorAll(
                        "[data-reveal-child]",
                    );
                    children.forEach((child) =>
                        child.classList.remove("revealed"),
                    );
                }
            });
        },
        {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px",
        },
    );

    revealElements.forEach((el) => observer.observe(el));
</script>
