    .status-error {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
</style>

<script>
    /* 
       Balik Scrollytelling Engine — Adapted Script
       Implementación original optimizada para el entorno Astro.
    */

    (function initEngine() {
        if (typeof window === "undefined") return;

        const canvas = document.getElementById(
            "webgl_canvas",
        ) as HTMLCanvasElement;
        const gl = canvas?.getContext("webgl", {
            alpha: false,
            antialias: false,
            depth: false,
            stencil: false,
            preserveDrawingBuffer: false,
            powerPreference: "high-performance",
        });

        if (!gl || !canvas) {
            if (canvas) canvas.style.background = "#0a0a0f";
            console.warn("WebGL not supported");
            return;
        }

        const vs = `attribute vec2 a; void main() { gl_Position = vec4(a, 0.0, 1.0); }`;
        const fs = `
            precision highp float;
            uniform vec2 uR;
            uniform float uT, uS, uSc, uBl;
            uniform vec3 uBg;

            #define PI 3.14159265359
            #define TA 6.28318530718
            #define MS 22
            #define RS 5

            float sat(float x) { return clamp(x, 0.0, 1.0); }
            float smoother(float x) { x = sat(x); return x * x * x * (x * (x * 6.0 - 15.0) + 10.0); }

            vec3 sCol(vec3 c0, vec3 c1, vec3 c2, vec3 c3, vec3 c4) {
                int si = int(uSc);
                vec3 a = c0; vec3 b = c1;
                if (si == 1) { a = c1; b = c2; }
                else if (si == 2) { a = c2; b = c3; }
                else if (si == 3) { a = c3; b = c4; }
                return mix(a, b, uBl);
            }

            float sF(float c0, float c1, float c2, float c3, float c4) {
                int si = int(uSc);
                float a = c0; float b = c1;
                if (si == 1) { a = c1; b = c2; }
                else if (si == 2) { a = c2; b = c3; }
                else if (si == 3) { a = c3; b = c4; }
                return mix(a, b, uBl);
            }

            mat2 rot(float a) { float c = cos(a), s = sin(a); return mat2(c, -s, s, c); }
            float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.545); }
            float noise(vec2 p) {
                vec2 i = floor(p); vec2 f = fract(p); f = f*f*(3.0-2.0*f);
                float a = hash(i), b = hash(i+vec2(1.0,0.0)), c = hash(i+vec2(0.0,1.0)), d = hash(i+vec2(1.0,1.0));
                return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
            }

            float waveH(vec2 p, float t, float amp, float storm) {
                float h = 0.0;
                vec2 s1 = normalize(vec2(1.0, 0.28)), s2 = normalize(vec2(-0.48, 0.88)), s3 = normalize(vec2(0.82, -0.16));
                s2 = rot(storm * 0.18) * s2; s3 = rot(-storm * 0.14) * s3;
                float d1 = dot(p, s1), d2 = dot(p, s2), d3 = dot(p, s3);
                h += amp * 0.66 * sin(d1 * 0.42 + t * 0.38);
                h += amp * 0.22 * sin(d1 * 0.94 - t * 0.62);
                h += amp * 0.14 * sin(d2 * 1.18 - t * 0.82);
                h += amp * 0.09 * sin(d3 * 1.82 + t * 1.04);
                h += amp * (0.11 + storm * 0.07) * sin(p.x * 1.45 - t * 0.76 + p.y * 0.66);
                float micro = noise(p * 14.0 + vec2(t * 0.18, t * 0.06)) - 0.5;
                h += micro * amp * (0.010 + storm * 0.008);
                return h;
            }

            vec3 waveNorm(vec2 p, float t, float amp, float storm) {
                float e = 0.018;
                float hL = waveH(p - vec2(e, 0.0), t, amp, storm), hR = waveH(p + vec2(e, 0.0), t, amp, storm);
                float hD = waveH(p - vec2(0.0, e), t, amp, storm), hU = waveH(p + vec2(0.0, e), t, amp, storm);
                return normalize(vec3(-(hR - hL), 2.0 * e, -(hU - hD)));
            }

            float stars(vec2 uv) {
                vec2 g = floor(uv), l = fract(uv)-0.5;
                float h = hash(g);
                return smoothstep(mix(0.012, 0.002, h), 0.0, length(l + (vec2(hash(g+3.1), hash(g+7.3))-0.5)*0.25)) * step(0.82, h);
            }

            void main() {
                vec2 uv = (gl_FragCoord.xy - uR * 0.5) / uR.y;
                float s = smoother(uS);
                float camY = mix(1.14, 1.03, s) + sin(s * PI * 1.4) * 0.028;
                float pitch = mix(0.115, 0.088, s);
                vec3 ro = vec3(0.0, camY, mix(0.08, -0.18, s)), rd = normalize(vec3(uv.x, uv.y - pitch, -1.4));

                float storm = smoothstep(0.8, 1.0, s), night = smoothstep(0.56, 0.84, s);
                vec3 skyT = sCol(vec3(0.50,0.70,1.00), vec3(0.18,0.06,0.24), vec3(0.26,0.06,0.04), vec3(0.01,0.01,0.05), vec3(0.04,0.05,0.09));
                vec3 skyH = sCol(vec3(0.95,0.98,1.00), vec3(0.92,0.48,0.18), vec3(0.88,0.32,0.04), vec3(0.03,0.05,0.14), vec3(0.15,0.17,0.23));
                vec3 sunC = sCol(vec3(1.00,1.00,1.00), vec3(1.0,0.62,0.22), vec3(1.0,0.38,0.05), vec3(0.70,0.75,0.94), vec3(0.26,0.28,0.34));
                vec3 seaD = sCol(vec3(0.00,0.12,0.45), vec3(0.08,0.05,0.12), vec3(0.10,0.06,0.04), vec3(0.00,0.01,0.03), vec3(0.03,0.04,0.07));
                vec3 seaS = sCol(vec3(0.08,0.35,0.80), vec3(0.28,0.17,0.24), vec3(0.24,0.13,0.06), vec3(0.04,0.06,0.16), vec3(0.07,0.10,0.14));
                vec3 fogC = sCol(vec3(0.90,0.95,1.00), vec3(0.80,0.50,0.30), vec3(0.70,0.28,0.05), vec3(0.02,0.03,0.08), vec3(0.12,0.14,0.18));

                vec3 sunDir = normalize(vec3(cos(clamp(s/0.58,0.0,1.0)*PI)*-0.75, sin(clamp(s/0.58,0.0,1.0)*PI)*0.38-0.08, -1.0));
                float waveA = sF(0.082, 0.070, 0.100, 0.054, 0.30) + storm * 0.02;
                float fogD = sF(0.020, 0.010, 0.022, 0.034, 0.046);
                
                vec3 col;
                if (rd.y < 0.0) {
                    float t = ro.y / (-rd.y), step = t / float(MS);
                    for (int i=0; i<MS; i++) { if (ro.y + rd.y*t < waveH(ro.xz+rd.xz*t, uT, waveA, storm)) break; t+=step; }
                    vec3 n = waveNorm(ro.xz+rd.xz*t, uT, waveA, storm);
                    float fres = pow(1.0-max(0.0, dot(n, -rd)), 4.0);
                    col = mix(mix(seaD, seaS, exp(-t*0.4)*0.5), mix(skyH, skyT, pow(max(0.0,reflect(rd,n).y),0.4)), 0.15+fres*0.34);
                    col = mix(col, fogC, 1.0-exp(-t*fogD*1.65));
                } else {
                    col = mix(skyH, skyT, pow(rd.y, 0.38));
                    float sd = max(0.0, dot(rd, sunDir));
                    col += sunC * (pow(sd, 380.0)*6.8 + pow(sd, 22.0)*0.2) * smoothstep(-0.1, 0.06, sunDir.y);
                    if (night > 0.02) col += vec3(0.8,0.9,1.0) * stars(rd.xy/max(0.1,rd.z+1.6)*140.0) * night * (1.0-storm*0.8);
                }
                gl_FragColor = vec4(col + (hash(gl_FragCoord.xy + floor(uT*12.0))-0.5)*0.006, 1.0);
            }
        `;

        const mkShader = (t: number, s: string) => {
            const sh = gl.createShader(t);
            if (!sh) return null;
            gl.shaderSource(sh, s);
            gl.compileShader(sh);
            return gl.getShaderParameter(sh, gl.COMPILE_STATUS)
                ? sh
                : (console.error(gl.getShaderInfoLog(sh)), null);
        };

        const prog = gl.createProgram();
        const vsh = mkShader(gl.VERTEX_SHADER, vs);
        const fsh = mkShader(gl.FRAGMENT_SHADER, fs);
        if (prog && vsh && fsh) {
            gl.attachShader(prog, vsh);
            gl.attachShader(prog, fsh);
            gl.linkProgram(prog);
            gl.useProgram(prog);
        }

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(
            gl.ARRAY_BUFFER,
            new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]),
            gl.STATIC_DRAW,
        );
        const ap = gl.getAttribLocation(prog!, "a");
        gl.enableVertexAttribArray(ap);
        gl.vertexAttribPointer(ap, 2, gl.FLOAT, false, 0, 0);

        const uR = gl.getUniformLocation(prog!, "uR"),
            uTi = gl.getUniformLocation(prog!, "uT");
        const uS = gl.getUniformLocation(prog!, "uS"),
            uSc = gl.getUniformLocation(prog!, "uSc"),
            uBl = gl.getUniformLocation(prog!, "uBl"),
            uBg = gl.getUniformLocation(prog!, "uBg");

        const updateBg = (theme: string) => {
            const hex = theme === "light" ? "#eef4ff" : "#0a0a0f";
            const n = parseInt(hex.replace("#", ""), 16);
            if (uBg)
                gl.uniform3f(
                    uBg,
                    ((n >> 16) & 255) / 255,
                    ((n >> 8) & 255) / 255,
                    (n & 255) / 255,
                );
        };

        let theme =
            document.documentElement.getAttribute("data-theme") || "dark";
        updateBg(theme);

        const themeToggle = document.getElementById("theme_toggle");
        themeToggle?.addEventListener("click", () => {
            theme = theme === "dark" ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", theme);
            updateBg(theme);
        });

        const resize = () => {
            const dpr = Math.min(window.devicePixelRatio, 1.5);
            canvas.width = window.innerWidth * dpr;
            canvas.height = window.innerHeight * dpr;
            gl.viewport(0, 0, canvas.width, canvas.height);
            if (uR) gl.uniform2f(uR, canvas.width, canvas.height);
        };
        window.addEventListener("resize", resize);
        resize();

        let tgt = 0,
            smooth = 0,
            velocity = 0;
        const scrollEase = 0.1,
            NAMES = ["MIDDAY", "DUSK", "NIGHT", "STORM"],
            N = NAMES.length;
        const progFill = document.getElementById("prog_fill"),
            hudPct = document.getElementById("hud_pct"),
            sceneName = document.getElementById("scene_name"),
            dots = document.querySelectorAll(".scene-dot");

        const updateScroll = () => {
            const bannerHeight = window.innerHeight; // The 100vh banner
            const sy = Math.max(0, window.scrollY - bannerHeight);
            const max =
                document.documentElement.scrollHeight -
                window.innerHeight -
                bannerHeight;
            tgt = max > 0 ? sy / max : 0;
        };
        window.addEventListener("scroll", updateScroll);

        // Scroll nativo habilitado. Se elimina el listener de 'wheel' con preventDefault.

        const frame = (now: number) => {
            // smooth += (tgt - smooth) * 0.1; // Se mantiene abajo en la lógica original

            smooth += (tgt - smooth) * 0.1;
            const raw = smooth * (N - 1),
                si = Math.min(Math.floor(raw), N - 2);

            if (progFill) progFill.style.width = `${Math.round(smooth * 100)}%`;
            if (hudPct)
                hudPct.textContent = `${Math.round(smooth * 100)}%`.padStart(
                    4,
                    "0",
                );
            if (sceneName)
                sceneName.textContent =
                    NAMES[Math.min(N - 1, Math.floor(smooth * N))];
            dots.forEach((d, i) =>
                d.classList.toggle(
                    "active",
                    i === Math.min(N - 1, Math.floor(smooth * N)),
                ),
            );

            gl.uniform1f(uTi, now * 0.001);
            gl.uniform1f(uS, smooth);
            gl.uniform1f(uSc, si);
            gl.uniform1f(uBl, raw - si);
            gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
            requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);

        const io = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) e.target.classList.add("visible");
                });
            },
            { threshold: 0 },
        );
        document
            .querySelectorAll(
                ".tag, h1, h2, .body-text, .stat-row, .cta, .h-line, [data-reveal]",
            )
            .forEach((el) => io.observe(el));

        // Formspree Logic for Balik
        const form = document.getElementById(
            "balik-contact-form",
        ) as HTMLFormElement;
        const status = document.getElementById("balik-form-status");
        const btn = document.getElementById(
            "balik-submit-btn",
        ) as HTMLButtonElement;

        if (form && status && btn) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                const formData = new FormData(form);

                btn.disabled = true;
                btn.innerHTML =
                    '<i class="fas fa-spinner fa-spin mr-2"></i> Enviando...';

                try {
                    const response = await fetch(form.action, {
                        method: form.method,
                        body: formData,
                        headers: {
                            Accept: "application/json",
                        },
                    });

                    if (response.ok) {
                        status.innerHTML =
                            "¡Gracias! Tu mensaje ha sido enviado con éxito 🎉";
                        status.classList.remove("hidden", "status-error");
                        status.classList.add("status-success");
                        form.reset();
                    } else {
                        const data = await response.json();
                        if (Object.hasOwn(data, "errors")) {
                            status.innerHTML = data["errors"]
                                .map((error: any) => error["message"])
                                .join(", ");
                        } else {
                            status.innerHTML =
                                "Hubo un problema al enviar el formulario.";
                        }
                        status.classList.remove("hidden", "status-success");
                        status.classList.add("status-error");
                    }
                } catch (error) {
                    status.innerHTML = "Error de conexión. Inténtalo de nuevo.";
                    status.classList.remove("hidden", "status-success");
                    status.classList.add("status-error");
                } finally {
                    btn.disabled = false;
                    btn.innerText = "Enviar Mensaje";
                }
            });
        }
    })();
</script>
