---
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="contacto"
  class="contact-section py-24 md:py-32 relative overflow-hidden bg-white"
>
  <!-- <section id="proyectos" class="projects-section py-32 relative overflow-hidden">
  <div class="custom-container"> -->
  <div class="custom-container">
    <div class="mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 xl:gap-24 items-start">
        <div class="contact-form-side" data-fade-in="up">
          <div class="mb-10 lg:text-left text-center">
            <h2
              class="text-4xl md:text-5xl font-extrabold text-[#111] mb-6 leading-[1.1]"
            >
              {
                lang === "es"
                  ? "Hablemos, cuéntanos tus metas"
                  : "Let's Chat, Reach Out to Us"
              }
            </h2>

            <form
              id="landing-contact-form"
              action="https://formspree.io/f/xkoplnrw"
              method="POST"
              class="space-y-6"
            >
              <div class="grid md:grid-cols-2 gap-6">
                <div class="form-group">
                  <label class="block text-sm font-bold text-gray-700 mb-2"
                    >{lang === "es" ? "Nombre" : "First Name"}</label
                  >
                  <input
                    type="text"
                    name="firstName"
                    required
                    placeholder={lang === "es" ? "Tu nombre" : "First name"}
                    class="w-full bg-[#F8F9FA] border border-gray-100 rounded-xl px-5 py-4 text-gray-800 focus:ring-2 focus:ring-brand-green/30 outline-none transition-all"
                  />
                </div>
                <div class="form-group">
                  <label class="block text-sm font-bold text-gray-700 mb-2"
                    >{lang === "es" ? "Apellido" : "Last Name"}</label
                  >
                  <input
                    type="text"
                    name="lastName"
                    required
                    placeholder={lang === "es" ? "Tu apellido" : "Last name"}
                    class="w-full bg-[#F8F9FA] border border-gray-100 rounded-xl px-5 py-4 text-gray-800 focus:ring-2 focus:ring-brand-green/30 outline-none transition-all"
                  />
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div class="form-group">
                  <label class="block text-sm font-bold text-gray-700 mb-2"
                    >{
                      lang === "es" ? "Correo Electrónico" : "Email Address"
                    }</label
                  >
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="email@address.com"
                    class="w-full bg-[#F8F9FA] border border-gray-100 rounded-xl px-5 py-4 text-gray-800 focus:ring-2 focus:ring-brand-green/30 outline-none transition-all"
                  />
                </div>
                <div class="form-group">
                  <label class="block text-sm font-bold text-gray-700 mb-2"
                    >{lang === "es" ? "Empresa" : "Company"}
                    <span class="text-xs text-gray-400 font-normal"
                      >({lang === "es" ? "Opcional" : "Optional"})</span
                    ></label
                  >
                  <input
                    type="text"
                    name="company"
                    placeholder={lang === "es"
                      ? "Nombre de tu empresa"
                      : "Your company name"}
                    class="w-full bg-[#F8F9FA] border border-gray-100 rounded-xl px-5 py-4 text-gray-800 focus:ring-2 focus:ring-brand-green/30 outline-none transition-all"
                  />
                </div>
                <div class="form-group pb-4 md:col-span-2">
                  <label class="block text-sm font-bold text-gray-700 mb-2"
                    >{lang === "es" ? "Mensaje" : "Message"}</label
                  >
                  <textarea
                    name="message"
                    required
                    placeholder={lang === "es"
                      ? "Déjanos un mensaje..."
                      : "Leave us a message..."}
                    class="w-full bg-[#F8F9FA] border border-gray-100 rounded-xl px-5 py-4 text-gray-800 focus:ring-2 focus:ring-brand-green/30 outline-none transition-all h-32 resize-none"
                  ></textarea>
                </div>
              </div>

              <div class="flex items-center gap-3 mb-8">
                <input
                  type="checkbox"
                  id="privacy-landing"
                  name="privacy"
                  required
                  class="w-5 h-5 rounded border-gray-300 text-brand-green focus:ring-brand-green"
                />
                <label
                  for="privacy-landing"
                  class="text-sm text-gray-500 font-medium cursor-pointer"
                >
                  {
                    lang === "es"
                      ? "Acepto las políticas de privacidad"
                      : "I agree to our friendly privacy policy"
                  }
                </label>
              </div>

              <button
                id="landing-submit-btn"
                type="submit"
                class="w-full bg-brand-green hover:opacity-80 text-black font-bold py-4 rounded-2xl shadow-xl shadow-brand-green/10 transition-all duration-300 transform hover:-translate-y-1"
              >
                {lang === "es" ? "Enviar Mensaje" : "Send Message"}
              </button>

              <div
                id="landing-form-status"
                class="hidden mt-4 p-4 rounded-xl text-center font-bold"
              >
              </div>
            </form>
          </div>

          <div
            class="contact-visual-side lg:sticky lg:top-32"
            data-fade-in="left"
          >
            <div
              class="bg-[#F8F9FA] rounded-[3.5rem] p-8 xl:p-12 border border-gray-100 flex flex-col gap-10"
            >
              <div class="relative group">
                <div
                  class="aspect-[4/3] rounded-[2.5rem] overflow-hidden bg-white shadow-brand-green/5 shadow-2xl transition-transform duration-700 group-hover:scale-[1.02]"
                >
                  <div
                    class="absolute inset-0 bg-gradient-to-br from-brand-green/5 to-transparent z-10"
                  >
                  </div>
                  <div
                    class="w-full h-full flex items-center justify-center p-12"
                  >
                    <img
                      src="/images/greenprod.png"
                      alt="Green Prod Logo"
                      class="max-w-full h-auto object-contain"
                    />
                  </div>
                </div>

                <div
                  class="absolute -top-6 -right-6 w-24 h-24 bg-brand-green/10 rounded-full blur-3xl opacity-50 animate-pulse"
                >
                </div>
              </div>

              <div class="space-y-6">
                <div
                  class="flex items-center gap-6 p-6 bg-white rounded-3xl shadow-sm border border-gray-50 transition-all hover:shadow-md"
                >
                  <div
                    class="min-w-[3.5rem] h-14 bg-brand-green/10 rounded-2xl flex items-center justify-center text-brand-green"
                  >
                    <i class="fas fa-envelope text-xl"></i>
                  </div>
                  <div class="overflow-hidden">
                    <p
                      class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1"
                    >
                      Email
                    </p>
                    <p
                      class="text-base sm:text-lg font-bold text-gray-800 break-all"
                    >
                      greenprodsustainable@gmail.com
                    </p>
                  </div>
                </div>

                <div
                  class="flex items-center gap-6 p-6 bg-white rounded-3xl shadow-sm border border-gray-50 transition-all hover:shadow-md"
                >
                  <div
                    class="min-w-[3.5rem] h-14 bg-brand-green/10 rounded-2xl flex items-center justify-center text-brand-green"
                  >
                    <i class="fas fa-phone-alt text-xl"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1"
                    >
                      {lang === "es" ? "Teléfono" : "Phone"}
                    </p>
                    <p class="text-lg font-bold text-gray-800">
                      +51 950 412 534
                    </p>
                  </div>
                </div>
              </div>

              <div class="pt-4">
                <p
                  class="text-center text-xs font-black text-gray-400 uppercase tracking-[0.2em] mb-8"
                >
                  Síguenos en Redes Sociales
                </p>
                <div class="flex justify-center flex-wrap gap-5">
                  {
                    [
                      {
                        icon: "fab fa-facebook-f",
                        color: "#1877F2",
                        name: "Facebook",
                      },
                      {
                        icon: "fab fa-instagram",
                        color: "#E4405F",
                        name: "Instagram",
                      },
                      {
                        icon: "fab fa-tiktok",
                        color: "#000000",
                        name: "TikTok",
                      },
                      {
                        icon: "fab fa-linkedin-in",
                        color: "#0A66C2",
                        name: "LinkedIn",
                      },
                      {
                        icon: "fab fa-whatsapp",
                        color: "#25D366",
                        name: "WhatsApp",
                      },
                    ].map((social) => (
                      <a
                        href="#"
                        class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group"
                        aria-label={social.name}
                      >
                        <i
                          class={`${social.icon} text-xl transition-colors duration-300`}
                          style={`color: ${social.color}`}
                        />
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        .contact-section {
          background-color: #ffffff;
        }

        [data-fade-in] {
          opacity: 0;
          transform: translateY(20px);
        }

        /* Status Styles */
        .status-success {
          background: #ecfdf5;
          color: #059669;
          border: 1px solid #10b981;
        }
        .status-error {
          background: #fef2f2;
          color: #dc2626;
          border: 1px solid #f87171;
        }
      </style>

      <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        window.addEventListener("load", () => {
          gsap.to("[data-fade-in]", {
            scrollTrigger: {
              trigger: ".contact-section",
              start: "top 80%",
            },
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out",
          });
        });

        const form = document.getElementById(
          "landing-contact-form",
        ) as HTMLFormElement;
        const status = document.getElementById("landing-form-status");
        const btn = document.getElementById(
          "landing-submit-btn",
        ) as HTMLButtonElement;

        if (form && status && btn) {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(form);

            btn.disabled = true;
            btn.innerHTML =
              '<i class="fas fa-spinner fa-spin mr-2"></i> Enviando...';

            try {
              const response = await fetch(form.action, {
                method: form.method,
                body: formData,
                headers: {
                  Accept: "application/json",
                },
              });

              if (response.ok) {
                status.innerHTML =
                  "¡Gracias! Tu mensaje ha sido enviado con éxito 🎉";
                status.classList.remove("hidden", "status-error");
                status.classList.add("status-success");
                form.reset();
              } else {
                const data = await response.json();
                if (Object.hasOwn(data, "errors")) {
                  status.innerHTML = data["errors"]
                    .map((error: any) => error["message"])
                    .join(", ");
                } else {
                  status.innerHTML =
                    "Vaya, hubo un problema al enviar el formulario.";
                }
                status.classList.remove("hidden", "status-success");
                status.classList.add("status-error");
              }
            } catch (error) {
              status.innerHTML =
                "Error de conexión. Inténtalo de nuevo más tarde.";
              status.classList.remove("hidden", "status-success");
              status.classList.add("status-error");
            } finally {
              btn.disabled = false;
              btn.innerText = "Enviar Mensaje";
            }
          });
        }
      </script>
    </div>
  </div>
</section>
