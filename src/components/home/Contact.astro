---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="contact-section py-32 relative overflow-hidden">
  <div class="custom-container">
    <div class="grid lg:grid-cols-2 gap-20">
      <div id="contactInfo" class="contact-info">
        <div class="section-badge mb-6">
          <span
            class="text-green-light font-bold tracking-widest text-xs uppercase"
            >05 / {t("nav.contact")}</span
          >
        </div>
        <h2
          class="text-5xl lg:text-7xl font-extrabold text-primary mb-8 leading-tight"
        >
          {
            lang === "es"
              ? "Construyamos el futuro hoy."
              : "Let's build the future today."
          }
        </h2>
        <p class="text-xl text-secondary mb-12 max-w-md">
          {
            lang === "es"
              ? "Estamos listos para guiar tu transición hacia la sostenibilidad industrial."
              : "We are ready to guide your transition towards industrial sustainability."
          }
        </p>

        <div class="contact-methods space-y-8">
          <div class="method flex items-center gap-6 group cursor-pointer">
            <div
              class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl group-hover:bg-green-light group-hover:text-white transition-all"
            >
              📧
            </div>
            <div>
              <p
                class="text-xs text-secondary uppercase font-bold tracking-widest"
              >
                Email
              </p>
              <p class="text-xl text-primary font-bold">
                contacto@greenprod.eco
              </p>
            </div>
          </div>
          <div class="method flex items-center gap-6 group cursor-pointer">
            <div
              class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl group-hover:bg-green-light group-hover:text-white transition-all"
            >
              💬
            </div>
            <div>
              <p
                class="text-xs text-secondary uppercase font-bold tracking-widest"
              >
                WhatsApp
              </p>
              <p class="text-xl text-primary font-bold">+34 600 000 000</p>
            </div>
          </div>
        </div>
      </div>

      <div id="contactForm" class="contact-form-container relative">
        <form class="glass p-10 lg:p-14 rounded-[3rem] space-y-8 relative z-10">
          <div class="grid md:grid-cols-2 gap-8">
            <div class="form-group">
              <label
                class="block text-xs uppercase font-black text-secondary tracking-widest mb-3"
                >{lang === "es" ? "Nombre" : "Name"}</label
              >
              <input
                type="text"
                placeholder="Nombre Completo"
                class="w-full bg-white/5 border border-border rounded-2xl px-6 py-4 text-primary focus:outline-none focus:border-green-light transition-colors"
                id="name"
              />
            </div>
            <div class="form-group">
              <label
                class="block text-xs uppercase font-black text-secondary tracking-widest mb-3"
                >Email</label
              >
              <input
                type="email"
                placeholder="ejemplo@empresa.com"
                class="w-full bg-white/5 border border-border rounded-2xl px-6 py-4 text-primary focus:outline-none focus:border-green-light transition-colors"
                id="email"
              />
            </div>
          </div>

          <div class="form-group">
            <label
              class="block text-xs uppercase font-black text-secondary tracking-widest mb-3"
              >{lang === "es" ? "Empresa" : "Company"}</label
            >
            <input
              type="text"
              placeholder="Nombre de tu empresa"
              class="w-full bg-white/5 border border-border rounded-2xl px-6 py-4 text-primary focus:outline-none focus:border-green-light transition-colors"
              id="company"
            />
          </div>

          <div class="form-group">
            <label
              class="block text-xs uppercase font-black text-secondary tracking-widest mb-3"
              >{lang === "es" ? "Mensaje" : "Message"}</label
            >
            <textarea
              placeholder={lang === "es"
                ? "Cuéntanos sobre tu proyecto..."
                : "Tell us about your project..."}
              class="w-full bg-white/5 border border-border rounded-2xl px-6 py-4 text-primary focus:outline-none focus:border-green-light transition-colors h-32"
              id="message"></textarea>
          </div>

          <button
            type="submit"
            class="btn-premium w-full justify-center text-lg py-5"
          >
            {lang === "es" ? "Enviar Mensaje" : "Send Message"}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--bg-main);
  }
  .border {
    border-color: var(--border-color);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from("#contactInfo", {
    scrollTrigger: {
      trigger: "#contacto",
      start: "top 70%",
    },
    y: 30,
    duration: 1,
  });

  gsap.from("#contactForm", {
    scrollTrigger: {
      trigger: "#contacto",
      start: "top 70%",
    },
    scale: 0.95,
    duration: 1.2,
    delay: 0.2,
  });
</script>
