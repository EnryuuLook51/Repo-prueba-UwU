---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="footer-section pt-24 pb-12 relative overflow-hidden">
  <div class="custom-container">
    <div class="grid lg:grid-cols-4 gap-12 border-b border-white/10 pb-20">
      <div class="lg:col-span-2">
        <div class="logo-footer mb-8">
          <img
            src="/images/greenprod.png"
            alt="GreenProd Logo"
            class="h-12 w-auto brightness-0 invert"
          />
        </div>
        <p class="text-white/70 text-lg max-w-md leading-relaxed font-light">
          {t("footer.tagline")}
        </p>
      </div>

      <div>
        <h4 class="text-white font-bold uppercase tracking-widest text-xs mb-8">
          Navegación
        </h4>
        <ul class="space-y-4">
          <li>
            <a
              href="#about"
              class="text-white/60 hover:text-brand-green transition-colors"
              >{t("nav.about")}</a
            >
          </li>
          <li>
            <a
              href="#lineas-negocio"
              class="text-white/60 hover:text-brand-green transition-colors"
              >{t("nav.services")}</a
            >
          </li>
          <li>
            <a
              href="#actividades"
              class="text-white/60 hover:text-brand-green transition-colors"
              >{t("nav.activities")}</a
            >
          </li>
          <li>
            <a
              href="#proyectos"
              class="text-white/60 hover:text-brand-green transition-colors"
              >{t("nav.projects")}</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold uppercase tracking-widest text-xs mb-8">
          Contacto
        </h4>
        <ul class="space-y-4">
          <li>
            <a
              href="https://linkedin.com"
              target="_blank"
              class="text-white/60 hover:text-brand-green transition-colors flex items-center gap-2"
            >
              <i class="fab fa-linkedin text-lg"></i>
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="mailto:info@greenprod.eco"
              class="text-white/60 hover:text-brand-green transition-colors"
            >
              info@greenprod.eco
            </a>
          </li>
          <li>
            <span class="text-white/60"> +34 600 000 000 </span>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="footer-bottom mt-12 flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <p class="text-white/30 text-sm italic">
        Hecho con 🌿 para un futuro mejor
      </p>
      <p class="text-white/30 text-sm">
        &copy; 2026 Green Prod & Sustainable. Todos los derechos reservados.
      </p>
    </div>
  </div>

  {/* Background accents */}
  <div
    class="absolute -bottom-20 -right-20 w-96 h-96 bg-brand-green/10 rounded-full blur-[1000px]"
  >
  </div>
  <div
    class="absolute -top-20 -left-20 w-96 h-96 bg-white/5 rounded-full blur-[1000px]"
  >
  </div>
</footer>

<style>
  .footer-section {
    background: var(--brand-blue); /* Solid company blue */
    color: white;
  }
</style>
