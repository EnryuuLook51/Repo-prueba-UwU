---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="actividades"
  class="activities-section py-32 relative overflow-hidden"
>
  <div class="custom-container">
    <!-- LEFT ALIGNMENT -->
    <div class="section-header mb-24 text-left" id="activitiesHeader">
      <div class="section-badge mb-6">
        <span
          class="text-brand-green font-bold tracking-widest text-xs uppercase"
          >03 / {t("nav.activities")}</span
        >
      </div>
      <h2 class="text-5xl lg:text-7xl font-black text-primary mb-6">
        Nuestra <span class="text-brand-green">Acción</span> en el <span
          class="text-brand-blue">Campo</span
        >
      </h2>
      <p class="text-secondary max-w-2xl text-lg leading-relaxed font-light">
        Más que consultores, somos socios operativos en la ejecución de
        actividades que garantizan un impacto sostenible real y duradero.
      </p>
    </div>

    <div
      class="activities-grid grid md:grid-cols-2 lg:grid-cols-3 gap-10"
      id="activitiesContainer"
    >
      {
        [
          {
            id: "01",
            title: "Auditorías de Impacto",
            desc: "Evaluamos exhaustivamente el cumplimiento de los estándares ESG.",
          },
          {
            id: "02",
            title: "Monitoreo en Tiempo Real",
            desc: "Sistemas de seguimiento para el consumo energético y huella de carbono.",
          },
          {
            id: "03",
            title: "Gestión de Residuos",
            desc: "Ejecución de programas de economía circular industrial de manera eficiente.",
          },
          {
            id: "04",
            title: "Talleres de Transformación",
            desc: "Formación de equipos operativos para adoptar culturas sostenibles.",
          },
          {
            id: "05",
            title: "Diseño de Roadmap",
            desc: "Planificación estratégica a largo plazo para la transición energética.",
          },
          {
            id: "06",
            title: "Optimización Logística",
            desc: "Ingeniería para reducir la huella de transporte y cadena de suministro.",
          },
        ].map((act) => (
          <div class="activity-box glass p-10 flex flex-col items-start transition-all duration-500 hover:border-brand-green/30">
            <div class="activity-number text-brand-green/10 text-6xl font-black mb-6">
              {act.id}
            </div>
            <h3 class="text-2xl font-bold text-primary mb-4">{act.title}</h3>
            <p class="text-secondary text-sm leading-relaxed opacity-80">
              {act.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .activities-section {
    background: var(--bg-main);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from("#activitiesHeader", {
    scrollTrigger: {
      trigger: "#actividades",
      start: "top 85%",
    },
    x: -100,
    duration: 1.5,
    ease: "power4.out",
  });

  gsap.from(".activity-box", {
    scrollTrigger: {
      trigger: "#activitiesContainer",
      start: "top 80%",
    },
    y: 50,
    stagger: 0.1,
    duration: 1.2,
    ease: "power2.out",
  });
</script>
