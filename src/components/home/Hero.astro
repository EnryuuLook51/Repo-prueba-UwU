---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero-section" id="hero">
  <div class="custom-container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-badge-top" id="heroBadgeTop" data-fade-in="down">
          <span>{t("hero.subtitle")}</span>
        </div>

        <h1 class="hero-title" id="heroTitle">
          {
            lang === "es" ? (
              <span class="title-main">
                Hola, somos{" "}
                <span class="text-brand-green split-target">Green Prod</span> &{" "}
                <span class="text-brand-blue split-target">Sustainable.</span>
              </span>
            ) : (
              <span class="title-main">
                Hi, we are{" "}
                <span class="text-brand-green split-target">Green Prod</span> &{" "}
                <span class="text-brand-blue split-target">Sustainable.</span>
              </span>
            )
          }
        </h1>

        <p class="hero-description" id="heroDesc" data-fade-in="up">
          {t("hero.description")}
        </p>

        <div class="hero-actions" id="heroActions" data-fade-in="up">
          <div class="hero-cta">
            <a href="#contacto" class="btn-premium">
              {t("nav.consultation")}
              <i class="fas fa-arrow-right ms-2 transition-transform"></i>
            </a>
          </div>
          <div class="hero-secondary-cta pt-4 md:pt-0">
            <span class="text-xs text-secondary/60 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-brand-green animate-pulse"
              ></span>
              Disponibilidad inmediata para nuevos proyectos
            </span>
          </div>
        </div>
      </div>

      <div class="hero-visual" id="heroVisual" data-fade-in="left">
        <div class="visual-container">
          <div class="main-image-wrapper glass">
            <img
              src="/images/agricultores_trabajando_202603251507.jpeg"
              alt="Sustainability"
              class="main-image"
              id="heroMainImg"
            />
            <div class="image-overlay"></div>
          </div>

          <!-- Floating Badges with added Mouse-Parallax class -->
          <div
            class="impact-badge badge-1 glass mouse-parallax"
            data-speed="0.05"
          >
            <div class="badge-icon">🌿</div>
            <div class="badge-text">
              <strong>-25k Tons</strong>
              <span>CO2 Compensado</span>
            </div>
          </div>

          <div
            class="impact-badge badge-2 glass mouse-parallax"
            data-speed="-0.03"
          >
            <div class="badge-icon">✅</div>
            <div class="badge-text">
              <strong>+50 Proyectos</strong>
              <span>Impacto Verificado</span>
            </div>
          </div>

          <div
            class="impact-badge badge-3 glass mouse-parallax"
            data-speed="0.04"
          >
            <div class="badge-icon">☀️</div>
            <div class="badge-text">
              <strong>100%</strong>
              <span>Energía Limpia</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator" id="scrollIndicator">
    <div class="mouse">
      <div class="wheel"></div>
    </div>
    <span class="scroll-text">Scrollear</span>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 10rem 0 6rem;
    background: var(--bg-main);
    overflow: hidden;
    position: relative;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badge-top {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    background: var(--border-color);
    border: 1px solid var(--border-color);
    border-radius: 100px;
    color: var(--brand-green);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2.5rem;
    opacity: 1;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 5.2rem);
    font-weight: 950;
    line-height: 1.05;
    margin-bottom: 2rem;
    letter-spacing: -0.04em;
    opacity: 1;
    visibility: visible;
  }

  .title-main {
    display: block;
  }

  :global(.word-wrapper) {
    display: inline-block;
    white-space: nowrap;
    margin-right: 0.25em;
  }

  :global(.split-char) {
    display: inline-block;
    opacity: 1;
    transform: translateX(0);
  }

  .hero-description {
    font-size: 1.35rem;
    color: var(--text-secondary);
    max-width: 580px;
    line-height: 1.6;
    margin-bottom: 3rem;
    opacity: 1;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 1;
  }

  .btn-premium:hover i {
    transform: translateX(5px);
  }

  .visual-container {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
  }

  .main-image-wrapper {
    position: relative;
    border-radius: 3rem;
    overflow: hidden;
    aspect-ratio: 4/5;
    box-shadow: 0 50px 100px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--border-color);
    transition: transform 0.5s var(--transition-premium);
  }

  .main-image-wrapper:hover {
    transform: scale(1.02);
  }

  .main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.2);
  }

  .impact-badge {
    position: absolute;
    padding: 1.2rem 1.8rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    z-index: 10;
    cursor: default;
    /* Removed translate transition to avoid conflicts with JS Parallax */
  }

  .badge-icon {
    font-size: 1.5rem;
    width: 3.5rem;
    height: 3.5rem;
    background: var(--brand-green);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1.2rem;
    box-shadow: 0 10px 20px rgba(108, 190, 79, 0.2);
  }

  .badge-1 {
    top: 10%;
    left: -15%;
  }
  .badge-2 {
    bottom: 10%;
    left: -15%;
  }
  .badge-3 {
    top: 50%;
    right: -15%;
  }

  /* Scroll Indicator Styles */
  .scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    transition: opacity 0.3s ease;
  }

  .mouse {
    width: 25px;
    height: 42px;
    border: 2px solid var(--text-secondary);
    border-radius: 20px;
    position: relative;
  }

  .wheel {
    width: 3px;
    height: 6px;
    background: var(--brand-green);
    border-radius: 2px;
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll-wheel 1.5s infinite;
  }

  .scroll-text {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-secondary);
  }

  @keyframes scroll-wheel {
    0% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, 15px);
    }
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 6rem;
    }
    .hero-description {
      margin: 0 auto 3rem;
    }
    .hero-actions {
      align-items: center;
    }
    .badge-1,
    .badge-2,
    .badge-3 {
      display: none;
    }
    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  function splitIntoWordsAndChars(node: Node) {
    const text = node.textContent || "";
    const words = text.split(" ").filter((w: string) => w !== "");
    const fragment = document.createDocumentFragment();

    words.forEach((word: string) => {
      const wordSpan = document.createElement("span");
      wordSpan.className = "word-wrapper";
      word.split("").forEach((char: string) => {
        const charSpan = document.createElement("span");
        charSpan.className = "split-char";
        charSpan.innerText = char;
        wordSpan.appendChild(charSpan);
      });
      fragment.appendChild(wordSpan);
    });
    (node as Element).replaceWith(fragment);
  }

  function splitTextPro(el: HTMLElement) {
    const childNodes = Array.from(el.childNodes);
    childNodes.forEach((node: Node) => {
      if (node.nodeType === 3) splitIntoWordsAndChars(node);
      else if (
        (node as Element).classList &&
        (node as Element).classList.contains("split-target")
      )
        splitIntoWordsAndChars(node);
    });
    return el.querySelectorAll(".split-char");
  }

  window.addEventListener("load", () => {
    const heroTl = gsap.timeline({ delay: 0 });
    const titleEl = document.getElementById("heroTitle");
    const chars = splitTextPro(titleEl);

    heroTl
      .to(chars, {
        x: 0,
        opacity: 1,
        ease: "power2.inOut",
        stagger: { each: 0.012, from: "random" },
        duration: 0.6,
      })
      .from(
        "[data-fade-in]",
        {
          y: (i, el) =>
            el.dataset.fadeIn === "up"
              ? 40
              : el.dataset.fadeIn === "down"
                ? -40
                : 0,
          x: (i, el) => (el.dataset.fadeIn === "left" ? 80 : 0),
          duration: 1.25,
          ease: "power4.inOut",
          stagger: 0.08,
        },
        "-=0.3",
      )
      .to(
        "#heroMainImg",
        {
          scale: 1,
          duration: 2,
          ease: "power2.out",
        },
        "-=1.5",
      );

    // NEW: Mouse Parallax Effect for UX
    window.addEventListener("mousemove", (e) => {
      const { clientX, clientY } = e;
      const xPos = clientX / window.innerWidth - 0.5;
      const yPos = clientY / window.innerHeight - 0.5;

      gsap.to(".mouse-parallax", {
        x: (i, el) => xPos * 100 * parseFloat(el.dataset.speed),
        y: (i, el) => yPos * 100 * parseFloat(el.dataset.speed),
        duration: 1.5,
        ease: "power2.out",
        overwrite: "auto",
      });
    });

    // Wave animation
    const brandChars = document.querySelectorAll(".split-target .split-char");
    if (brandChars.length > 0) {
      gsap.to(brandChars, {
        y: -15,
        duration: 0.6,
        ease: "sine.inOut",
        stagger: { each: 0.04, from: "start", repeat: -1, yoyo: true },
        repeat: -1,
        repeatDelay: 4,
        yoyo: true,
      });
    }

    // Hide scroll indicator on scroll
    window.addEventListener("scroll", () => {
      const indicator = document.getElementById("scrollIndicator");
      if (window.scrollY > 200) {
        gsap.to(indicator, { opacity: 0, duration: 0.3 });
      } else {
        gsap.to(indicator, { opacity: 1, duration: 0.3 });
      }
    });
  });
</script>
