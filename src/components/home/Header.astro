---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname.replace(/^\/(en)?/, "") || "/";
---

<header class="main-header" id="header">
  <nav class="nav-container">
    <div class="nav-brand">
      <a href="#hero" class="nav-brand-link">
        <img
          src="/images/greenprod.png"
          alt="GreenProd Logo"
          class="nav-icon-img"
        />
      </a>
    </div>

    <div class="nav-menu" id="navMenu">
      <a href="#about" class="nav-link" data-section="about">
        <i class="fas fa-industry text-brand-blue"></i>
        <span class="nav-text">{t("nav.about")}</span>
      </a>
      <a href="#lineas-negocio" class="nav-link" data-section="skills">
        <i class="fas fa-leaf text-brand-green"></i>
        <span class="nav-text">{t("nav.services")}</span>
      </a>
      <a href="#actividades" class="nav-link" data-section="experience">
        <i class="fas fa-chart-line text-brand-blue"></i>
        <span class="nav-text">{t("nav.activities")}</span>
      </a>
      <a href="#proyectos" class="nav-link" data-section="projects">
        <i class="fas fa-award text-brand-green"></i>
        <span class="nav-text">{t("nav.projects")}</span>
      </a>
      <a href="#contacto" class="nav-link nav-link-btn" data-section="contact">
        <i class="fas fa-paper-plane"></i>
        <span class="nav-text">{t("nav.contact")}</span>
      </a>
    </div>

    <div class="nav-controls">
      <a
        href={lang === "es" ? `/en${currentPath}` : currentPath}
        class="lang-toggle"
        id="langToggle"
      >
        <i class="fas fa-language"></i>
        <span class="lang-text">{lang === "es" ? "EN" : "ES"}</span>
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Toggle Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 1.5rem 0;
    background: transparent;
  }

  .nav-container {
    max-width: 1550px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 4.5rem;
  }

  .nav-brand {
    flex: 1;
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .nav-brand-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .nav-icon-img {
    height: 3.2rem;
    width: auto;
    object-fit: contain;
  }

  .nav-menu {
    flex: 0 1 auto;
    display: flex;
    align-items: center;
    gap: 2.2rem;
    justify-content: center;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.75;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, #2374b9, #6cbe4f);
    transition: width 0.3s ease;
  }

  .nav-link:not(.nav-link-btn):hover::after,
  .nav-link.active:not(.nav-link-btn)::after {
    width: 100%;
  }

  .nav-link:hover,
  .nav-link.active {
    opacity: 1;
  }

  .nav-link-btn {
    background: var(--brand-green);
    color: white !important;
    padding: 0.65rem 1.5rem;
    border-radius: 100px;
    opacity: 1 !important;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 12px rgba(108, 190, 79, 0.2);
  }

  .nav-link-btn i {
    color: white !important;
  }

  .nav-link-btn:hover {
    background: var(--brand-blue);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(35, 116, 185, 0.3);
  }

  .nav-controls {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    transition: all 0.25s ease;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 800;
  }

  .lang-toggle:hover {
    background: rgba(129, 195, 100, 0.1);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 25px;
    height: 2px;
    background: var(--text-primary);
  }

  /* SCROLL STATE */
  .scrolled {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-color);
    padding: 0.6rem 0;
  }

  .scrolled .nav-container {
    height: 4rem;
  }
  .scrolled .nav-icon-img {
    height: 2.6rem;
  }

  @media (max-width: 1024px) {
    .nav-menu {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById("header");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  // Toggle mobile menu logic could be added here
</script>
