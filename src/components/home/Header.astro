---
import { getLangFromUrl, useTranslations, ui } from "../../i18n/utils";
import Navbar from "../common/Navbar";

const lang = getLangFromUrl(Astro.url);
const curLang = lang as "es" | "en";

// Safely merge translations with fallbacks
const translations = {
  ...ui["es"], // Using 'es' as safe fallback
  ...ui[curLang],
};
---

<Navbar client:only="react" lang={curLang} t={translations} />

<style is:global>
  /* Ensure the body has padding top if needed, 
     but since it's transparent/fixed it's handled in the component. */
</style>
