---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefixPath = (path: string) => {
  if (lang === "es") return path;
  return `/${lang}${path}`;
};
---

<Layout title={`${t("contact.badge")} | Green Prod & Sustainable`}>
  <section class="contact-page py-20 lg:py-28 min-h-screen">
    <div class="custom-container">
      <div class="text-center mb-12">
        <span
          class="inline-flex items-center gap-2 text-[#2374b9] font-semibold tracking-widest text-xs uppercase mb-4 px-4 py-2 bg-[#2374b9]/10 rounded-full"
        >
          <span class="w-2 h-2 bg-[#2374b9] rounded-full animate-pulse"></span>
          {t("contact.badge")}
        </span>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 mb-4">
          {t("contact.title")}
        </h1>
        <p class="text-lg text-slate-600 max-w-xl mx-auto">
          {t("contact.description")}
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 xl:gap-16 max-w-6xl mx-auto">
        <!-- Formulario -->
        <div
          class="bg-white rounded-3xl p-8 lg:p-10 shadow-xl border border-slate-100"
        >
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-slate-700 mb-2"
                  >{t("contact.form.name")}</label
                >
                <input
                  type="text"
                  placeholder={t("contact.form.name")}
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-800 focus:ring-2 focus:ring-[#6cbe4f]/30 focus:border-[#6cbe4f] outline-none transition-all"
                />
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-700 mb-2"
                  >{t("contact.form.lastname")}</label
                >
                <input
                  type="text"
                  placeholder={t("contact.form.lastname")}
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-800 focus:ring-2 focus:ring-[#6cbe4f]/30 focus:border-[#6cbe4f] outline-none transition-all"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-slate-700 mb-2"
                  >{t("contact.form.email")}</label
                >
                <input
                  type="email"
                  placeholder="email@address.com"
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-800 focus:ring-2 focus:ring-[#6cbe4f]/30 focus:border-[#6cbe4f] outline-none transition-all"
                />
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">
                  {t("contact.form.company")}
                  <span class="text-xs text-slate-400 font-normal"
                    >{t("contact.form.optional")}</span
                  >
                </label>
                <input
                  type="text"
                  placeholder={t("contact.form.company")}
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-800 focus:ring-2 focus:ring-[#6cbe4f]/30 focus:border-[#6cbe4f] outline-none transition-all"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2"
                >{t("contact.form.message")}</label
              >
              <textarea
                placeholder="Cuéntanos..."
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-800 focus:ring-2 focus:ring-[#6cbe4f]/30 focus:border-[#6cbe4f] outline-none transition-all h-40 resize-none"
              ></textarea>
            </div>

            <div class="flex items-center gap-3">
              <input
                type="checkbox"
                id="privacy"
                class="w-5 h-5 rounded border-slate-300 text-[#6cbe4f] focus:ring-[#6cbe4f]"
              />
              <label
                for="privacy"
                class="text-sm text-slate-500 font-medium cursor-pointer"
              >
                {t("contact.form.privacy")}
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-[#6cbe4f] hover:bg-[#5ab33f] text-white font-bold py-4 rounded-2xl shadow-lg shadow-[#6cbe4f]/20 transition-all duration-300 transform hover:-translate-y-1"
            >
              {t("contact.form.send")}
            </button>
          </form>
        </div>

        <!-- Info de contacto -->
        <div class="space-y-6">
          <!-- Logo card -->
          <div
            class="bg-slate-50 rounded-3xl p-8 text-center border border-slate-100"
          >
            <img
              src="/images/greenprod.png"
              alt="Green Prod Logo"
              class="max-w-[200px] mx-auto mb-6"
            />
            <p class="text-slate-600 text-sm">
              Conectando el mar con el campo para un futuro orgánico
            </p>
          </div>

          <!-- Contact info -->
          <div
            class="bg-white rounded-3xl p-8 shadow-lg border border-slate-100 space-y-4"
          >
            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl">
              <div
                class="w-12 h-12 bg-[#6cbe4f]/10 rounded-xl flex items-center justify-center text-[#6cbe4f]"
              >
                <i class="fas fa-envelope text-xl"></i>
              </div>
              <div>
                <p
                  class="text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Email
                </p>
                <a
                  href="mailto:greenprodsustainable@gmail.com"
                  class="text-base font-bold text-slate-800 hover:text-[#6cbe4f] transition-colors"
                >
                  greenprodsustainable@gmail.com
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl">
              <div
                class="w-12 h-12 bg-[#6cbe4f]/10 rounded-xl flex items-center justify-center text-[#6cbe4f]"
              >
                <i class="fas fa-phone-alt text-xl"></i>
              </div>
              <div>
                <p
                  class="text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Teléfono
                </p>
                <a
                  href="tel:+51950412534"
                  class="text-lg font-bold text-slate-800 hover:text-[#6cbe4f] transition-colors"
                >
                  +51 950 412 534
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl">
              <div
                class="w-12 h-12 bg-[#2374b9]/10 rounded-xl flex items-center justify-center text-[#2374b9]"
              >
                <i class="fab fa-whatsapp text-xl"></i>
              </div>
              <div>
                <p
                  class="text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  WhatsApp
                </p>
                <a
                  href="https://wa.me/51950412534"
                  target="_blank"
                  class="text-lg font-bold text-slate-800 hover:text-[#2374b9] transition-colors"
                >
                  +51 950 412 534
                </a>
              </div>
            </div>
          </div>

          <!-- Redes sociales -->
          <div
            class="bg-white rounded-3xl p-8 shadow-lg border border-slate-100"
          >
            <p
              class="text-center text-xs font-bold text-slate-400 uppercase tracking-widest mb-6"
            >
              {t("contact.follow_us")}
            </p>
            <div class="flex justify-center gap-4">
              <a
                href="#"
                class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-[#1877F2] hover:bg-[#1877F2] hover:text-white transition-all hover:-translate-y-1 shadow"
                aria-label="Facebook"
              >
                <i class="fab fa-facebook-f text-lg"></i>
              </a>
              <a
                href="#"
                class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-[#E4405F] hover:bg-gradient-to-br hover:from-[#f09433] hover:to-[#e6683c] hover:text-white transition-all hover:-translate-y-1 shadow"
                aria-label="Instagram"
              >
                <i class="fab fa-instagram text-lg"></i>
              </a>
              <a
                href="#"
                class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-slate-800 hover:bg-black hover:text-white transition-all hover:-translate-y-1 shadow"
                aria-label="TikTok"
              >
                <i class="fab fa-tiktok text-lg"></i>
              </a>
              <a
                href="https://linkedin.com"
                target="_blank"
                class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-[#0A66C2] hover:bg-[#0A66C2] hover:text-white transition-all hover:-translate-y-1 shadow"
                aria-label="LinkedIn"
              >
                <i class="fab fa-linkedin-in text-lg"></i>
              </a>
              <a
                href="https://wa.me/51950412534"
                target="_blank"
                class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-[#25D366] hover:bg-[#25D366] hover:text-white transition-all hover:-translate-y-1 shadow"
                aria-label="WhatsApp"
              >
                <i class="fab fa-whatsapp text-lg"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-page {
    background: linear-gradient(180deg, var(--bg-main, #f8fafc) 0%, white 100%);
  }
</style>
