---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Balik | Green Prod & Sustainable";
---

<Layout title={title}>
    <section class="line-hero">
        <div class="custom-container">
            <span class="badge" data-reveal>{t("nav.services")}</span>
            <h1 class="font-heading" data-reveal>{t("navbar.balik")}</h1>
            <p class="description" data-reveal>{t("navbar.balik_desc")}</p>

            <div class="cta-wrapper" data-reveal>
                <a
                    href="/lineas-de-negocio/balik/productos"
                    class="cta-button primary"
                >
                    Ver Productos
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        class="arrow"
                    >
                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <section class="line-content">
        <div class="custom-container">
            <div class="info-grid">
                <div class="info-text" data-reveal>
                    <h2 class="font-heading">
                        Soluciones de Ingeniería Biológica
                    </h2>
                    <p class="font-body">
                        En Balik, nos enfocamos en el desarrollo de
                        infraestructura y procesos que garantizan la máxima
                        calidad en el tratamiento de recursos marinos, siguiendo
                        estándares ESG internacionales.
                    </p>
                </div>
                <div class="info-image" data-reveal>
                    <!-- Placeholder para imagen representativa -->
                    <div class="image-mockup"></div>
                </div>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    .line-hero {
        padding: 12rem 0 6rem;
        background: var(--brand-blue);
        color: white;
    }

    .badge {
        display: inline-block;
        padding: 0.5rem 1.2rem;
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
    }

    h1 {
        font-size: clamp(3.5rem, 8vw, 6rem);
        line-height: 1;
        margin-bottom: 2rem;
    }

    .description {
        font-family: var(--font-secondary);
        font-size: 1.25rem;
        max-width: 600px;
        opacity: 0.9;
        margin-bottom: 3rem;
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem 2.5rem;
        background: white;
        color: var(--brand-blue);
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .cta-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        gap: 1.5rem;
    }

    .arrow {
        width: 1.2rem;
        height: 1.2rem;
    }

    .line-content {
        padding: 8rem 0;
        background: white;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .image-mockup {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: var(--bg-card);
        border-radius: 2rem;
    }

    [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("revealed");
                }
            });
        },
        { threshold: 0.1 },
    );

    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
</script>
