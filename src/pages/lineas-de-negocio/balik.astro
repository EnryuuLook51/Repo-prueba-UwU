---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import BalikExperience from "../../components/pages/balik/BalikExperience.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Balik | Green Prod & Sustainable";
---

<Layout title={title}>
    <!-- Balik Static Hero Banner -->
    <section class="balik-static-banner">
        <div class="banner-content">
            <div class="banner-logo-wrapper" data-reveal>
                <img
                    src="/images/lineas/balik/hero/LOGOBALIK.png"
                    alt="Balik Logo"
                    class="banner-logo"
                />
            </div>

            <div class="banner-card" data-reveal>
                <p>
                    Ofrecemos productos marinos completamente limpios y
                    sanitizados, conservados en cadena de frío para garantizar
                    frescura, seguridad e inocuidad en cada entrega.
                    <br /><br />
                    Contamos con una línea especializada de conservas (premium y comercial)
                    que mantienen la esencia del mar peruano y su valor nutricional.
                </p>
                <div class="banner-cta-group">
                    <a
                        href="/lineas-de-negocio/balik/productos"
                        class="banner-cta">Ver Catálogo Completo</a
                    >
                </div>
            </div>
        </div>

        <!-- Background Asset for Banner -->
        <div class="banner-bg">
            <img
                src="/images/lineas/balik/hero/langostino.jpg"
                alt="Background"
            />
            <div class="banner-overlay"></div>
        </div>
    </section>

    <!-- Marine Scrollytelling Experience starts after banner -->
    <BalikExperience />

    <Footer />

    <style>
        .balik-static-banner {
            position: relative;
            height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            color: white;
            background: #050a14;
            z-index: 20;
            padding-top: 5rem;
        }

        .banner-content {
            position: relative;
            z-index: 10;
            text-align: center;
            max-width: 60rem;
            padding: 2rem;
        }

        .banner-logo-wrapper {
            margin-bottom: 2rem;
        }

        .banner-logo {
            height: clamp(100px, 15vw, 160px);
            width: auto;
        }

        .banner-card {
            padding: 3rem 4rem;
            border-radius: 1.5rem;
        }

        .banner-card p {
            font-size: 1.2rem;
            line-height: 1.6;
            margin-bottom: 2.5rem;
            font-weight: 300;
            color: rgba(255, 255, 255, 0.95);
        }

        .banner-cta {
            display: inline-block;
            background: var(--brand-green);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 100px;
            font-weight: 700;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px rgba(103, 189, 69, 0.4);
        }

        .banner-cta:hover {
            background: white;
            color: var(--brand-green);
            transform: translateY(-3px);
        }

        .banner-bg {
            position: absolute;
            inset: 0;
            z-index: 1;
        }

        .banner-bg img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.6;
        }

        .banner-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom,
                rgba(255, 255, 255, 0),
                rgba(92, 113, 124, 0.443)
            );
        }

        [data-reveal] {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        [data-reveal].revealed {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <script>
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("revealed");
                    }
                });
            },
            { threshold: 0.1 },
        );

        document
            .querySelectorAll("[data-reveal]")
            .forEach((el) => observer.observe(el));
    </script>
</Layout>
