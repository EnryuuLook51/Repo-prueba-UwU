---
import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import "../../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Productos Balik | Green Prod & Sustainable";

const products = [
    {
        name: "Sistema de Filtrado ESG",
        desc: "Optimización de recursos hídricos para procesos marinos.",
    },
    {
        name: "Bio-Reactores Integrados",
        desc: "Ingeniería avanzada para el tratamiento de subproductos.",
    },
];
---

<Layout title={title}>
    <section class="products-header">
        <div class="custom-container">
            <a href="/lineas-de-negocio/balik" class="back-link">
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    class="arrow-back"
                >
                    <path d="M19 12H5M12 19l-7-7 7-7"></path>
                </svg>
                Volver a Balik
            </a>
            <h1 class="font-heading">Nuestros Productos</h1>
        </div>
    </section>

    <section class="products-grid">
        <div class="custom-container">
            <div class="grid">
                {
                    products.map((p) => (
                        <div class="p-card" data-reveal>
                            <h3 class="font-heading">{p.name}</h3>
                            <p class="font-body">{p.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    .products-header {
        padding: 10rem 0 4rem;
        background: white;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--brand-blue);
        text-decoration: none;
        font-family: var(--font-primary);
        font-weight: 700;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    .arrow-back {
        width: 1rem;
        height: 1rem;
    }

    h1 {
        font-size: 4rem;
        color: var(--text-primary);
    }

    .products-grid {
        padding: 4rem 0 10rem;
        background: var(--bg-main);
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }

    .p-card {
        background: white;
        padding: 2.5rem;
        border-radius: 1.5rem;
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .p-card:hover {
        transform: translateY(-5px);
        border-color: var(--brand-blue);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);
    }

    .p-card h3 {
        margin-bottom: 1rem;
        color: var(--brand-blue);
    }

    .p-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
    }

    [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("revealed");
                }
            });
        },
        { threshold: 0.1 },
    );

    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
</script>
