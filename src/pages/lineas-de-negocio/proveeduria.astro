---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Proveeduría | Green Prod & Sustainable";
---

<Layout title={title}>
    <!-- Hero Section -->
    <section class="provee-hero">
        <div class="hero-overlay"></div>
        <div class="custom-container relative z-10">
            <span class="badge" data-reveal
                >Línea de Suministro Estratégico</span
            >
            <div class="hero-content">
                <h1 class="font-heading" data-reveal>
                    {t("proveeduria.hero.title")}
                </h1>
                <p class="hero-desc" data-reveal>
                    {t("proveeduria.hero.desc")}
                </p>
            </div>
        </div>
    </section>

    <!-- Quienes Somos / Identidad -->
    <section class="provee-identity">
        <div class="custom-container">
            <div class="identity-grid">
                <div class="identity-text" data-reveal>
                    <h2 class="font-heading">
                        {t("proveeduria.identity.title")}
                    </h2>
                    <p class="font-body mt-6">
                        {t("proveeduria.identity.p1")}
                    </p>
                    <p class="font-body mt-4">
                        {t("proveeduria.identity.p2")}
                    </p>
                    <div class="mt-10">
                        <a href="/contacto" class="btn-cta-green">
                            {t("proveeduria.cta.button")}
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-2"
                            >
                                <path d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                </div>
                <div class="identity-visual" data-reveal>
                    <div class="stats-box">
                        <div class="stat-item">
                            <span class="num">100%</span>
                            <span class="lab">Trazable</span>
                        </div>
                        <div class="stat-item">
                            <span class="num">24/7</span>
                            <span class="lab">Operativo</span>
                        </div>
                    </div>
                    <img
                        src="/images/lineas/proveeduria/proveeduri.jpeg"
                        alt="Logística de Proveeduría"
                        class="rounded-3xl shadow-2xl transition-transform duration-700 hover:scale-105"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Propuesta de Valor -->
    <section class="provee-value">
        <!-- Background Elements -->
        <div class="value-bg-patterns">
            <div class="pattern-wavy"></div>
            <div class="pattern-leaf left"></div>
            <div class="pattern-leaf right"></div>
        </div>

        <div class="custom-container relative z-10">
            <div class="section-header text-center mb-20" data-reveal>
                <h2 class="value-title font-heading">
                    {t("proveeduria.valor.title")}
                    <span class="title-underline"></span>
                </h2>
            </div>

            <div class="value-grid">
                {
                    [1, 2, 3].map((i) => (
                        <div class="value-card" data-reveal>
                            <div class="card-image">
                                <img
                                    src={`/images/propuesta-de-valor/${["abastecimiento", "rapidez", "calidad"][i - 1]}.png`}
                                    alt={t(
                                        `proveeduria.valor.item${i}.title` as any,
                                    )}
                                />
                            </div>
                            <div class="card-content">
                                <h3>
                                    {t(
                                        `proveeduria.valor.item${i}.title` as any,
                                    )}
                                </h3>
                                <p>
                                    {t(
                                        `proveeduria.valor.item${i}.desc` as any,
                                    )}
                                </p>
                            </div>
                        </div>
                    ))
                }
                <div class="value-row-bottom">
                    {
                        [4, 5].map((i) => (
                            <div class="value-card" data-reveal>
                                <div class="card-image">
                                    <img
                                        src={`/images/propuesta-de-valor/${["relacion", "pesca"][i - 4]}.png`}
                                        alt={t(
                                            `proveeduria.valor.item${i}.title` as any,
                                        )}
                                    />
                                </div>
                                <div class="card-content">
                                    <h3>
                                        {t(
                                            `proveeduria.valor.item${i}.title` as any,
                                        )}
                                    </h3>
                                    <p>
                                        {t(
                                            `proveeduria.valor.item${i}.desc` as any,
                                        )}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <div class="cta-wrap text-center mt-20" data-reveal>
                <a href="/contacto" class="btn-conecta">
                    CONECTA CON NOSOTROS
                </a>
            </div>
        </div>
    </section>

    <!-- Valor Diferencial -->
    <section class="provee-diff">
        <div class="custom-container">
            <div class="diff-header" data-reveal>
                <h2 class="font-heading">
                    {t("proveeduria.diferencial.title")}
                </h2>
            </div>
            <div class="diff-stack mt-12">
                {
                    [1, 2, 3, 4, 5].map((i) => (
                        <div class="diff-row" data-reveal>
                            <span class="row-num">0{i}</span>
                            <div class="row-content">
                                <h3>
                                    {t(
                                        `proveeduria.diferencial.item${i}.title` as any,
                                    )}
                                </h3>
                                <p>
                                    {t(
                                        `proveeduria.diferencial.item${i}.desc` as any,
                                    )}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Productos -->
    <section class="provee-products">
        <div class="custom-container">
            <div class="products-box" data-reveal>
                <h2 class="font-heading text-center">
                    {t("proveeduria.productos.title")}
                </h2>
                <p class="text-center mt-4 max-w-2xl mx-auto opacity-70">
                    {t("proveeduria.productos.desc")}
                </p>
                <div class="categories-grid mt-16">
                    {
                        [1, 2, 3, 4, 5].map((i) => (
                            <div class="cat-pill">
                                <i class="fas fa-check-circle" />
                                <span>
                                    {t(`proveeduria.productos.cat${i}` as any)}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Infraestructura y Capacidad -->
    <section class="provee-infra">
        <div class="custom-container">
            <h2 class="section-title text-center" data-reveal>
                {t("proveeduria.infra.title")}
            </h2>
            <div class="infra-grid mt-16">
                {
                    [1, 2, 3, 4, 5].map((i) => (
                        <div class="infra-card" data-reveal>
                            <div class="infra-icon">
                                <i
                                    class={`fas fa-${["industry", "snowflake", "tools", "microscope", "user-tie"][i - 1]}`}
                                />
                            </div>
                            <div class="infra-text">
                                <h3>
                                    {t(
                                        `proveeduria.infra.item${i}.title` as any,
                                    )}
                                </h3>
                                <p>
                                    {t(
                                        `proveeduria.infra.item${i}.desc` as any,
                                    )}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- CTA Final -->
    <section class="provee-cta">
        <div class="custom-container text-center" data-reveal>
            <h2 class="font-heading">
                ¿Listo para optimizar su operación naval?
            </h2>
            <p class="mt-6 text-xl opacity-80">
                Contáctenos hoy para una cotización personalizada y trazable.
            </p>
            <div class="mt-10 flex justify-center gap-6">
                <a href="mailto:ventas@greenprod.pe" class="btn-main"
                    >Escríbanos</a
                >
                <a href="https://wa.me/51950412534" class="btn-outline"
                    >WhatsApp</a
                >
            </div>
        </div>
    </section>

    <Footer />

    <style>
        /* Hero */
        .provee-hero {
            padding: 16rem 0 12rem;
            background: url("/images/lineas/proveeduria/hero.png") center/cover
                no-repeat;
            background-attachment: fixed; /* Parallax básico */
            position: relative;
            color: white;
            overflow: hidden;
        }
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom,
                rgba(2, 69, 122, 0.6),
                rgba(97, 173, 223, 0.4)
            );
        }
        .badge {
            display: inline-block;
            padding: 0.6rem 1.4rem;
            background: var(--linea-proveeduria);
            color: white;
            border-radius: 100px;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 2rem;
            box-shadow: 0 5px 15px rgba(97, 173, 223, 0.3);
        }
        .provee-hero h1 {
            font-size: clamp(4rem, 10vw, 6.5rem);
            line-height: 0.95;
            margin-bottom: 2rem;
            font-family: var(--font-primary);
            font-weight: 800;
        }
        .hero-desc {
            font-size: 1.75rem;
            max-width: 800px;
            line-height: 1.4;
            opacity: 0.95;
            font-family: var(--font-secondary);
        }

        .provee-identity {
            padding: 10rem 0;
            background: white;
        }

        .btn-cta-green {
            display: inline-flex;
            align-items: center;
            background: var(--brand-green);
            color: white;
            padding: 1.2rem 3rem;
            border-radius: 100px;
            font-weight: 800;
            text-decoration: none;
            letter-spacing: 0.05em;
            font-size: 0.95rem;
            box-shadow: 0 10px 30px rgba(103, 189, 69, 0.3);
            transition: all 0.4s var(--transition-premium);
        }

        .btn-cta-green:hover {
            transform: translateY(-5px);
            background: var(--brand-blue);
            box-shadow: 0 20px 40px rgba(0, 109, 182, 0.4);
        }

        .btn-cta-green svg {
            margin-left: 0.75rem;
            width: 1.25rem;
            height: 1.25rem;
            transition: transform 0.3s ease;
        }

        .btn-cta-green:hover svg {
            transform: translateX(5px);
        }

        .identity-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center;
        }
        .identity-text h2 {
            font-size: 3.5rem;
            color: var(--linea-proveeduria);
            font-family: var(--font-primary);
            line-height: 1.1;
        }
        .identity-visual {
            position: relative;
        }
        .stats-box {
            position: absolute;
            bottom: -2rem;
            left: -2rem;
            background: white;
            padding: 2rem;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
            display: flex;
            gap: 3rem;
            z-index: 5;
        }
        .stat-item {
            display: flex;
            flex-direction: column;
        }
        .stat-item .num {
            font-size: 2rem;
            font-weight: 900;
            color: var(--brand-green);
            line-height: 1;
        }
        .stat-item .lab {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--linea-proveeduria);
            letter-spacing: 0.1em;
            margin-top: 0.5rem;
        }

        /* Propuesta de Valor */
        .provee-value {
            padding: 10rem 0;
            background: radial-gradient(
                circle at 50% 50%,
                rgba(103, 189, 69, 0.05) 0%,
                rgba(255, 255, 255, 1) 100%
            );
            position: relative;
            overflow: hidden;
        }

        .value-bg-patterns {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .pattern-wavy {
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg width='100%25' height='100%25' viewBox='0 0 1000 1000' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0,500 C150,400 350,600 500,500 C650,400 850,600 1000,500' fill='none' stroke='white' stroke-width='2' opacity='0.3'/%3E%3Cpath d='M0,450 C150,350 350,550 500,450 C650,350 850,550 1000,450' fill='none' stroke='white' stroke-width='1.5' opacity='0.2'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 800px;
            opacity: 0.5;
        }

        .pattern-leaf {
            position: absolute;
            width: 400px;
            height: 600px;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M100,20 C120,50 140,80 140,110 C140,150 100,180 100,180 C100,180 60,150 60,110 C60,80 80,50 100,20' fill='%2367bd45' opacity='0.1'/%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-size: contain;
            opacity: 0.1;
        }

        .pattern-leaf.left {
            left: -100px;
            bottom: 10%;
            transform: rotate(25deg);
        }
        .pattern-leaf.right {
            right: -100px;
            top: 10%;
            transform: rotate(-25deg);
        }

        .value-title {
            font-size: 3.5rem;
            color: var(--linea-proveeduria);
            position: relative;
            display: inline-block;
            padding-bottom: 0.5rem;
        }

        .title-underline {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 10px;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 10' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0,5 Q25,0 50,5 T100,5' fill='none' stroke='%23006db6' stroke-width='2'/%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-size: contain;
        }

        .value-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 3rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .value-row-bottom {
            grid-column: 1 / -1;
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-top: 1rem;
        }

        .value-card {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 40px;
            padding: 4rem 2.5rem;
            text-align: center;
            transition: all 0.5s var(--transition-premium);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.04);
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            max-width: 380px;
        }

        .value-card:hover {
            transform: translateY(-15px) scale(1.03);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.08);
            border-color: var(--brand-green);
        }

        .card-image {
            width: 100%;
            height: 200px;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.6s ease;
        }

        .value-card:hover .card-image {
            transform: scale(1.1);
        }

        .card-image img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 0 15px rgba(103, 189, 69, 0.1));
        }

        .card-content h3 {
            font-size: 1.6rem;
            color: var(--linea-proveeduria);
            font-family: var(--font-primary);
            font-weight: 700;
            margin-bottom: 1.2rem;
        }

        .card-content p {
            font-size: 1.05rem;
            color: #64748b;
            line-height: 1.6;
            font-family: var(--font-secondary);
        }

        .btn-conecta {
            display: inline-block;
            background: white;
            color: var(--linea-proveeduria);
            padding: 1.2rem 3rem;
            border-radius: 100px;
            font-weight: 800;
            text-decoration: none;
            letter-spacing: 0.1em;
            font-size: 0.9rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            border: 1px solid #f1f5f9;
            transition: all 0.4s var(--transition-premium);
        }

        .btn-conecta:hover {
            background: var(--linea-proveeduria);
            color: white;
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 109, 182, 0.3);
        }

        @media (max-width: 1100px) {
            .value-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .value-row-bottom {
                grid-column: auto;
                flex-direction: column;
                align-items: center;
            }
            .value-card {
                max-width: 100%;
            }
        }

        @media (max-width: 768px) {
            .value-grid {
                grid-template-columns: 1fr;
            }
            .value-title {
                font-size: 2.5rem;
            }
        }

        /* Diferencial */
        .provee-diff {
            padding: 10rem 0;
            background: white;
        }
        .diff-stack {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .diff-row {
            display: flex;
            gap: 3rem;
            padding: 3rem;
            background: #fdfdfd;
            border: 1px solid #f1f5f9;
            border-radius: 20px;
            align-items: center;
            transition: border-color 0.3s ease;
        }
        .diff-row:hover {
            border-color: var(--brand-blue-3);
        }
        .row-num {
            font-size: 3rem;
            font-weight: 900;
            color: var(--linea-proveeduria);
            opacity: 0.3;
        }
        .row-content h3 {
            font-size: 1.5rem;
            color: var(--linea-proveeduria);
            margin-bottom: 0.5rem;
        }
        .row-content p {
            color: #475569;
            font-size: 1.2rem;
            line-height: 1.6;
            font-family: var(--font-secondary);
        }

        /* Productos */
        .provee-products {
            padding: 8rem 0;
            background: var(--linea-proveeduria);
            color: white;
        }
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }
        .cat-pill {
            background: rgba(255, 255, 255, 0.05);
            padding: 1.5rem 2rem;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 1.1rem;
        }
        .cat-pill i {
            color: var(--brand-green);
        }

        /* Infra */
        .provee-infra {
            padding: 10rem 0;
            background: white;
        }
        .infra-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 3rem;
        }
        .infra-card {
            display: flex;
            gap: 2rem;
            padding: 2.5rem;
            background: #f8fafc;
            border-radius: 24px;
            align-items: flex-start;
        }
        .infra-icon {
            width: 50px;
            height: 50px;
            min-width: 50px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--brand-blue);
            font-size: 1.25rem;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        }
        .infra-text h3 {
            font-size: 1.2rem;
            color: var(--brand-blue);
            margin-bottom: 0.5rem;
        }
        .infra-text p {
            font-size: 1.05rem;
            color: #64748b;
            line-height: 1.6;
            font-family: var(--font-secondary);
        }

        /* CTA */
        .provee-cta {
            padding: 10rem 0;
            background: linear-gradient(
                rgba(103, 189, 69, 0.05),
                rgba(2, 69, 122, 0.05)
            );
        }
        .btn-main {
            background: var(--brand-blue);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 100px;
            font-weight: 700;
            transition: all 0.3s ease;
        }
        .btn-main:hover {
            background: var(--linea-proveeduria);
            transform: translateY(-5px);
        }
        .btn-outline {
            border: 2px solid var(--brand-blue);
            color: var(--brand-blue);
            padding: 1rem 2.5rem;
            border-radius: 100px;
            font-weight: 700;
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background: var(--brand-blue);
            color: white;
            transform: translateY(-5px);
        }

        /* Reveal animations */
        [data-reveal] {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }
        [data-reveal].revealed {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 1024px) {
            .identity-grid {
                grid-template-columns: 1fr;
                gap: 4rem;
            }
        }
    </style>

    <script>
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry, index) => {
                    if (entry.isIntersecting) {
                        // Stagger effect for items in the same container
                        setTimeout(
                            () => {
                                entry.target.classList.add("revealed");
                            },
                            (index % 5) * 150,
                        );
                    }
                });
            },
            { threshold: 0.15 },
        );
        document
            .querySelectorAll("[data-reveal]")
            .forEach((el) => observer.observe(el));

        // Parallax smooth script (optional mobile fix)
        window.addEventListener("scroll", () => {
            const scrolled = window.pageYOffset;
            const hero = document.querySelector(".provee-hero") as HTMLElement;
            if (hero) {
                hero.style.backgroundPositionY = -(scrolled * 0.25) + "px";
            }
        });
    </script>
</Layout>
