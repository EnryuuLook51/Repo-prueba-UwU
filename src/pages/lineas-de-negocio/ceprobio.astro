---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Ceprobio | Bioinsumos Agrícolas | Green Prod & Sustainable";
---

<Layout title={title}>
    <!-- Hero Section -->
    <section class="ceprobio-hero">
        <div class="custom-container">
            <span class="badge" data-reveal>Línea de Biotecnología</span>
            <div class="hero-content">
                <h1 class="font-heading" data-reveal>
                    BIOINSUMOS <br /><span class="text-white/80">AGRÍCOLAS</span
                    >
                </h1>
                <p class="slogan" data-reveal>
                    Incentivamos a la agricultura orgánica y sostenible
                </p>
                <div class="hero-actions" data-reveal>
                    <a
                        href="/lineas-de-negocio/ceprobio/productos"
                        class="cta-button primary"
                    >
                        Ver Catálogo 2026
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            class="arrow"
                        >
                            <path d="M5 12h14M12 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="intro-section">
        <div class="custom-container">
            <div class="intro-grid">
                <div class="intro-text" data-reveal>
                    <h2 class="font-heading">
                        ¿Qué es <span class="text-brand-green">CEPROBIO?</span>
                    </h2>
                    <p class="font-body">
                        Es un centro de producción de bioinsumos agrícolas, que
                        a través de soluciones biotecnológicas, contribuimos con
                        nuestros productos a optimizar la productividad de los
                        cultivos, restaurar el equilibrio natural de los campos
                        y reducir progresivamente la dependencia de
                        agroquímicos.
                    </p>
                    <p class="font-body mt-4">
                        Aquí producimos productos <strong>100% orgánicos</strong
                        >, a base de hongos y bacterias beneficiosas capaces de
                        mejorar la salud del suelo, estimular el desarrollo
                        radicular y fortalecer las defensas naturales de los
                        cultivos.
                    </p>
                </div>
                <div class="intro-visual" data-reveal>
                    <div class="image-box">
                        <img
                            src="/images/lineas/ceprobio/laboratorio.jpg"
                            alt="Laboratorio Ceprobio"
                            class="img-fluid"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mision Vision / Enfoque -->
    <section class="enfoque-corporativo">
        <div class="custom-container">
            <div class="mv-flex">
                <div class="mv-item" data-reveal>
                    <div class="mv-header">
                        <span class="mv-label">01</span>
                        <h3 class="font-heading">Visión</h3>
                    </div>
                    <p>
                        Reducir los impactos ambientales producidos por
                        agroquímicos y transformar la agricultura a través de
                        biotecnología aplicada.
                    </p>
                </div>

                <div class="mv-item" data-reveal>
                    <div class="mv-header">
                        <span class="mv-label">02</span>
                        <h3 class="font-heading">Enfoque</h3>
                    </div>
                    <p>
                        Promover una agricultura más orgánica, sostenible y
                        responsable, optimizando la salud y nutrición de los
                        suelos.
                    </p>
                </div>

                <div class="mv-item" data-reveal>
                    <div class="mv-header">
                        <span class="mv-label">03</span>
                        <h3 class="font-heading">Misión</h3>
                    </div>
                    <p>
                        Ser el aliado estratégico de agricultores y exportadores
                        que buscan rentabilidad mediante soluciones
                        biotecnológicas eficaces.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Áreas de Trabajo -->
    <section class="areas-section">
        <div class="custom-container">
            <h2 class="section-title font-heading" data-reveal>
                BIOTECNOLOGÍA APLICADA
            </h2>
            <div class="areas-grid">
                <div class="area-item" data-reveal>
                    <div class="area-number">01</div>
                    <h4 class="font-heading">I+D</h4>
                    <p>
                        Nuestro laboratorio respalda la investigación,
                        evaluación y control de bioinsumos, garantizando calidad
                        y eficacia.
                    </p>
                </div>
                <div class="area-item" data-reveal>
                    <div class="area-number">02</div>
                    <h4 class="font-heading">Producción</h4>
                    <p>
                        Desarrollamos bioinsumos a base de microorganismos
                        benéficos para fortalecer los sistemas de producción
                        orgánica.
                    </p>
                </div>
                <div class="area-item" data-reveal>
                    <div class="area-number">03</div>
                    <h4 class="font-heading">Valorización</h4>
                    <p>
                        Transformamos residuos de pescado en hidrolizados,
                        aceites y materia orgánica para soluciones agrícolas.
                    </p>
                </div>
                <div class="area-item" data-reveal>
                    <div class="area-number">04</div>
                    <h4 class="font-heading">Equipo Técnico</h4>
                    <p>
                        Especialistas que supervisan cada proceso para asegurar
                        la trazabilidad y calidad total.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Capacidad Operativa -->
    <section class="capacidad-section">
        <div class="custom-container">
            <h2 class="font-heading text-center mb-12" data-reveal>
                Capacidad Operativa
            </h2>
            <div class="stats-grid">
                <div class="stat-box" data-reveal>
                    <span class="stat-value">1 Ton/mes</span>
                    <span class="stat-label">Planta de Bioinsumos</span>
                </div>
                <div class="stat-box" data-reveal>
                    <span class="stat-value">100 Ton/mes</span>
                    <span class="stat-label">Valorización de Residuos</span>
                </div>
                <div class="stat-box" data-reveal>
                    <span class="stat-value">Lab Equipado</span>
                    <span class="stat-label">Control de Calidad</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Contacto Rápido -->
    <section class="contact-strip">
        <div class="custom-container">
            <div class="strip-content" data-reveal>
                <div class="strip-text">
                    <h3 class="font-heading">¿Necesitas asesoría técnica?</h3>
                    <p>Contáctanos directamente para optimizar tus cultivos.</p>
                </div>
                <div class="strip-actions">
                    <a href="tel:+51919514085" class="btn-contact"
                        >919 514 085</a
                    >
                    <a
                        href="mailto:ceprobio@greenprod.pe"
                        class="btn-contact outline">ceprobio@greenprod.pe</a
                    >
                </div>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    .ceprobio-hero {
        padding: 14rem 0 8rem;
        background:
            linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)),
            url("/images/banners/ceprobio.jpg");
        background-size: cover;
        background-position: center;
        background-color: var(--brand-green);
        color: white;
        position: relative;
    }

    .badge {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        background: var(--brand-green);
        color: white;
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 2rem;
    }

    h1 {
        font-size: clamp(3rem, 10vw, 5.5rem);
        line-height: 0.9;
        margin-bottom: 1.5rem;
        /* Suave contorno blanco */
        text-shadow:
            1px 1px 0 #fff,
            -1px -1px 0 #fff,
            1px -1px 0 #fff,
            -1px 1px 0 #fff;
    }

    .slogan {
        font-family: var(--font-secondary);
        font-size: 1.5rem;
        font-weight: 300;
        margin-bottom: 3rem;
        max-width: 600px;
        /* Suave contorno blanco ligero */
        text-shadow: 0.5px 0.5px 0 rgba(255, 255, 255, 0.5);
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem 2.8rem;
        background: white;
        color: var(--brand-green);
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.4s var(--transition-premium);
    }

    .cta-button:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
        gap: 1.5rem;
    }

    .arrow {
        width: 1.2rem;
        height: 1.2rem;
    }

    /* Intro */
    .intro-section {
        padding: 10rem 0;
        background: white;
    }
    .intro-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 6rem;
        align-items: center;
    }
    .intro-text h2 {
        font-size: 3rem;
        margin-bottom: 2.5rem;
        line-height: 1.1;
    }
    .intro-text p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        line-height: 1.8;
    }

    /* MV Flex / Enfoque Corporativo */
    .enfoque-corporativo {
        padding: 8rem 0;
        background: white;
        border-bottom: 1px solid var(--border-color);
    }

    .mv-flex {
        display: flex;
        justify-content: space-between;
        gap: 4rem;
    }

    .mv-item {
        flex: 1;
        position: relative;
    }

    .mv-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .mv-label {
        font-family: var(--font-primary);
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--brand-green);
        position: relative;
        padding-left: 1.5rem;
    }

    .mv-label::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        width: 1rem;
        height: 2px;
        background: var(--brand-green);
        transform: translateY(-50%);
    }

    .mv-item h3 {
        font-size: 1.6rem;
        color: var(--text-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .mv-item p {
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--text-secondary);
        border-left: 2px solid var(--bg-main);
        padding-left: 1.5rem;
    }

    /* Areas */
    .areas-section {
        padding: 10rem 0;
        background: white;
    }
    .section-title {
        text-align: center;
        font-size: 3rem;
        margin-bottom: 5rem;
        color: var(--brand-green);
    }
    .areas-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 3rem;
    }
    .area-item {
        position: relative;
    }
    .area-number {
        font-size: 4rem;
        font-weight: 900;
        color: rgba(0, 153, 68, 0.1);
        line-height: 1;
        margin-bottom: 1rem;
    }
    .area-item h4 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }
    .area-item p {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    /* Capacidad */
    .capacidad-section {
        padding: 8rem 0;
        background: var(--text-primary);
        color: white;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        text-align: center;
    }
    .stat-value {
        display: block;
        font-size: 3rem;
        font-weight: 800;
        color: var(--brand-green);
        margin-bottom: 0.5rem;
    }
    .stat-label {
        font-family: var(--font-primary);
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.7;
    }

    /* Strip */
    .contact-strip {
        padding: 4rem 0;
        background: var(--brand-blue);
        color: white;
    }
    .strip-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .strip-actions {
        display: flex;
        gap: 1.5rem;
    }
    .btn-contact {
        padding: 1rem 2rem;
        background: white;
        color: var(--brand-blue);
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .btn-contact.outline {
        background: transparent;
        border: 2px solid white;
        color: white;
    }
    .btn-contact:hover {
        transform: scale(1.05);
    }

    [data-reveal] {
        opacity: 0;
        transform: translateY(30px);
        transition: all 1s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 1024px) {
        .intro-grid,
        .mv-flex,
        .areas-grid,
        .stats-grid {
            flex-direction: column;
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting)
                    entry.target.classList.add("revealed");
            });
        },
        { threshold: 0.15 },
    );

    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
</script>
