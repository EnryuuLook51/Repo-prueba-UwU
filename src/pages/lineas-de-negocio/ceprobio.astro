---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/pages/layout/Footer.astro";
import CeprobioExperience from "../../components/pages/ceprobio/CeprobioExperience.astro";
import BioParticles from "../../components/pages/ceprobio/BioParticles.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import "../../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Ceprobio | Bioinsumos Agrícolas | Green Prod & Sustainable";
---

<Layout title={title}>
    <!-- Hero Section con BioParticles -->
    <section class="ceprobio-hero">
        <BioParticles />
        <div class="custom-container">
            <span class="badge" data-reveal>Línea de Biotecnología</span>
            <div class="hero-content">
                <h1 class="font-heading" data-reveal>
                    BIOINSUMOS <br /><span class="text-white/80">AGRÍCOLAS</span
                    >
                </h1>
                <p class="slogan" data-reveal>
                    {t("navbar.ceprobio_desc")}
                </p>
                <div class="hero-actions" data-reveal>
                    <a
                        href="/lineas-de-negocio/ceprobio/productos"
                        class="cta-button primary"
                    >
                        Ver Catálogo 2026
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            class="arrow"
                        >
                            <path d="M5 12h14M12 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Interactive Storytelling Section (Entre Hero y Footer) -->
    <CeprobioExperience />

    <Footer />
</Layout>

<style>
    .ceprobio-hero {
        padding: 14rem 0 10rem;
        background:
            linear-gradient(
                135deg,
                rgba(10, 14, 10, 0.85) 0%,
                rgba(103, 189, 69, 0.3) 100%
            ),
            url("/images/banners/ceprobio.jpg");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .ceprobio-hero .custom-container {
        position: relative;
        z-index: 5;
    }

    /* Las partículas se inyectan con z-index 1 en su componente */

    .badge {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        background: var(--brand-green);
        color: white;
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 2rem;
    }

    h1 {
        font-size: clamp(3rem, 10vw, 5.5rem);
        line-height: 0.9;
        margin-bottom: 1.5rem;
        letter-spacing: -0.03em;
        text-transform: uppercase;
    }

    .slogan {
        font-family: var(--font-secondary);
        font-size: 1.6rem;
        font-weight: 300;
        margin-bottom: 3.5rem;
        max-width: 700px;
        opacity: 0.9;
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem 2.8rem;
        background: var(--brand-green);
        color: white;
        border-radius: 100px;
        font-family: var(--font-primary);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.4s var(--transition-premium);
        box-shadow: 0 10px 30px rgba(103, 189, 69, 0.3);
    }

    .cta-button:hover {
        background: white;
        color: black;
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(255, 255, 255, 0.2);
        gap: 1.5rem;
    }

    .arrow {
        width: 1.2rem;
        height: 1.2rem;
    }

    [data-reveal] {
        opacity: 0;
        transform: translateY(30px);
        transition: all 1s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting)
                    entry.target.classList.add("revealed");
            });
        },
        { threshold: 0.15 },
    );

    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
</script>
