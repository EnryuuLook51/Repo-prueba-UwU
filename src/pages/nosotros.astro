---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/pages/layout/Footer.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import "../styles/global.css";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = "Sobre Nosotros | Green Prod & Sustainable";
---

<Layout title={title}>
    <!-- Hero Section -->
    <section class="nosotros-hero">
        <div class="banner-overlay"></div>
        <div class="custom-container relative z-10">
            <h1 class="font-heading text-white reveal-text">
                {t("nosotros.hero.title")}
            </h1>
        </div>
    </section>

    <!-- Quienes Somos -->
    <section class="about-intro">
        <div class="custom-container">
            <div class="intro-grid">
                <div class="intro-content" data-reveal>
                    <span class="section-tag">{t("nosotros.about.title")}</span>
                    <h2 class="font-heading mt-4">
                        Nuestra Esencia Sostenible
                    </h2>
                    <p class="mt-8 text-lg text-slate-600 leading-relaxed">
                        {t("nosotros.about.p1")}
                    </p>
                    <p class="mt-4 text-lg text-slate-600 leading-relaxed">
                        {t("nosotros.about.p2")}
                    </p>
                </div>
                <div class="intro-visual" data-reveal>
                    <div class="experience-badge">
                        <span class="number">10+</span>
                        <span class="label">Años de Innovación</span>
                    </div>
                    <img
                        src="/images/banners/ceprobio.jpg"
                        alt="Innovación Green Prod"
                        class="rounded-2xl shadow-2xl"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Modelo Circular -->
    <section class="circular-model">
        <div class="custom-container">
            <h2 class="section-title text-center" data-reveal>
                {t("nosotros.modelo.title")}
            </h2>
            <div class="circular-grid mt-16">
                {
                    [1, 2, 3, 4].map((i) => (
                        <div class="circular-card" data-reveal>
                            <div class="card-icon-wrap">
                                <span class="card-num">0{i}</span>
                            </div>
                            <h3>{t(`nosotros.modelo.item${i}.title`)}</h3>
                            <p>{t(`nosotros.modelo.item${i}.desc`)}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Ejes Económicos -->
    <section class="economic-axes">
        <div class="custom-container">
            <h2 class="section-title text-center mb-20" data-reveal>
                {t("nosotros.ejes.title")}
            </h2>

            <div class="axes-stack">
                <!-- Planta Residuos -->
                <div class="axis-item" data-reveal>
                    <div class="axis-header">
                        <div class="axis-title-wrap">
                            <span class="axis-label">Operación 01</span>
                            <h3 class="font-heading">
                                {t("nosotros.ejes.planta.title")}
                            </h3>
                        </div>
                    </div>
                    <div class="axis-details">
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.productos")}</h4>
                            <ul>
                                <li>
                                    Hidrolizado de pescado (1L, 4L, 20L, 200L,
                                    1000L)
                                </li>
                                <li>Materia orgánica sólida</li>
                                <li>Aceite de pescado para uso agrícola</li>
                                <li>Biofertilizante sólido y líquido</li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.licencias")}</h4>
                            <ul>
                                <li>Convenio con SENASA</li>
                                <li>Licencia de operaciones</li>
                                <li>Análisis de macro y micronutrientes</li>
                                <li>Aminogramas por lote</li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.capacidad")}</h4>
                            <ul>
                                <li>01 planta de procesamiento de residuos</li>
                                <li>10 Toneladas de residuo por mes</li>
                                <li>
                                    02 Toneladas de materia orgánica por mes
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Ceprobio -->
                <div class="axis-item inverse" data-reveal>
                    <div class="axis-header">
                        <div class="axis-title-wrap">
                            <span class="axis-label">Operación 02</span>
                            <h3 class="font-heading">
                                {t("nosotros.ejes.ceprobio.title")}
                            </h3>
                        </div>
                    </div>
                    <div class="axis-details">
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.productos")}</h4>
                            <ul>
                                <li>Insecticidas biológicos</li>
                                <li>Fungicidas biológicos</li>
                                <li>Nematicidas biológicos</li>
                                <li>
                                    Polvo mojable de 500 gr • Sustrato sólido
                                </li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.licencias")}</h4>
                            <ul>
                                <li>Convenio con SENASA</li>
                                <li>Licencia de operaciones</li>
                                <li>Cepas nativas controladas</li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.capacidad")}</h4>
                            <ul>
                                <li>01 laboratorio debidamente implementado</li>
                                <li>
                                    Producción de bioinsumos: Beauveria,
                                    Metarhizium, Lilacinus, Isaria, Bacillus
                                    Subtilis, Thuringiensis, Trichoderma.
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Balik -->
                <div class="axis-item" data-reveal>
                    <div class="axis-header">
                        <div class="axis-title-wrap">
                            <span class="axis-label">Operación 03</span>
                            <h3 class="font-heading">
                                {t("nosotros.ejes.balik.title")}
                            </h3>
                        </div>
                    </div>
                    <div class="axis-details">
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.productos")}</h4>
                            <ul>
                                <li>Fresco refrigerado</li>
                                <li>Filetes congelados</li>
                                <li>Empacados al vacío</li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.licencias")}</h4>
                            <ul>
                                <li>Protocolo técnico sanitario</li>
                                <li>Licencia de operaciones</li>
                                <li>
                                    Licencia de funcionamiento y Defensa civil
                                </li>
                            </ul>
                        </div>
                        <div class="detail-col">
                            <h4>{t("nosotros.ejes.capacidad")}</h4>
                            <ul>
                                <li>01 planta de procesamiento primario</li>
                                <li>03 Ton/día de pescado</li>
                                <li>01 Tonelada de almacenamiento</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="team-section">
        <div class="custom-container">
            <h2 class="section-title text-center" data-reveal>
                {t("nosotros.team.title")}
            </h2>
            <div class="team-flex mt-16">
                <div class="team-card" data-reveal>
                    <div class="team-info">
                        <h3>David Salazar</h3>
                        <span>CEO</span>
                    </div>
                </div>
                <div class="team-card" data-reveal>
                    <div class="team-info">
                        <h3>Wilmer Guzman</h3>
                        <span>COO</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    .nosotros-hero {
        padding: 18rem 0 10rem;
        background: url("/images/banners/ceprobio.jpg") center/cover no-repeat;
        position: relative;
        text-align: center;
    }
    .banner-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.3),
            rgba(0, 0, 0, 0.5)
        );
    }
    .nosotros-hero h1 {
        font-size: clamp(3rem, 8vw, 5rem);
        line-height: 1.1;
        text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
    }

    .about-intro {
        padding: 10rem 0;
        background: white;
    }
    .intro-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 6rem;
        align-items: center;
    }
    .section-tag {
        color: var(--brand-green);
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }
    .intro-visual {
        position: relative;
    }
    .experience-badge {
        position: absolute;
        top: -2rem;
        left: -2rem;
        background: var(--brand-green);
        color: white;
        padding: 2rem;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 20px 40px rgba(76, 175, 80, 0.3);
        z-index: 5;
    }
    .experience-badge .number {
        font-size: 2.5rem;
        font-weight: 900;
        line-height: 1;
    }
    .experience-badge .label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
        margin-top: 0.5rem;
    }

    .circular-model {
        padding: 8rem 0;
        background: #f8fafc;
    }
    .section-title {
        font-size: 3rem;
        color: var(--brand-blue);
    }
    .circular-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2.5rem;
    }
    .circular-card {
        background: white;
        padding: 3rem;
        border-radius: 24px;
        transition: all 0.4s ease;
        border: 1px solid #e2e8f0;
    }
    .circular-card:hover {
        transform: translateY(-10px);
        border-color: var(--brand-green);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }
    .card-num {
        color: var(--brand-green);
        font-weight: 900;
        font-size: 1.2rem;
        opacity: 0.3;
    }
    .circular-card h3 {
        font-size: 1.3rem;
        margin: 1.5rem 0 1rem;
        color: var(--text-primary);
        line-height: 1.3;
    }
    .circular-card p {
        color: var(--text-secondary);
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .economic-axes {
        padding: 10rem 0;
        background: white;
    }
    .axes-stack {
        display: flex;
        flex-direction: column;
        gap: 4rem;
    }
    .axis-item {
        background: #fdfdfd;
        border: 1px solid #f1f5f9;
        border-radius: 30px;
        padding: 4rem;
        transition: all 0.4s ease;
    }
    .axis-item:hover {
        border-color: var(--brand-green);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.04);
    }
    .axis-label {
        color: var(--brand-green);
        font-weight: 800;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .axis-header h3 {
        font-size: 2.5rem;
        margin-top: 0.5rem;
        color: var(--brand-blue);
    }

    .axis-details {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4rem;
        margin-top: 4rem;
    }
    .detail-col h4 {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: #94a3b8;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        font-weight: 800;
    }
    .detail-col ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }
    .detail-col li {
        font-size: 0.95rem;
        color: #475569;
        position: relative;
        padding-left: 1.5rem;
        line-height: 1.4;
    }
    .detail-col li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.6rem;
        width: 6px;
        height: 6px;
        background: var(--brand-green);
        border-radius: 50%;
    }

    .team-section {
        padding: 8rem 0 12rem;
        background: #f8fafc;
    }
    .team-flex {
        display: flex;
        justify-content: center;
        gap: 4rem;
    }
    .team-card {
        background: white;
        padding: 3rem;
        border-radius: 20px;
        min-width: 300px;
        text-align: center;
        border: 1px solid #e2e8f0;
    }
    .team-info h3 {
        font-size: 1.8rem;
        color: var(--brand-blue);
        margin-bottom: 0.5rem;
    }
    .team-info span {
        color: var(--brand-green);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.8rem;
    }

    @media (max-width: 1024px) {
        .intro-grid,
        .axis-details {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .axis-item {
            padding: 2.5rem;
        }
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting)
                    entry.target.classList.add("revealed");
            });
        },
        { threshold: 0.1 },
    );

    document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
</script>
